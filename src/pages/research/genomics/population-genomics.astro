---
const coreAreas = [
  [
    'Human Genetic Diversity',
    'Understanding how genomic variation differs across individuals and populations, and how this diversity shapes biological traits, ancestry, and disease risk.',
  ],
  [
    'Population Genetics',
    'Studying allele frequencies, recombination, selection, drift, and demographic processes that shape genomes across generations.',
  ],
  [
    'Evolutionary Genomics',
    'Exploring how genomes change over time to reveal adaptation, evolutionary history, comparative biology, and species relationships.',
  ],
  [
    'Genomic Epidemiology',
    'Applying genomic data to investigate disease transmission, pathogen evolution, outbreak surveillance, and public health dynamics.',
  ],
];

const resources = [
  ['Human Genome Project', 'Established the first reference framework for modern human genomics and large-scale biological data.'],
  ['1000 Genomes Project', 'Created a global catalog of common and low-frequency human genetic variation across populations.'],
  ['Human Pangenome Reference Consortium', 'Expanded reference genomics beyond a single human genome to better capture global diversity.'],
  ['UK Biobank', 'A major population resource linking genomic data with rich phenotype and health information.'],
  ['All of Us Research Program', 'A large-scale precision medicine initiative designed to improve representation and diversity in biomedical research.'],
  ['Human Cell Atlas', 'A global effort to map human cells and their molecular states across tissues and populations.'],
];

const methods = [
  ['Genome-wide Association Studies (GWAS)', 'Associating common genetic variants with traits, disease susceptibility, and complex human phenotypes.'],
  ['Population Structure Analysis', 'Modeling ancestry, clustering, and demographic structure across populations and cohorts.'],
  ['Haplotype Analysis', 'Studying linked genetic variants inherited together across chromosomes and populations.'],
  ['Admixture Analysis', 'Investigating mixed ancestry and the genomic contributions of multiple ancestral populations.'],
  ['Phylogenomics', 'Using genomic data to reconstruct evolutionary relationships and population histories.'],
  ['Polygenic Risk Scores', 'Aggregating many genetic variants to estimate risk for complex disease and precision health applications.'],
];

const timeline = [
  [
    '1990–2003',
    'Human Genome Project',
    'Established the first reference framework for studying human genetic variation at genome scale.'
  ],
  [
    '2002–2010',
    'International HapMap Project',
    'Mapped common patterns of human genetic variation and linkage disequilibrium, supporting population genetics and genome-wide association studies.'
  ],
  [
    '2008–2015',
    '1000 Genomes Project',
    'Transformed the study of global human variation through population-scale sequencing across diverse populations.'
  ],
  [
    '2012–Present',
    'Biobank-Scale Genomics',
    'Large biobanks link genomic data with phenotypes, health records, ancestry, environment, and population health outcomes.'
  ],
  [
    '2023–Present',
    'Human Pangenome Reference',
    'Improves reference genomics by representing broader human genomic diversity beyond a single linear reference genome.'
  ],
  [
    'Present',
    'Global Precision Medicine',
    'Population genomics increasingly informs risk prediction, public health, ancestry-aware analysis, and more inclusive precision medicine.'
  ],
];

const publications = [
  ['The International HapMap Project', 'International HapMap Consortium', 'Nature • 2003'],
  ['A Map of Human Genome Variation from Population-Scale Sequencing', '1000 Genomes Project Consortium', 'Nature • 2010'],
  ['Genome-wide Association Studies and Human Disease', 'Population genomics and GWAS landmark studies', 'Nature Reviews Genetics'],
  ['The UK Biobank Resource with Deep Phenotyping and Genomic Data', 'UK Biobank investigators', 'Nature'],
  ['A Draft Human Pangenome Reference', 'Human Pangenome Reference Consortium', 'Nature • 2023'],
  ['Population Genomics in Precision Medicine', 'Precision health and genomic diversity studies', 'NEJM / Nature Medicine'],
];

const related = [
  ['Genome Sequencing', '/research/genomics/genome-sequencing'],
  ['Variant Discovery', '/research/genomics/variant-discovery'],
  ['Precision Medicine', '/research/genomics/precision-medicine'],
];
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Population Genomics | PanorOmics Research</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      background:#020817;
      color:white;
      font-family:Inter,sans-serif;
      overflow-x:hidden;
    }

    .container{
      max-width:1200px;
      margin:auto;
      padding:80px 7% 70px;
    }

    .back{
      color:#3b82f6;
      text-decoration:none;
      font-size:.9rem;
      font-weight:700;
    }

    .hero{
      margin-top:34px;
    }

    .hero h1{
      font-size:clamp(2.7rem,5vw,4.8rem);
      line-height:.95;
      letter-spacing:-.055em;
      margin-bottom:18px;
    }

    .hero h1 span{
      color:#3b82f6;
    }

    .hero p{
      color:#cbd5e1;
      font-size:1rem;
      line-height:1.8;
      max-width:900px;
    }

    .hero-image{
      margin-top:36px;
      width:100vw;
      margin-left:calc(50% - 50vw);
    }

    .hero-image img{
      width:100%;
      display:block;
      border-radius:24px;
      border:1px solid rgba(59,130,246,.14);
    }

    .section{
      margin-top:64px;
    }

    .section h2{
      font-size:2rem;
      margin-bottom:16px;
    }

    .section h2 span{
      color:#3b82f6;
    }

    .section p{
      color:#cbd5e1;
      line-height:1.9;
      font-size:1rem;
      margin-bottom:16px;
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:20px;
      margin-top:24px;
    }

    .card{
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:24px;
    }

    .card h3{
      color:#3b82f6;
      margin-bottom:10px;
      line-height:1.3;
    }

    .card p{
      margin:0;
      font-size:.92rem;
      color:#cbd5e1;
    }

    .timeline{
      display:grid;
      gap:16px;
      margin-top:24px;
    }

    .timeline-item{
      display:grid;
      grid-template-columns:120px 1fr;
      gap:18px;
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:20px;
    }

    .year{
      color:#3b82f6;
      font-weight:900;
      font-size:1.15rem;
    }

    .paper{
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:22px;
    }

    .paper h3{
      color:#3b82f6;
      margin-bottom:8px;
    }

    .meta{
      color:#94a3b8;
      font-size:.86rem;
      line-height:1.5;
    }

    .button{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      margin-top:24px;
      padding:12px 24px;
      border-radius:999px;
      background:#2563eb;
      color:white;
      text-decoration:none;
      font-weight:700;
    }

    .card-link{
      text-decoration:none;
      color:inherit;
      display:block;
      transition:.25s ease;
      cursor:pointer;
    }

    .card-link:hover{
      transform:translateY(-4px);
      border-color:#3b82f6;
      box-shadow:0 12px 30px rgba(59,130,246,.15);
    }

    .secondary-button{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      margin-top:12px;
      padding:14px 30px;
      border-radius:999px;
      background:#8C1515;
      color:#ffffff;
      border:1px solid #A77A7A;
      text-decoration:none;
      font-weight:700;
      transition:.25s ease;
    }

    .secondary-button:hover{
      background:#6F1111;
      border-color:#8C1515;
      transform:translateY(-2px);
    }

    @media(max-width:768px){
      .container{
        padding:70px 20px 55px;
      }

      .timeline-item{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <a href="/genomics" class="back">
      ← Back to Genomics
    </a>

    <section class="hero">

      <h1>
        Population <span>Genomics</span>
      </h1>

      <p>
        Population genomics studies genetic variation across individuals and populations to understand ancestry, evolution, disease susceptibility, public health, and global precision medicine. It connects genomic diversity to biology at the scale of people, communities, and populations.
      </p>

      <div class="hero-image">
        <img
          src="/research-population-genomics-hero-v1.png"
          alt="Population Genomics Research"
        >
      </div>

    </section>

    <section class="section">

      <h2>
        Research <span>Overview</span>
      </h2>

      <p>
        Population genomics examines how genetic variation is distributed across populations and how evolutionary history, migration, natural selection, demography, and environmental pressures shape genomes over time. These approaches provide essential insights into ancestry, adaptation, complex disease, and human diversity.
      </p>

      <p>
        At PanorOmics, population genomics represents the large-scale human dimension of genomics. It links genome sequencing, variant discovery, and precision medicine to population structure, epidemiology, and global biological understanding.
      </p>

    </section>

    <section class="section">

      <h2>
        Core <span>Research Areas</span>
      </h2>

      <div class="grid">

        {coreAreas.map(([title, text]) => (

          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Global Genomic <span>Resources</span>
      </h2>

      <div class="grid">

        {resources.map(([title, text]) => (

          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Population Genomic <span>Methods</span>
      </h2>

      <div class="grid">

        {methods.map(([title, text]) => (

          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Landmark <span>Discoveries</span>
      </h2>

      <div class="timeline">

        {timeline.map(([year, title, text]) => (

          <div class="timeline-item">
            <div class="year">{year}</div>
            <div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Featured <span>Publications</span>
      </h2>

      <div class="grid">

        {publications.map(([title, authors, journal]) => (

          <div class="paper">
            <h3>{title}</h3>
            <div class="meta">
              {authors}<br>
              {journal}
            </div>
          </div>

        ))}

      </div>

      <a href="/publications" class="button">
        Explore Publications Library →
      </a>

    </section>

    <section class="section">

      <h2>
        Continue Your <span>Research Journey</span>
      </h2>

      <div class="grid">

        {related.map(([title, href]) => (

          <a href={href} class="card card-link">
            <h3>{title} →</h3>
            <p>Continue exploring the Genomics Research Center.</p>
          </a>

        ))}

      </div>

      <a href="/online" class="secondary-button">
        Explore PanorOmics Online →
      </a>

    </section>

  </div>

</body>

</html>
