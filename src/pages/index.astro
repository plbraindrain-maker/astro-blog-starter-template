---
// Final Production Delivery for PanorOmics - Clean Image Matrix
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/icon-mark.png" />
		<title>PanorOmics | integrating life sciences • data • discovery</title>
		<style>
			/* Reset browser defaults */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				scroll-behavior: smooth;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED LIGHT STICKY NAVIGATION HEADER */
			.site-header {
				background-color: #f4f7fa; 
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.header-logo-icon {
				height: 45px !important;
				width: auto !important;
				display: block !important;
				border-radius: 8px !important;
				clip-path: none !important;
			}

			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; 
				letter-spacing: -0.5px;
			}

			.brand-subtitle {
				font-size: 0.7rem;
				color: #4a607a; 
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				margin-top: 1px;
			}

			/* MAIN PRESENTATION SECTION LAYOUT */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			/* HERO MATRIX ROW - LOGO LEFT, CLICKABLE LANDING ASSET CENTER */
			.hero-matrix-row {
				width: 100%;
				max-width: 1400px;
				padding: 4rem 2rem;
				box-sizing: border-box;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 3rem;
			}

			/* Left-aligned Icon Mark */
			.left-logo-frame {
				width: 160px;
				height: 160px;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}

			.left-logo-frame img {
				width: 100%;
				height: auto;
				display: block;
				object-fit: contain;
			}

			/* Clickable Middle Landing Page Frame */
			.center-landing-link {
				display: block;
				width: 100%;
				max-width: 750px;
				cursor: pointer;
				text-decoration: none;
				transition: transform 0.2s ease;
			}

			.center-landing-link:hover {
				transform: scale(1.01);
			}

			/* INFOGRAPHIC IMMERSIVE LAYERS */
			.page-section {
				width: 100%;
				max-width: 1400px;
				display: flex;
				justify-content: center;
				position: relative;
			}

			.full-page-asset {
				width: 100% !important;
				height: auto !important;
				display: block !important;
				border-radius: 0px !important;
				clip-path: none !important;
			}

			/* INVISIBLE MAP LINKS FOR THE SIX PILLARS PANELS */
			.clickable-area {
				position: absolute;
				display: block;
				cursor: pointer;
			}

			/* Mobile Stacking Breakpoint */
			@media (max-width: 860px) {
				.hero-matrix-row {
					flex-direction: column;
					text-align: center;
					gap: 2rem;
					padding: 3rem 1.5rem;
				}
				.left-logo-frame {
					width: 120px;
					height: 120px;
				}
			}
		</style>
	</head>
	<body>

		<!-- FIXED STICKY HEADER -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<img src="/icon-mark.png" alt="PanorOmics Icon" class="header-logo-icon" />
					
						<span class="brand-text">PanorOmics</span>
						<span class="brand-subtitle">The Panoramic Omics Sciences Center</span>
					</div>
				</a>
			</div>
		</header>

		<!-- CONTENT BLOCK MATRIX -->
		<div class="landing-container">
			
			<!-- SECTION 1: HERO MATRIX (Logo Left, Clickable Landing Graphic Center) -->
			<section class="hero-matrix-row">
				<!-- Logo Image sitting directly on the left side -->
				<div class="left-logo-frame">
					
				</div>
				
				<!-- Main Landing Page graphic sitting in the middle and completely clickable -->
				<a href="/about" class="center-landing-link" title="Click to open landing content">
					<img 
						src="/panoromics-logo.png" 
						alt="PanorOmics | integrating life sciences • data • discovery" 
						class="full-page-asset" 
					/>
				</a>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA INFOGRAPHIC LAYER WITH CLICKABLE TARGETS -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>

				<!-- INVISIBLE CLICK LINKS FOR THE SIX PILLARS AT THE BOTTOM -->
				<a href="/research#genomics" class="clickable-area" style="top: 60%; left: 0%; width: 16.6%; height: 40%;" title="Genomics Pillar"></a>
				<a href="/research#transcriptomics" class="clickable-area" style="top: 60%; left: 16.6%; width: 16.6%; height: 40%;" title="Transcriptomics Pillar"></a>
				<a href="/research#proteomics" class="clickable-area" style="top: 60%; left: 33.2%; width: 16.6%; height: 40%;" title="Proteomics Pillar"></a>
				<a href="/research#metabolomics" class="clickable-area" style="top: 60%; left: 49.8%; width: 16.6%; height: 40%;" title="Metabolomics Pillar"></a>
				<a href="/research#lipidomics" class="clickable-area" style="top: 60%; left: 66.4%; width: 16.6%; height: 40%;" title="Lipidomics Pillar"></a>
				<a href="/research#epigenomics" class="clickable-area" style="top: 60%; left: 83%; width: 17%; height: 40%;" title="Epigenomics Pillar"></a>
			</section>

		</div>
	</body>
</html>
