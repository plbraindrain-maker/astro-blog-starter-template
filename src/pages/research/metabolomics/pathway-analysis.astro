}

.timeline-item{
  display:grid;
  grid-template-columns:120px 1fr;
  gap:18px;
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:20px;
}

.year{
  color:#3b82f6;
  font-weight:900;
  font-size:1.15rem;
}

.paper{
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:22px;
}

.paper h3{
  color:#3b82f6;
  margin-bottom:8px;
}

.meta{
  color:#94a3b8;
  font-size:.86rem;
  line-height:1.5;
}

.button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin-top:24px;
  padding:12px 24px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-weight:700;
}

.secondary-button{
  display:inline-flex;
