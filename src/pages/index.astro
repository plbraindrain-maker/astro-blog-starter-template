---
// Clean Operational Presentation Canvas for PanorOmics
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/panoromics-logo.png" />
		<title>PanorOmics | Unifying Omics. Advancing Health. Transforming Lives.</title>
		<style>
			/* Strip browser defaults */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				scroll-behavior: smooth;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED STICKY NAVIGATION BAR */
			.site-header {
				background-color: #f4f7fa; 
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 12px;
				text-decoration: none;
			}

			/* Clean, lightweight inline SVG icon matching your helix design */
			.header-logo-vector {
				width: 32px;
				height: 32px;
				display: block;
			}

			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; 
				letter-spacing: -0.5px;
			}

			.brand-subtitle {
				font-size: 0.7rem;
				color: #4a607a; 
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				margin-top: 1px;
			}

			/* PAGE CONTENT LAYOUT */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			.page-section {
				width: 100%;
				max-width: 1920px;
				display: flex;
				justify-content: center;
			}

			.full-page-asset {
				width: 100%;
				height: auto;
				display: block;
			}
		</style>
	</head>
	<body>

		<!-- HEADER BAR -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<!-- Crisp graphic science emblem for the header link -->
					<svg class="header-logo-vector" viewBox="0 0 24 24" fill="none" stroke="#003366" stroke-width="2.5" stroke-linecap="round">
						<path d="M4.5 10.5C4.5 5.52285 8.52285 1.5 13.5 1.5C18.4772 1.5 22.5 5.52285 22.5 10.5C22.5 15.4772 18.4772 19.5 13.5 19.5" />
						<path d="M9 7.5C9 9.98528 11.0147 12 13.5 12C15.9853 12 18 9.98528 18 7.5C18 5.01472 15.9853 3 13.5 3" />
						<path d="M12 14.5V22.5" />
						<path d="M8.5 19H15.5" />
					</svg>
					
						<span class="brand-text">PanorOmics</span>
						<span class="brand-subtitle">The Panoramic Omics Sciences Center</span>
					</div>
				</a>
			</div>
		</header>

		<!-- INFOGRAPHIC SCROLLING SECTIONS -->
		<div class="landing-container">
			
			<!-- SECTION 1: LOADS YOUR FULL-SCALE WIDESCREEN IMAGE ASSET -->
			<section class="page-section">
				<img 
					src="/panoromics-logo.png" 
					alt="PanorOmics - Unifying Omics. Advancing Health. Transforming Lives." 
					class="full-page-asset"
				/>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA MAP -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>
			</section>

		</div>
	</body>
</html>
