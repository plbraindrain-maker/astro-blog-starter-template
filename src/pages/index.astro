---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
  <h1>Welcome to The Panoramic Omics Sciences Center</h1>
  
  <img src="/omics-dogma.jpg" alt="The Central Dogma of Omics Science" style="width: 100%; height: auto; border-radius: 12px; margin: 20px 0; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" />

  <p>
    PanorOmics is dedicated to advancing precision medicine through multi-omics integration and innovative data science. 
    Our center explores the complex biological landscape—integrating <strong>epigenomics</strong>, genomics, and proteomics—to solve pressing challenges in disease mechanisms.
  </p>

  <h3>Our Research Pillars</h3>
  <ul>
    <li>Genomics & Transcriptomics</li>
    <li><strong>Epigenomics & Chromatin Dynamics</strong></li> <!-- Added here -->
    <li>Proteomics & Metabolomics</li>
    <li>Computational Bioinformatics</li>
  </ul>
</main>
		<Footer />
	</body>
</html>
