---
// Final Production Delivery for PanorOmics Landing Page
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/icon-mark.png" />
		<title>PanorOmics | Unifying Omics. Advancing Health. Transforming Lives.</title>
		<style>
			/* Reset browser defaults */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				scroll-behavior: smooth;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED LIGHT STICKY NAVIGATION HEADER */
			.site-header {
				background-color: #f4f7fa; 
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.header-logo-icon {
				height: 45px !important;
				width: auto !important;
				display: block !important;
				border-radius: 8px !important;
				clip-path: none !important;
			}

			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; 
				letter-spacing: -0.5px;
			}

			.brand-subtitle {
				font-size: 0.7rem;
				color: #4a607a; 
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				margin-top: 1px;
			}

			/* PAGE CONTENT LAYOUT WRAPPER */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			/* BULLETPROOF HERO WRAPPER - FORCES LOGO TO THE LEFT */
			.widescreen-hero {
				width: 100%;
				max-width: 1200px;
				padding: 6rem 2rem;
				box-sizing: border-box;
				display: flex !important;
				flex-direction: row !important; /* Force items horizontal side-by-side */
				align-items: center !important;
				justify-content: center !important;
				gap: 4rem; 
			}

			/* Logo sitting cleanly on the left side */
			.hero-logo-frame {
				width: 220px;
				height: 220px;
				display: flex !important;
				align-items: center !important;
				justify-content: center !important;
				flex-shrink: 0;
			}

			.hero-logo-frame img {
				width: 100%;
				height: auto;
				display: block;
				object-fit: contain;
			}

			/* Clickable center framework link wrapping the brand text matrix */
			.hero-text-link {
				display: flex !important;
				flex-direction: column !important;
				max-width: 650px;
				text-decoration: none !important; 
				cursor: pointer !important;
			}

			.hero-title {
				font-size: clamp(3.2rem, 6vw, 4.8rem);
				font-weight: 800;
				line-height: 1.05;
				margin: 0 0 0.75rem 0;
				letter-spacing: -1.5px;
				color: #ffffff !important;
			}

			.hero-title span {
				color: #1a8cff !important; 
			}

			.hero-tagline {
				font-size: 1.35rem;
				color: #a0c0e0 !important;
				line-height: 1.6;
				margin: 0;
				letter-spacing: 0.5px;
				text-transform: lowercase;
				font-weight: 400;
			}

			/* INFOGRAPHIC CONTENT LAYER */
			.page-section {
				width: 100%;
				max-width: 1400px;
				display: flex;
				justify-content: center;
				position: relative;
			}

			.full-page-asset {
				width: 100% !important;
				height: auto !important;
				display: block !important;
				border-radius: 0px !important;
				clip-path: none !important;
			}

			/* INTERACTIVE INVISIBLE CLICK TARGETS FOR THE GRAPHICS BLOCKS */
			.clickable-area {
				position: absolute;
				display: block;
				cursor: pointer;
			}

			/* Responsive mobile stacking layout */
			@media (max-width: 860px) {
				.widescreen-hero {
					flex-direction: column !important;
					text-align: center;
					gap: 2.5rem;
					padding: 4rem 1.5rem;
				}
			}
		</style>
	</head>
	<body>

		<!-- HEADER BAR -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<img src="/icon-mark.png" alt="PanorOmics Icon" class="header-logo-icon" />
					
						<span class="brand-text">PanorOmics</span>
						<span class="brand-subtitle">The Panoramic Omics Sciences Center</span>
					</div>
				</a>
			</div>
		</header>

		<!-- MAIN PRESENTATION CANVAS -->
		<div class="landing-container">
			
			<!-- SECTION 1: WIDESCREEN HERO (Forced Side-by-Side) -->
			<section class="widescreen-hero">
				<!-- Logo sitting perfectly on the left side -->
				<div class="hero-logo-frame">
					
				</div>
				
				<!-- Main text block configured as a clickable landing page link -->
				<a href="/about" class="hero-text-link" title="Go to About Landing Page">
					<h1 class="hero-title">Panor<span>Omics</span></h1>
					<p class="hero-tagline">integrating life sciences • data • discovery</p>
				</a>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA INFOGRAPHIC LAYER WITH CLICKABLE TARGETS -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>

				<!-- INVISIBLE LINKS FOR THE SIX PILLARS PANELS -->
				<a href="/research#genomics" class="clickable-area" style="top: 60%; left: 0%; width: 16.6%; height: 40%;" title="Genomics Pillar"></a>
				<a href="/research#transcriptomics" class="clickable-area" style="top: 60%; left: 16.6%; width: 16.6%; height: 40%;" title="Transcriptomics Pillar"></a>
				<a href="/research#proteomics" class="clickable-area" style="top: 60%; left: 33.2%; width: 16.6%; height: 40%;" title="Proteomics Pillar"></a>
				<a href="/research#metabolomics" class="clickable-area" style="top: 60%; left: 49.8%; width: 16.6%; height: 40%;" title="Metabolomics Pillar"></a>
				<a href="/research#lipidomics" class="clickable-area" style="top: 60%; left: 66.4%; width: 16.6%; height: 40%;" title="Lipidomics Pillar"></a>
				<a href="/research#epigenomics" class="clickable-area" style="top: 60%; left: 83%; width: 17%; height: 40%;" title="Epigenomics Pillar"></a>
			</section>

		</div>
	</body>
</html>
