
---
import HeaderLink from './HeaderLink.astro';
---

<header style="background: white; border-bottom: 1px solid #eee; padding: 0.8rem 0;">
	<nav style="display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 0 1rem;">
		
		<!-- LOGO SECTION -->
		<a href="/" style="display: flex; align-items: center; text-decoration: none; gap: 15px;">
			<img src="/logo.png" alt="PanorOmics Logo" style="height: 75px; width: auto;" />
			<div style="display: flex; flex-direction: column; line-height: 1.2;">
				<span style="font-size: 1.4rem; font-weight: 800; color: #0047AB; letter-spacing: -0.5px;">PanorOmics</span>
				<span style="font-size: 0.85rem; color: #666; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Sciences Center</span>
			</div>
		</a>

		<!-- RIGHT SIDE CONTROLS -->
		<div style="display: flex; align-items: center; gap: 25px;">
			
			<!-- DROPDOWN MENU -->
			<div class="dropdown">
				<button class="dropbtn">Explore ▼</button>
				<div class="dropdown-content">
					<HeaderLink href="/research">Research</HeaderLink>
					<HeaderLink href="/education">Education and Learning</HeaderLink>
					<HeaderLink href="/news">News</HeaderLink>
					<HeaderLink href="/about">About Us</HeaderLink>
					<HeaderLink href="/give" style="font-weight: bold; color: #0047AB;">Give</HeaderLink>
				</div>
			</div>

			<!-- SEARCH BUTTON (Now with ID for JavaScript) -->
			<button id="search-button" aria-label="Search" style="background: none; border: none; cursor: pointer; padding: 5px;">
				<svg xmlns="http://www.w3.org" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"></circle>
					<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
				</svg>
			</button>
		</div>
	</nav>
</header>

<!-- JAVASCRIPT TO MAKE IT CLICKABLE -->
<script>
	const searchBtn = document.getElementById('search-button');
	
	searchBtn?.addEventListener('click', () => {
		// Basic functionality: asks the user for a search term
		const query = prompt("What are you looking for?");
		if (query) {
			// Redirects to a search page (you'll need to create /search)
			window.location.href = `/search?q=${encodeURIComponent(query)}`;
		}
	});
</script>

<style>
	.dropdown { position: relative; display: inline-block; }
	.dropbtn { background: none; border: none; color: #333; font-weight: 500; font-size: 1rem; cursor: pointer; padding: 10px 0; }
	.dropdown-content {
		display: none;
		position: absolute;
		right: 0;
		background-color: #ffffff;
		min-width: 220px;
		box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.1);
		z-index: 10;
		border-radius: 4px;
		border: 1px solid #eee;
	}
	.dropdown-content :global(a) { color: #333; padding: 12px 16px; text-decoration: none; display: block; font-size: 0.95rem; }
	.dropdown-content :global(a:hover) { background-color: #f8f9fa; color: #0047AB; }
	.dropdown:hover .dropdown-content { display: block; }
</style>
