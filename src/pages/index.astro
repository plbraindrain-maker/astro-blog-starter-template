---
// Full Presentation Canvas for PanorOmics Widescreen Infographics
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/panoromics-logo.png" />
		<title>PanorOmics | Unifying Omics. Advancing Health. Transforming Lives.</title>
		<style>
			/* Completely flush the browser margins for a full-screen layout */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610; /* Blends flawlessly into the dark midnight blue of your graphic assets */
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			.page-section {
				width: 100%;
				max-width: 1920px; /* Ensures ultra-high res monitors display text perfectly sharp */
				display: flex;
				justify-content: center;
			}

			.full-page-asset {
				width: 100%;
				height: auto;
				display: block;
			}
		</style>
	</head>
	<body>
		<div class="landing-container">
			
			<!-- PAGE ONE: MAIN LANDING HERO & ECOSYSTEM OVERVIEW -->
			<section class="page-section">
				<img 
					src="/panoromics-logo.png" 
					alt="PanorOmics - Unifying Omics. Advancing Health. Transforming Lives." 
					class="full-page-asset"
				/>
			</section>

			<!-- PAGE TWO: CENTRAL DOGMA & SIX PILLARS MAP -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>
			</section>

		</div>
	</body>
</html>
