---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const cards = [
  ['Genomics', 'Comprehensive analysis of genetic variation to uncover biology and disease risk.', '/research'],
  ['Transcriptomics', 'Profiling RNA expression to understand gene activity and regulation.', '/research'],
  ['Proteomics', 'Characterizing proteins to reveal function, pathways, and biomarkers.', '/research'],
  ['Metabolomics', 'Measuring metabolites to capture biochemical phenotypes and pathways.', '/research'],
  ['Lipidomics', 'Analyzing lipid species to illuminate membrane biology and metabolism.', '/research'],
  ['Epigenomics', 'Studying epigenetic modifications that shape gene regulation.', '/research'],
];
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PanorOmics</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:Arial,Helvetica,sans-serif;
  background:#020817;
  color:white;
  overflow-x:hidden;
}

/* HEADER */

.header{
  background:white;
  padding:1rem 2rem;
}

.header-inner{
  max-width:1600px;
  margin:auto;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:2rem;
}

.brand{
  display:flex;
  align-items:center;
  gap:1rem;
  text-decoration:none;
}

.brand img{
  width:62px;
  height:62px;
}

.brand-title{
  font-size:2.8rem;
  font-weight:900;
  color:#020817;
  line-height:1;
}

.brand-title span{
  color:#2563eb;
}

.brand-sub{
  color:#64748b;
  font-size:.8rem;
  letter-spacing:.22em;
  margin-top:.25rem;
}

.nav{
  display:flex;
  gap:1.7rem;
  flex-wrap:wrap;
}

.nav a{
  color:#0f172a;
  text-decoration:none;
  font-weight:800;
}

.nav a:hover{
  color:#2563eb;
}

/* HERO */

.hero{
  padding:4rem 3rem 5rem;
  overflow:hidden;
  background:
    radial-gradient(circle at center,
    rgba(59,130,246,.18) 0%,
    rgba(0,0,0,0) 55%),
    #020817;
}

.hero-inner{
  max-width:1700px;
  margin:0 auto;
  display:grid;
  grid-template-columns:.75fr 1.25fr;
  align-items:center;
  gap:3rem;
}

.hero-left{
  position:relative;
  z-index:2;
}

.hero h1{
  font-size:clamp(3.2rem,5vw,5.2rem);
  line-height:.95;
  margin-bottom:2rem;
  font-weight:900;
  letter-spacing:-2px;
}

.hero h1 span{
  color:#3b82f6;
}

.hero p{
  font-size:1.15rem;
  line-height:1.9;
  color:#cbd5e1;
  max-width:650px;
  margin-bottom:2.5rem;
}

.btn{
  display:inline-block;
  background:#2563eb;
  color:white;
  text-decoration:none;
  padding:1rem 2rem;
  border-radius:999px;
  font-weight:800;
  transition:.25s;
}

.btn:hover{
  transform:translateY(-2px);
  background:#3b82f6;
}

.hero-img{
  display:block;
  border-radius:32px;
  overflow:hidden;
  box-shadow:
    0 0 80px rgba(59,130,246,.25);
}

.hero-img img{
  width:100%;
  display:block;
}

/* NEW OMICS DEFINITION SECTION */

.omics-definition{
  padding:7rem 2rem;
  background:#020817;
  border-top:1px solid rgba(59,130,246,.08);
  border-bottom:1px solid rgba(59,130,246,.08);
}

.omics-definition-inner{
  max-width:1100px;
  margin:auto;
  text-align:center;
}

.definition-label{
  color:#3b82f6;
  font-size:.9rem;
  letter-spacing:.28em;
  font-weight:800;
  margin-bottom:1.5rem;
}

.omics-definition h2{
  font-size:clamp(3rem,5vw,5rem);
  line-height:1.05;
  margin-bottom:2rem;
  font-weight:900;
  letter-spacing:-2px;
}

.omics-definition h2 span{
  color:#3b82f6;
}

.omics-definition p{
  color:#cbd5e1;
  font-size:1.2rem;
  line-height:2;
  max-width:950px;
  margin:0 auto 2rem;
}

/* CARDS */

.cards{
  max-width:1500px;
  margin:auto;
  padding:2rem 2rem 5rem;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.5rem;
}

.card{
  text-decoration:none;
  color:white;
  background:rgba(255,255,255,.025);
  border:1px solid rgba(59,130,246,.25);
  border-radius:22px;
  padding:2rem;
  min-height:210px;
  transition:.25s;
}

.card:hover{
  transform:translateY(-6px);
  border-color:#3b82f6;
  box-shadow:0 0 35px rgba(37,99,235,.18);
}

.card h3{
  font-size:1.7rem;
  margin-bottom:1rem;
}

.card p{
  color:#cbd5e1;
  line-height:1.75;
  font-size:1.05rem;
}

.card span{
  display:block;
  color:#3b82f6;
  margin-top:1.5rem;
  font-weight:800;
}

/* DOGMA */

.dogma{
  padding:4rem 2rem 7rem;
  text-align:center;
  background:#020817;
}

.dogma h2{
  font-size:clamp(2.8rem,5vw,5rem);
  line-height:1.05;
  font-weight:950;
  margin-bottom:1rem;
}

.dogma p{
  color:#94a3b8;
  font-size:1.3rem;
  margin-bottom:3rem;
}

.dogma-img{
  max-width:1500px;
  margin:auto;
  border-radius:30px;
  overflow:hidden;
  box-shadow:0 0 80px rgba(37,99,235,.25);
}

.dogma-img img{
  width:100%;
  display:block;
}

/* MOBILE */

@media(max-width:1000px){

  .header-inner{
    flex-direction:column;
  }

  .nav{
    justify-content:center;
  }

  .hero-inner{
    grid-template-columns:1fr;
    text-align:center;
  }

  .hero p{
    margin-left:auto;
    margin-right:auto;
  }

  .cards{
    grid-template-columns:1fr;
  }
}

</style>
</head>

<body>

<header class="header">

  <div class="header-inner">

    <a class="brand" href="/">
      <img src="/panoromics-logo.png" alt="PanorOmics Logo" />

      <div>
        <div class="brand-title">
          Panor<span>Omics</span>
        </div>

        <div class="brand-sub">
          THE PANORAMIC OMICS SCIENCES CENTER
        </div>
      </div>
    </a>

    <nav class="nav">
      {navLinks.map(link => (
        <a href={link.href}>{link.name}</a>
      ))}
    </nav>

  </div>

</header>

<!-- HERO -->

<section class="hero">

  <div class="hero-inner">

    <div class="hero-left">

      <h1>
        Unifying <span>omics.</span><br />
        Advancing <span>health.</span><br />
        Transforming <span>lives.</span>
      </h1>

      <p>
        PanorOmics integrates multi-omics science, computational systems,
        artificial intelligence, and translational biology to advance
        systems-level understanding of life, disease, biotechnology,
        and human health.
      </p>

      <a class="btn" href="/research">
        Explore Our Research →
      </a>

    </div>

    <a class="hero-img" href="/research">
      <img
        src="/main-landing.png"
        alt="PanorOmics cinematic hero"
      />
    </a>

  </div>

</section>

<!-- NEW OMICS SCIENCES SECTION -->

<section class="omics-definition">

  <div class="omics-definition-inner">

    <div class="definition-label">
      WHAT IS OMICS SCIENCES?
    </div>

    <h2>
      A Discipline, <span>Not a Toolbox</span>
    </h2>

    <p>
      Omics Sciences is an emerging integrative discipline that unifies
      molecular biology, computational systems, artificial intelligence,
      spatial biology, translational medicine, and multidimensional biological
      data into a systems-level understanding of life, disease, and human health.
    </p>

    <p>
      Rather than functioning as isolated technologies, omics sciences
      integrates genomics, transcriptomics, proteomics, metabolomics,
      lipidomics, epigenomics, and clinical frameworks to study how biological
      information is organized, regulated, disrupted, and translated into
      phenotype and disease at the scale of the whole organism.
    </p>

  </div>

</section>

<!-- CARDS -->

<section class="cards">

  {cards.map(card => (
    <a class="card" href={card[2]}>
      <h3>{card[0]}</h3>
      <p>{card[1]}</p>
      <span>Learn More →</span>
    </a>
  ))}

</section>

<!-- DOGMA -->

<section class="dogma">

  <h2>
    The Central Dogma of Omics Science
  </h2>

  <p>
    From information to function. From biology to impact.
  </p>

  <div class="dogma-img">
    <img
      src="/central-dogma.png"
      alt="Central Dogma of Omics Science"
    />
  </div>

</section>

</body>
</html>
