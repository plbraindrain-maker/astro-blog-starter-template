        <img
          src="${story.image}"
          alt="${story.alt}"
          style="
            width:100%;
            max-width:720px;
            height:auto;
            display:block;
            margin:0 auto 10px auto;
            border-radius:16px;
            border:1px solid rgba(59,130,246,.12);
          "
        >

        ${story.credit ? `
          <p style="
            font-size:.72rem;
            color:#94a3b8;
            max-width:720px;
            margin:0 auto 18px auto;
            line-height:1.45;
          ">
            ${story.credit}
          </p>
        ` : ""}

        <p style="
          max-width:720px;
          margin:0 auto;
          color:#7f8ca3;
          font-size:.9rem;
          line-height:1.65;
        ">
          ${story.description}
        </p>

        <div style="max-width:720px; margin:20px auto 0 auto; width:100%;">
          <a
            href="${story.href}"
            style="
              display:inline-flex;
              align-items:center;
              justify-content:center;
              gap:8px;
              padding:12px 24px;
              border-radius:999px;
              background:#2563eb;
              color:white;
              text-decoration:none;
              font-size:.9rem;
              font-weight:700;
              transition:.35s ease;
            "
          >
            ${story.button}
          </a>
        </div>

      </div>
    `).join("");
  </script>

