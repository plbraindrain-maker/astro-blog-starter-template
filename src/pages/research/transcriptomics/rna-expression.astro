---
const coreAreas = [
  ['Differential Gene Expression', 'Comparing RNA expression levels across tissues, disease states, treatments, or biological conditions to identify genes associated with function and phenotype.'],
  ['Expression Signatures', 'Defining gene expression patterns that classify cell states, disease subtypes, biological pathways, and molecular responses.'],
  ['Pathway-Level Expression Analysis', 'Interpreting RNA expression changes through biological pathways, regulatory networks, and systems-level functional programs.'],
  ['Clinical RNA Biomarkers', 'Using RNA expression patterns to support disease classification, prognosis, therapeutic response prediction, and precision medicine research.'],
];

const technologies = [
  ['RNA Sequencing', 'High-throughput sequencing of RNA molecules to quantify gene expression and characterize transcriptome-wide activity.'],
  ['Microarray Profiling', 'Hybridization-based measurement of gene expression across thousands of genes, widely used before RNA sequencing became dominant.'],
  ['qPCR / RT-qPCR', 'Targeted quantitative measurement of RNA expression for validation, diagnostics, and focused gene expression studies.'],
  ['Single-cell RNA-seq', 'Expression profiling at single-cell resolution to reveal cellular heterogeneity, rare cell states, and dynamic transcriptional programs.'],
  ['Spatial Transcriptomics', 'RNA expression analysis within tissue architecture, preserving spatial relationships between cells and molecular activity.'],
];

const modalities = [
  ['Bulk RNA Expression', 'Measures average RNA expression across a tissue, sample, or cell population.'],
  ['Single-cell RNA Expression', 'Profiles gene expression in individual cells to identify cell types, states, and heterogeneity.'],
  ['Spatial RNA Expression', 'Maps gene expression patterns directly within tissue structure.'],
  ['Targeted Expression Panels', 'Measures selected genes or pathways for focused biological or clinical questions.'],
  ['Time-course Expression Profiling', 'Tracks RNA expression changes across development, treatment, stress, or disease progression.'],
  ['Expression-Based Classification', 'Uses RNA signatures to classify disease subtypes, biological states, or therapeutic response groups.'],
];

const timeline = [
  [
    '1977',
    'Northern Blotting',
    'RNA detection methods made it possible to measure specific gene transcripts and study gene expression experimentally.'
  ],
  [
    '1987–Present',
    'RT-PCR and Quantitative Expression Analysis',
    'Reverse transcription PCR and later quantitative PCR enabled sensitive targeted measurement of RNA expression.'
  ],
  [
    '1995–2000s',
    'Gene Expression Microarrays',
    'Microarrays allowed thousands of genes to be measured simultaneously, transforming transcriptome-scale expression profiling.'
  ],
  [
    '2008–Present',
    'RNA Sequencing',
    'RNA-seq replaced many array-based approaches by enabling high-resolution, transcriptome-wide expression analysis.'
  ],
  [
    '2009–Present',
    'Single-cell RNA Expression',
    'Single-cell RNA-seq revealed cellular heterogeneity by measuring gene expression at individual-cell resolution.'
  ],
  [
    '2016–Present',
    'Spatial Transcriptomics',
    'Spatial methods connected RNA expression patterns with tissue architecture and cellular microenvironments.'
  ],
  [
    'Present',
    'AI-Assisted RNA Expression Analysis',
    'AI increasingly supports expression signature discovery, cell-state classification, pathway interpretation, and clinical transcriptomics.'
  ],
];

const publications = [
  ['Expression Monitoring by Hybridization to High-Density Oligonucleotide Arrays', 'Lockhart et al.', 'Nature Biotechnology • 1996'],
  ['Serial Analysis of Gene Expression', 'Velculescu et al.', 'Science • 1995'],
  ['Mapping and Quantifying Mammalian Transcriptomes by RNA-seq', 'Mortazavi et al.', 'Nature Methods • 2008'],
  ['Transcriptome Sequencing to Detect Gene Fusions', 'Maher et al.', 'Nature • 2009'],
  ['Single-cell RNA-seq Reveals Cellular Heterogeneity', 'Single-cell transcriptomics studies', 'Nature / Science / Cell'],
  ['Spatial Transcriptomics', 'Ståhl et al.', 'Science • 2016'],
];

const related = [
  ['RNA-seq', '/research/transcriptomics/rna-seq'],
  ['Alternative Splicing', '/research/transcriptomics/alternative-splicing'],
  ['Non-coding RNA', '/research/transcriptomics/non-coding-rna'],
];
