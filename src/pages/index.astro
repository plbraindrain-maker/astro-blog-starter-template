---
// Clean Operational Presentation Canvas for PanorOmics
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/icon-mark.png" />
		<title>PanorOmics | Unifying Omics. Advancing Health. Transforming Lives.</title>
		<style>
			/* Strip browser defaults */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				scroll-behavior: smooth;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED STICKY NAVIGATION BAR */
			.site-header {
				background-color: #f4f7fa; 
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.header-logo-icon {
				height: 45px;
				width: auto;
				display: block;
				border-radius: 8px;
			}

			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; 
				letter-spacing: -0.5px;
			}

			.brand-subtitle {
				font-size: 0.7rem;
				color: #4a607a; 
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				margin-top: 1px;
			}

			/* PAGE CONTENT LAYOUT */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			/* HORIZONTAL CODE-BASED HERO BANNER */
			.code-hero {
				width: 100%;
				max-width: 1400px;
				padding: 6rem 2rem;
				box-sizing: border-box;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 4rem;
			}

			/* Crisp vector graphic helix emblem matching your institutional identity */
			.helix-vector-box {
				width: 180px;
				height: 180px;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}

			.hero-text-block {
				display: flex;
				flex-direction: column;
				max-width: 600px;
			}

			.hero-headline {
				font-size: clamp(3rem, 6vw, 4.5rem);
				font-weight: 800;
				line-height: 1.1;
				margin: 0 0 0.5rem 0;
				letter-spacing: -1.5px;
				color: #ffffff;
			}

			.hero-headline span {
				color: #1a8cff;
			}

			.hero-slogan {
				font-size: 1.25rem;
				color: #a0c0e0;
				line-height: 1.6;
				margin: 0;
				letter-spacing: 0.5px;
				text-transform: lowercase;
			}

			/* IMAGE SECTIONS */
			.page-section {
				width: 100%;
				max-width: 1920px;
				display: flex;
				justify-content: center;
			}

			.full-page-asset {
				width: 100%;
				height: auto;
				display: block;
			}

			/* Responsive tweaks for mobile viewports */
			@media (max-width: 820px) {
				.code-hero {
					flex-direction: column;
					text-align: center;
					gap: 2rem;
					padding: 4rem 1.5rem;
				}
			}
		</style>
	</head>
	<body>

		<!-- HEADER BAR -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<img src="/icon-mark.png" alt="PanorOmics Icon" class="header-logo-icon" />
					
						<span class="brand-text">PanorOmics</span>
						<span class="brand-subtitle">The Panoramic Omics Sciences Center</span>
					</div>
				</a>
			</div>
		</header>

		<!-- INFOGRAPHIC SCROLLING SECTIONS -->
		<div class="landing-container">
			
			<!-- SECTION 1: CLEAN CODE HERO BLOCK (REPLACES CRASHED CROP BOX) -->
			<section class="code-hero">
				<!-- Clean, scalable vector helix emblem that will never crop or blur -->
				<svg class="helix-vector-box" viewBox="0 0 100 100" fill="none" xmlns="http://w3.org">
					<circle cx="50" cy="50" r="44" stroke="#ffffff" stroke-width="4" stroke-dasharray="6 4" />
					<path d="M30 30 C 40 45, 60 55, 70 70" stroke="#1a8cff" stroke-width="6" stroke-linecap="round" />
					<path d="M70 30 C 60 45, 40 55, 30 70" stroke="#ffffff" stroke-width="6" stroke-linecap="round" />
					<path d="M38 39 H 62" stroke="#1a8cff" stroke-width="3" />
					<path d="M44 49 H 56" stroke="#ffffff" stroke-width="3" />
					<path d="M38 61 H 62" stroke="#1a8cff" stroke-width="3" />
				</svg>
				
				<div class="hero-text-block">
					<h1 class="hero-headline">Panor<span>Omics</span></h1>
					<p class="hero-slogan">integrating life sciences • data • discovery</p>
				</div>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA MAP -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>
			</section>

		</div>
	</body>
</html>
