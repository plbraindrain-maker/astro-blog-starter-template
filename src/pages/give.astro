<!DOCTYPE html>
<html lang="en"> 

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Give | PanorOmics</title>

<style>

body{
  margin:0;
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
}

.give-hero{
  min-height:82vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:64px 8%;
}

.give-container{
  max-width:1120px;
  width:100%;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:46px;
  align-items:center;
}

.give-left h1{
  font-size:3.1rem;
  line-height:.98;
  margin-bottom:22px;
  letter-spacing:-0.05em;
}

.give-left h1 span{
  color:#3b82f6;
}

.give-left p{
  color:#cbd5e1;
  font-size:.95rem;
  line-height:1.75;
  max-width:540px;
  margin-bottom:28px;
}

.give-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:14px 26px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-size:.95rem;
  font-weight:700;
  transition:.3s ease;
}

.give-button:hover{
  transform:translateY(-3px);
  box-shadow:0 14px 36px rgba(37,99,235,.28);
}

.give-right{
  display:flex;
  justify-content:center;
  align-items:center;
}

.give-right img{
  width:100%;
  max-width:470px;
  object-fit:contain;
  filter:
  drop-shadow(0 0 22px rgba(59,130,246,.18));
}

@media(max-width:900px){

  .give-hero{
    padding:80px 24px 56px;
  }

  .give-container{
    grid-template-columns:1fr;
    text-align:center;
    gap:34px;
  }

  .give-left p{
    margin:auto auto 28px;
  }

  .give-left h1{
    font-size:2.45rem;
  }

  .give-right img{
    max-width:300px;
  }
}

</style>

</head>

<body>

<section class="give-hero">

  <div class="give-container">

    <div class="give-left">

      <h1>
        Advance the Future of <span>Omics Sciences</span>
      </h1>

      <p>
        Support education, translational research,
        computational biology, artificial intelligence,
        and the future of precision medicine through
        next-generation omics sciences.
      </p>

      <a href="/contact" class="give-button">
        Support PanorOmics
      </a>

    </div>

    <div class="give-right">

      <img
        src="/give-panoromics-logo.png"
        alt="PanorOmics Give"
      >

    </div>

  </div>

</section>

</body>

</html>
