---
// PanorOmics Landing Page

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const omicsPillars = [
  {
    id: 'genomics',
    name: 'GENOMICS',
    border: '#2563eb',
    text: 'The complete set of DNA, including genes, variants, and genetic architecture.'
  },
  {
    id: 'transcriptomics',
    name: 'TRANSCRIPTOMICS',
    border: '#16a34a',
    text: 'Examine RNA molecules to understand gene expression and cellular function.'
  },
  {
    id: 'proteomics',
    name: 'PROTEOMICS',
    border: '#9333ea',
    text: 'Analyze the full complement of proteins to uncover function, interactions, and pathways.'
  },
  {
    id: 'metabolomics',
    name: 'METABOLOMICS',
    border: '#dc2626',
    text: 'Profile small-molecule metabolites to reveal biochemical activity and metabolic states.'
  },
  {
    id: 'lipidomics',
    name: 'LIPIDOMICS',
    border: '#ca8a04',
    text: 'Investigate lipids and lipid species to understand membrane biology and signaling.'
  },
  {
    id: 'epigenomics',
    name: 'EPIGENOMICS',
    border: '#4f46e5',
    text: 'Explore epigenetic modifications regulating gene activity without changing DNA.'
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>PanorOmics</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      background: #010610;
      color: white;
      font-family: system-ui, sans-serif;
      overflow-x: hidden;
    }

    body {
      min-height: 100vh;
    }

    /* HEADER */

    .site-header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .header-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1rem 2rem;

      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .branding {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .branding img {
      width: 52px;
      height: 52px;
      object-fit: contain;
    }

    .branding-text {
      display: flex;
      flex-direction: column;
    }

    .brand-title {
      color: #020817;
      font-size: 1.3rem;
      font-weight: 800;
    }

    .brand-sub {
      color: #64748b;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .main-nav {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .nav-link {
      text-decoration: none;
      color: #334155;
      font-size: 0.95rem;
      font-weight: 600;
      transition: 0.3s ease;
    }

    .nav-link:hover {
      color: #2563eb;
    }

    /* HERO */

    .hero-section {
      min-height: 80vh;

      display: flex;
      align-items: center;
      justify-content: center;

      padding: 6rem 2rem 4rem;

      background:
        radial-gradient(circle at center,
        rgba(37,99,235,0.20),
        transparent 60%);
    }

    .hero-container {
      max-width: 1400px;
      width: 100%;

      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .hero-text h1 {
      font-size: 5rem;
      line-height: 1.05;
      margin-bottom: 2rem;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .hero-text h1 span {
      color: #3b82f6;
    }

    .hero-text p {
      font-size: 1.2rem;
      line-height: 1.9;
      color: #cbd5e1;
      max-width: 600px;
      margin-bottom: 2rem;
    }

    .hero-btn {
      display: inline-block;
      background: #2563eb;
      color: white;
      text-decoration: none;
      padding: 1rem 2rem;
      border-radius: 999px;
      font-weight: 700;
      transition: 0.3s ease;
    }

    .hero-btn:hover {
      background: #3b82f6;
      transform: translateY(-2px);
    }

    .hero-image {
      display: flex;
      justify-content: center;
    }

    .hero-image img {
      width: 100%;
      max-width: 550px;
      border-radius: 28px;
      opacity: 0.92;
      box-shadow: 0 0 60px rgba(59,130,246,0.25);
    }

    /* PILLARS */

    .pillars-section {
      max-width: 1400px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .section-title {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-title p {
      color: #64748b;
      letter-spacing: 0.2em;
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .section-title h2 {
      font-size: 3rem;
      font-weight: 900;
    }

    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
    }

    .pillar-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px;
      padding: 2rem;
      transition: 0.3s ease;
    }

    .pillar-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 0 25px rgba(59,130,246,0.2);
    }

    .pillar-name {
      display: block;
      font-size: 1.2rem;
      font-weight: 800;
      margin-bottom: 1rem;
      letter-spacing: 0.05em;
    }

    .pillar-description {
      color: #cbd5e1;
      line-height: 1.8;
    }

    /* DOGMA */

    .dogma-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem 8rem;
      text-align: center;
    }

    .dogma-section h2 {
      font-size: 3rem;
      margin-bottom: 1rem;
      font-weight: 900;
    }

    .dogma-section p {
      color: #94a3b8;
      margin-bottom: 3rem;
      font-size: 1.1rem;
    }

    .dogma-image {
      position: relative;
      overflow: hidden;
      border-radius: 24px;
    }

    .dogma-image img {
      width: 100%;
      display: block;
      border-radius: 24px;
    }

    .overlay-btn {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);

      background: #2563eb;
      color: white;
      text-decoration: none;

      padding: 1rem 2rem;
      border-radius: 999px;
      font-weight: 700;
    }

    /* MOBILE */

    @media (max-width: 900px) {

      .hero-container {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .hero-text h1 {
        font-size: 3.5rem;
      }

      .hero-text p {
        margin-left: auto;
        margin-right: auto;
      }

      .main-nav {
        justify-content: center;
      }

      .header-container {
        flex-direction: column;
        gap: 1rem;
      }

    }
  </style>
</head>

<body>

  <!-- HEADER -->

  <header class="site-header">
    <div class="header-container">

      <div class="branding">
        <img src="/logo.jpg" alt="PanorOmics Logo" />

        <div class="branding-text">
          <span class="brand-title">PanorOmics</span>
          <span class="brand-sub">
            THE PANORAMIC OMICS SCIENCES CENTER
          </span>
        </div>
      </div>

      <nav class="main-nav">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link">
            {link.name}
          </a>
        ))}
      </nav>

    </div>
  </header>

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-container">

      <div class="hero-text">

        <h1>
          Unifying <span>omics.</span><br />
          Advancing <span>health.</span><br />
          Transforming <span>lives.</span>
        </h1>

        <p>
          PanorOmics integrates genomics, transcriptomics,
          proteomics, metabolomics, AI, and systems biology
          into one unified scientific ecosystem for discovery,
          education, and precision medicine innovation.
        </p>

        <a href="/research" class="hero-btn">
          Explore Research
        </a>

      </div>

      <div class="hero-image">
        <img src="/main-landing.png" alt="DNA Omics Visualization" />
      </div>

    </div>

  </section>

  <!-- PILLARS -->

  <section class="pillars-section">

    <div class="section-title">
      <p>THE SIX PILLARS OF OMICS SCIENCE</p>
      <h2>Integrated Omics Disciplines</h2>
    </div>

    <div class="pillars-grid">

      {omicsPillars.map(pillar => (
        <div
          class="pillar-card"
          style={`border-color: ${pillar.border}`}
        >
          <span class="pillar-name">
            {pillar.name}
          </span>

          <p class="pillar-description">
            {pillar.text}
          </p>
        </div>
      ))}

    </div>

  </section>

  <!-- CENTRAL DOGMA -->

  <section class="dogma-section">

    <h2>The Central Dogma of Omics Science</h2>

    <p>
      From information to function. From biology to impact.
    </p>

    <div class="dogma-image">

      <img
        src="/main-landing.png"
        alt="Central Dogma Omics Diagram"
      />

      <a href="/research" class="overlay-btn">
        Explore Our Research →
      </a>

    </div>

  </section>

</body>
</html>
