---
// Force a static standalone server response
export const prerender = true;
---

!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/panoromics-logo.png" />
		<title>PanorOmics | integrating life sciences • data • discovery</title>
		<style>
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
				font-family: system-ui, -apple-system, sans-serif;
			}

			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.page-section {
				width: 100%;
				max-width: 1200px;
				display: flex;
				justify-content: center;
				position: relative;
			}

			.full-page-asset {
				width: 100%;
				height: auto;
				display: block;
			}

			.clickable-area {
				position: absolute;
				display: block;
				cursor: pointer;
			}
		</style>
	</head>
	<body>
		<div class="landing-container">
			
			<section class="page-section">
				<!-- Loads your complete unified graphic template layout directly -->
				<img 
					src="/main-landing.png" 
					alt="PanorOmics Home Portal" 
					class="full-page-asset" 
				/>

				<!-- ========================================== -->
				<!-- TOP NAVIGATION SYSTEM LINKS MAP            -->
				<!-- ========================================== -->
				<a href="/" class="clickable-area" style="top: 3.0%; left: 1.5%; width: 18%; height: 3.5%;" title="Home"></a>
				<a href="/" class="clickable-area" style="top: 3.8%; left: 25.8%; width: 3.5%; height: 2.0%;" title="Home"></a>
				<a href="/about" class="clickable-area" style="top: 3.8%; left: 30.6%; width: 4.2%; height: 2.0%;" title="About"></a>
				<a href="/research" class="clickable-area" style="top: 3.8%; left: 36.2%; width: 6.2%; height: 2.0%;" title="Research"></a>
				<a href="/education" class="clickable-area" style="top: 3.8%; left: 43.6%; width: 6.5%; height: 2.0%;" title="Education"></a>
				<a href="/platforms" class="clickable-area" style="top: 3.8%; left: 51.5%; width: 6.6%; height: 2.0%;" title="Platforms"></a>
				<a href="/data" class="clickable-area" style="top: 3.8%; left: 59.5%; width: 3.2%; height: 2.0%;" title="Data"></a>
				<a href="/publications" class="clickable-area" style="top: 3.8%; left: 64.0%; width: 8.5%; height: 2.0%;" title="Publications"></a>
				<a href="/news" class="clickable-area" style="top: 3.8%; left: 74.0%; width: 3.5%; height: 2.0%;" title="News"></a>
				<a href="/contact" class="clickable-area" style="top: 3.8%; left: 79.0%; width: 5.5%; height: 2.0%;" title="Contact"></a>
				<a href="/partner" class="clickable-area" style="top: 3.2%; left: 86.5%; width: 12.0%; height: 3.0%;" title="Partner With Us"></a>

				<!-- ========================================== -->
				<!-- CENTRAL HELIX EMBEDDED BUTTONS             -->
				<!-- ========================================== -->
				<a href="/research" class="clickable-area" style="top: 71.0%; left: 4.2%; width: 18.0%; height: 3.0%;" title="Explore Our Research"></a>

				<!-- ========================================== -->
				<!-- BOTTOM SEVEN CARD SUB-PAGES TARGETS        -->
				<!-- ========================================== -->
				<a href="/genomics" class="clickable-area" style="top: 77.0%; left: 1.8%; width: 12.5%; height: 21.0%;" title="Genomics"></a>
				<a href="/transcriptomics" class="clickable-area" style="top: 77.0%; left: 15.8%; width: 12.5%; height: 21.0%;" title="Transcriptomics"></a>
				<a href="/proteomics" class="clickable-area" style="top: 77.0%; left: 29.8%; width: 12.5%; height: 21.0%;" title="Proteomics"></a>
				<a href="/metabolomics" class="clickable-area" style="top: 77.0%; left: 43.8%; width: 12.5%; height: 21.0%;" title="Metabolomics"></a>
				<a href="/lipidomics" class="clickable-area" style="top: 77.0%; left: 57.8%; width: 12.5%; height: 21.0%;" title="Lipidomics"></a>
				<a href="/epigenomics" class="clickable-area" style="top: 77.0%; left: 71.8%; width: 12.5%; height: 21.0%;" title="Epigenomics"></a>
				<a href="/education" class="clickable-area" style="top: 77.0%; left: 85.8%; width: 12.5%; height: 21.0%;" title="Education"></a>
			</section>

		</div>
	</body>
</html>
