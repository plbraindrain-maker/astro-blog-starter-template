<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>PanorOmics | The Panoramic Omics Sciences Center</title>

<link rel="icon" type="image/png" href="/icon-mark.png" />
<link rel="apple-touch-icon" href="/icon-mark.png" />

<meta name="theme-color" content="#020817" />

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
  overflow-x:hidden;
}

.header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  z-index:1000;
  background:rgba(2,8,23,.78);
  backdrop-filter:blur(18px);
  border-bottom:1px solid rgba(59,130,246,.10);
}

.header-inner{
  max-width:1450px;
  margin:0 auto;
  padding:12px 32px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.brand{
  display:flex;
  align-items:center;
  gap:12px;
  text-decoration:none;
}

.brand img{
  width:44px;
  height:44px;
  object-fit:contain;
}

.brand-title{
  font-size:1.45rem;
  font-weight:800;
  line-height:1;
  color:white;
  letter-spacing:-0.04em;
}

.brand-title span{
  color:#3b82f6;
}

.brand-sub{
  color:#94a3b8;
  font-size:.56rem;
  margin-top:2px;
  letter-spacing:.10em;
}

.nav{
  display:flex;
  gap:18px;
}

.nav a{
  color:#dbe4ff;
  text-decoration:none;
  font-size:.8rem;
  transition:.3s ease;
}

.nav a:hover{
  color:#3b82f6;
}

.menu-toggle{
  display:none;
  background:none;
  border:none;
  color:white;
  font-size:1.8rem;
  cursor:pointer;
}

.mobile-menu{
  display:none;
  flex-direction:column;
  position:fixed;
  top:68px;
  left:0;
  width:100%;
  z-index:999;
  background:#020817;
  border-bottom:1px solid rgba(59,130,246,.12);
  padding:16px 24px;
}

.mobile-menu a{
  color:#dbe4ff;
  text-decoration:none;
  font-size:.95rem;
  padding:12px 0;
  border-bottom:1px solid rgba(255,255,255,.06);
}

.mobile-menu.show{
  display:flex;
}

.hero{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:30px;
  padding:78px 6% 24px;
  min-height:auto;
  overflow:hidden;
  background:
  radial-gradient(circle at center,
  rgba(59,130,246,.14),
  transparent 42%),
  #020817;
}

.hero-left{
  flex:1;
  max-width:480px;
}

.hero-kicker{
  color:#3b82f6;
  font-size:.7rem;
  letter-spacing:.26em;
  margin-bottom:14px;
  font-weight:700;
}

.hero-title{
  font-size:clamp(2.15rem,3.9vw,3.7rem);
  line-height:.96;
  letter-spacing:-0.055em;
  font-weight:900;
  margin-bottom:16px;
}

.hero-title span{
  color:#3b82f6;
}

.hero-description{
  font-size:.9rem;
  line-height:1.6;
  color:#cbd5e1;
  max-width:500px;
  margin-bottom:24px;
}

.hero-button{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:12px 24px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-size:.9rem;
  font-weight:700;
  transition:.35s ease;
}

.hero-button:hover{
  transform:translateY(-3px);
  box-shadow:0 12px 40px rgba(37,99,235,.35);
}

.hero-video-wrap{
  flex:1;
  display:flex;
  justify-content:center;
  width:100%;
}

.hero-video{
  width:100%;
  max-width:670px;
  border-radius:20px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.06);
  box-shadow:0 0 42px rgba(37,99,235,.10);
  position:relative;
  aspect-ratio:16/9;
  background:#020817;
}

.hero-video video{
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
}
.hero-slide{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transition:opacity 1.2s ease;
}

.hero-slide.active{
  opacity:1;
}
.hero-caption{
  position:absolute;
  left:22px;
  bottom:18px;
  z-index:3;
  color:rgba(255,255,255,.72);
  font-size:.72rem;
  letter-spacing:.08em;
  font-weight:600;
  text-transform:none;
  text-shadow:0 2px 12px rgba(0,0,0,.65);
}

.section{
  padding:30px 7%;
}

.section-title{
  font-size:clamp(1.55rem,2.6vw,2.55rem);
  line-height:1.08;
  letter-spacing:-0.04em;
  margin-bottom:10px;
}

.section-title span{
  color:#3b82f6;
}

.section-description{
  font-size:.9rem;
  line-height:1.6;
  color:#cbd5e1;
  max-width:820px;
}

.omics-grid{
  margin-top:20px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
  gap:16px;
}

.omics-card{
  background:rgba(8,15,35,.72);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:18px;
  text-decoration:none;
  transition:.35s ease;
  overflow:hidden;
}

.omics-card:hover{
  transform:translateY(-5px);
  border-color:#3b82f6;
  box-shadow:0 18px 50px rgba(37,99,235,.11);
}

.omics-card img{
  width:100%;
  height:145px;
  object-fit:cover;
  border-radius:14px;
  margin-bottom:14px;
  display:block;
  border:1px solid rgba(59,130,246,.12);
}

.omics-card h3{
  font-size:1.12rem;
  margin-bottom:9px;
  color:#2563eb;
}

.omics-card p{
  color:#7f8ca3;
  line-height:1.55;
  font-size:.86rem;
}

.central-dogma{
  margin-top:20px;
  border-radius:22px;
  overflow:hidden;
  border:1px solid rgba(59,130,246,.10);
  box-shadow:0 0 42px rgba(37,99,235,.09);
}

.central-dogma img{
  width:100%;
  display:block;
}

.footer{
