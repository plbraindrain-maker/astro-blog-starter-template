  padding:28px 5% 14px;
  color:#dbe4ee;
  border-top:1px solid rgba(255,255,255,.06);
}

.footer-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:24px;
}

.footer-brand{
  display:flex;
  align-items:center;
  gap:14px;
}

.footer-logo{
  width:72px;
  height:72px;
  object-fit:contain;
}

.footer-brand h3{
  font-size:1.1rem;
  color:white;
  margin-bottom:2px;
}

.footer-brand p{
  font-size:.78rem;
  color:#94a3b8;
}

.footer-social{
  display:flex;
  gap:18px;
}

.footer-social a{
  color:#dbe4ee;
  font-size:1.45rem;
  transition:.25s ease;
}

.footer-social a:nth-child(1):hover{color:#0b3d91;}
.footer-social a:nth-child(2):hover{color:#000000;}
.footer-social a:nth-child(3):hover{color:#e1306c;}
.footer-social a:nth-child(4):hover{color:#ff0000;}
.footer-social a:nth-child(5):hover{color:#0a66c2;}
.footer-social a:nth-child(6):hover{color:#ffffff;}

.footer-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
