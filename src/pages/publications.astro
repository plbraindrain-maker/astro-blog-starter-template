---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Publications Library | PanorOmics</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
  overflow-x:hidden;
}

.container{
  max-width:1200px;
  margin:auto;
  padding:80px 7% 60px;
}

.back{
  color:#3b82f6;
  text-decoration:none;
  font-size:.9rem;
  font-weight:700;
}

.hero{
  margin-top:32px;
  text-align:center;
}

.library-logo{
  width:130px;
  height:auto;
  display:block;
  margin:0 auto 24px;
}

.hero-kicker{
  color:#3b82f6;
  font-size:.72rem;
  letter-spacing:.26em;
  font-weight:800;
  margin-bottom:16px;
}

.hero h1{
  font-size:clamp(2.6rem,5vw,4.6rem);
  line-height:.95;
  letter-spacing:-.055em;
  margin-bottom:18px;
}

.hero h1 span{
  color:#3b82f6;
}

.hero p{
  color:#cbd5e1;
  font-size:1rem;
  line-height:1.8;
  max-width:920px;
  margin:0 auto;
}

.stats{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:16px;
  margin-top:34px;
}

.stat{
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:18px;
}

.stat strong{
  display:block;
  color:#3b82f6;
  font-size:1.5rem;
  margin-bottom:4px;
}

.stat span{
  color:#94a3b8;
  font-size:.84rem;
}

.library-toolbar{
  margin-top:42px;
  background:rgba(8,15,35,.78);
  border:1px solid rgba(59,130,246,.14);
  border-radius:24px;
  padding:22px;
  box-shadow:0 0 50px rgba(37,99,235,.10);
}

.search-box{
  width:100%;
  padding:16px 18px;
  border-radius:999px;
  border:1px solid rgba(59,130,246,.25);
  background:#020817;
  color:white;
  font-size:1rem;
  outline:none;
}

.search-box::placeholder{
  color:#64748b;
}

.toolbar-label{
  color:#94a3b8;
  font-size:.78rem;
  font-weight:800;
  letter-spacing:.08em;
  margin-top:18px;
  margin-bottom:10px;
  text-transform:uppercase;
}

.filters{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.filter-pill{
  cursor:pointer;
  font-family:inherit;
  padding:9px 15px;
  border-radius:999px;
  border:1px solid rgba(59,130,246,.18);
  background:rgba(59,130,246,.08);
  color:#cbd5e1;
  font-size:.82rem;
  font-weight:700;
}

.filter-pill.active{
  background:#2563eb;
  color:white;
}

.section{
  margin-top:64px;
}

.section h2{
  font-size:2rem;
  margin-bottom:16px;
}

.section h2 span{
  color:#3b82f6;
}

.section p{
  color:#cbd5e1;
  line-height:1.9;
  font-size:1rem;
  margin-bottom:16px;
}

.library-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px;
  margin-top:24px;
}

.library-card{
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:20px;
  padding:24px;
  transition:.3s ease;
}

.library-card:hover{
  transform:translateY(-4px);
  border-color:#3b82f6;
  box-shadow:0 18px 50px rgba(37,99,235,.10);
}

.paper-tag{
  display:inline-block;
  margin-bottom:12px;
  padding:6px 10px;
  border-radius:999px;
  background:rgba(59,130,246,.12);
  color:#60a5fa;
  font-size:.72rem;
  font-weight:800;
}

.library-card h3{
  color:#3b82f6;
  margin-bottom:10px;
  line-height:1.25;
}

.meta{
  color:#94a3b8;
  font-size:.82rem;
  line-height:1.5;
  margin-bottom:12px;
}

.library-card p{
  margin:0;
  font-size:.92rem;
  color:#cbd5e1;
  line-height:1.7;
}

.hero-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin-top:24px;
  padding:12px 24px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-weight:700;
}

.hidden{
  display:none !important;
}

@media(max-width:768px){
  .container{
    padding:70px 20px 50px;
  }

  .library-logo{
    width:105px;
  }

  .hero h1{
    font-size:2.6rem;
  }
}

</style>

</head>

<body>

<div class="container">

<a href="/" class="back">
← Back to PanorOmics
</a>

<section class="hero">

<img
  src="/panoromics-logo.png"
  alt="PanorOmics Logo"
  class="library-logo"
/>

<div class="hero-kicker">
PANOROMICS SCIENTIFIC KNOWLEDGE LIBRARY
</div>

<h1>
Publications <span>Library</span>
</h1>

<p>
A curated scientific knowledge portal for omics sciences, biotechnology,
artificial intelligence, systems biology, precision medicine, and human health.
Search by keyword, omics layer, publication type, research topic, landmark discovery,
or human impact story.
</p>

<div class="stats">

  <div class="stat">
    <strong>7</strong>
    <span>Omics Disciplines</span>
  </div>

  <div class="stat">
    <strong>12+</strong>
    <span>Keyword Collections</span>
  </div>

  <div class="stat">
    <strong>8</strong>
    <span>Journal Collections</span>
  </div>

  <div class="stat">
    <strong>Working</strong>
    <span>Search + Filters</span>
  </div>

</div>

<div class="library-toolbar">

<input
  id="searchInput"
  class="search-box"
  type="search"
  placeholder="Search publications, authors, journals, keywords, diseases, or omics disciplines..."
>

<div class="toolbar-label">
Omics Toolbar
</div>

<div class="filters">
  {omicsCategories.map((item, index) => (
    <button
      class={`filter-pill ${index === 0 ? 'active' : ''}`}
      data-filter={item}
      type="button"
    >
      {item}
    </button>
  ))}
</div>

<div class="toolbar-label">
Publication Type
</div>

<div class="filters">
  {publicationTypes.map((item, index) => (
    <button
      class={`filter-pill ${index === 0 ? 'active' : ''}`}
      data-filter={item}
      type="button"
    >
      {item}
    </button>
  ))}
</div>

<div class="toolbar-label">
Keyword Search
</div>

<div class="filters">
  {keywords.map((item) => (
    <button
      class="filter-pill"
      data-filter={item}
      type="button"
    >
      {item}
    </button>
  ))}
</div>

</div>

</section>

<section class="section">

<h2>
Featured <span>Publications</span>
</h2>

<div class="library-grid">

{featuredPapers.map((paper) => (

  <article
    class="library-card searchable-card"
    data-search={`${paper.title} ${paper.authors} ${paper.journal} ${paper.year} ${paper.category} ${paper.type} ${paper.keywords} ${paper.why}`}
  >

    <span class="paper-tag">{paper.category} • {paper.type}</span>

    <h3>{paper.title}</h3>

    <div class="meta">
      {paper.authors}<br>
      {paper.journal} • {paper.year}
    </div>

    <p>{paper.why}</p>

  </article>

))}

</div>

</section>

<section class="section">

<h2>
Landmark <span>Discoveries</span>
</h2>

<div class="library-grid">

{landmarkDiscoveries.map((item) => (

  <div
    class="library-card searchable-card"
    data-search={`${item} landmark discovery omics science biomedical research`}
  >
    <h3>{item}</h3>
    <p>Curated resources explaining the discovery, scientific context, omics connection, and human impact.</p>
  </div>

))}

</div>

</section>

<section class="section">

<h2>
Browse by <span>Omics Science</span>
</h2>

<div class="library-grid">

{omicsCategories.filter((item) => item !== 'All').map((item) => (

  <div
    class="library-card searchable-card"
    data-search={`${item} omics science curated papers landmark studies reviews translational discoveries`}
  >
    <h3>{item}</h3>
    <p>Curated papers, landmark studies, educational summaries, and translational discoveries in {item.toLowerCase()}.</p>
  </div>

))}

</div>

</section>

<section class="section">

<h2>
Curated <span>Collections</span>
</h2>

<div class="library-grid">

{curatedCollections.map((item) => (

  <div
    class="library-card searchable-card"
    data-search={`${item} curated collection publications education translational biotechnology`}
  >
    <h3>{item}</h3>
    <p>PanorOmics-selected readings connecting scientific publications with education, research, and translational biotechnology.</p>
  </div>

))}

</div>

</section>

<section class="section">

<h2>
Journal <span>Browser</span>
</h2>

<div class="library-grid">

{journalCollections.map((item) => (

  <div
    class="library-card searchable-card"
    data-search={`${item} journal browser high impact literature omics biomedical discovery`}
  >
    <h3>{item}</h3>
    <p>Browse high-impact literature and selected papers relevant to omics sciences and biomedical discovery.</p>
  </div>

))}

</div>

</section>

<section class="section">

<h2>
Human Impact <span>Stories</span>
</h2>

<div
  class="library-card searchable-card"
  data-search="Victoria Gray CRISPR sickle cell disease genomics gene editing clinical translation biotechnology human impact"
>

<h3>
Victoria Gray CRISPR Collection
</h3>

<p>
A curated collection connecting sickle cell disease, genomics, CRISPR gene editing,
clinical translation, biotechnology, and human impact.
</p>

<a href="/victoria-gray" class="hero-button">
Read Victoria Gray's Story →
</a>

</div>

</section>

</div>

<script is:inline>
window.addEventListener("DOMContentLoaded", function () {
  const searchInput =
  document.getElementById("searchInput");

  const buttons =
  document.querySelectorAll(".filter-pill");

  const cards =
  document.querySelectorAll(".searchable-card");

  function clearActiveButtons() {
    buttons.forEach(function(button) {
      button.classList.remove("active");
    });
  }

  function filterCards(query) {
    const cleanQuery =
    String(query || "").toLowerCase().trim();

    cards.forEach(function(card) {
      const text =
      (
        card.getAttribute("data-search") ||
        card.textContent ||
        ""
      ).toLowerCase();

      if (
        cleanQuery === "" ||
        cleanQuery === "all" ||
        cleanQuery === "all types" ||
        text.includes(cleanQuery)
      ) {
        card.classList.remove("hidden");
      } else {
        card.classList.add("hidden");
      }
    });
  }

  if (searchInput) {
    searchInput.addEventListener("input", function() {
      clearActiveButtons();
      filterCards(searchInput.value);
    });
  }

  buttons.forEach(function(button) {
    button.addEventListener("click", function() {
      const value =
      button.getAttribute("data-filter") || "";

      clearActiveButtons();
      button.classList.add("active");

      if (searchInput) {
        searchInput.value =
        value.toLowerCase() === "all" ||
        value.toLowerCase() === "all types"
          ? ""
          : value;
      }

      filterCards(value);
    });
  });
});
</script>
<script is:inline>
window.addEventListener("DOMContentLoaded", function () {
  const searchInput = document.getElementById("searchInput");
  const buttons = document.querySelectorAll(".filter-pill");
  const cards = document.querySelectorAll(".searchable-card");

  function clearActiveButtons() {
    buttons.forEach(function(button) {
      button.classList.remove("active");
    });
  }

  function filterCards(query) {
    const cleanQuery = String(query || "").toLowerCase().trim();

    cards.forEach(function(card) {
      const text = (
        card.getAttribute("data-search") ||
        card.textContent ||
        ""
      ).toLowerCase();

      if (
        cleanQuery === "" ||
        cleanQuery === "all" ||
        cleanQuery === "all types" ||
        text.includes(cleanQuery)
      ) {
        card.classList.remove("hidden");
      } else {
        card.classList.add("hidden");
      }
    });
  }

  if (searchInput) {
    searchInput.addEventListener("keydown", function(event) {
      if (event.key === "Enter") {
        clearActiveButtons();
        filterCards(searchInput.value);
      }
    });
  }

  buttons.forEach(function(button) {
    button.addEventListener("click", function() {
      const value = button.getAttribute("data-filter") || "";

      clearActiveButtons();
      button.classList.add("active");

      if (searchInput) {
        searchInput.value =
          value.toLowerCase() === "all" ||
          value.toLowerCase() === "all types"
            ? ""
            : value;
      }

      filterCards(value);
    });
  });
});
</script>
</body>

</html>
