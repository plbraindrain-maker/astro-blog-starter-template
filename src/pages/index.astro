---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const cards = [
  ['Genomics', 'Comprehensive analysis of genetic variation to uncover biology and disease risk.', '/research'],
  ['Transcriptomics', 'Profiling RNA expression to understand gene activity and regulation.', '/research'],
  ['Proteomics', 'Characterizing proteins to reveal function, pathways, and biomarkers.', '/research'],
  ['Metabolomics', 'Measuring metabolites to capture biochemical phenotypes and pathways.', '/research'],
  ['Lipidomics', 'Analyzing lipid species to illuminate membrane biology and metabolism.', '/research'],
  ['Epigenomics', 'Studying epigenetic modifications that shape gene regulation.', '/research'],
  ['Education', 'Omics learning programs for the next generation of scientists.', '/education'],
];
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PanorOmics</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Arial,Helvetica,sans-serif;background:#020817;color:white;overflow-x:hidden}

.site-header{background:#fff;position:relative;z-index:10}
.header-container{max-width:1500px;margin:auto;padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:2rem}
.brand{display:flex;align-items:center;gap:1rem;text-decoration:none}
.brand img{width:64px;height:64px;object-fit:contain}
.brand-title{font-size:2.8rem;font-weight:900;color:#020817;line-height:1}
.brand-title span{color:#2563eb}
.brand-sub{color:#64748b;letter-spacing:.22em;font-size:.8rem;margin-top:.25rem}
nav{display:flex;gap:1.7rem;flex-wrap:wrap}
nav a{color:#0f172a;text-decoration:none;font-weight:700}
nav a:hover{color:#2563eb}

.hero{min-height:88vh;padding:4rem 2rem;background:radial-gradient(circle at 70% 45%,rgba(37,99,235,.28),transparent 38%),#020817}
.hero-grid{max-width:1500px;margin:auto;display:grid;grid-template-columns:1fr 1.1fr;gap:4rem;align-items:center}
.hero h1{font-size:5.5rem;line-height:1.05;font-weight:900}
.blue{color:#3b82f6}
.hero p{margin:2rem 0;color:#cbd5e1;font-size:1.25rem;line-height:1.8;max-width:640px}
.btn{display:inline-block;background:#2563eb;color:white;text-decoration:none;padding:1rem 2rem;border-radius:999px;font-weight:800}
.btn:hover{background:#3b82f6}

.dna-box{position:relative;min-height:520px;border-radius:34px;background:linear-gradient(135deg,rgba(15,23,42,.9),rgba(2,8,23,.65));box-shadow:0 0 80px rgba(37,99,235,.28);overflow:hidden}
.dna{position:absolute;inset:0;background:
radial-gradient(circle at 50% 50%,rgba(59,130,246,.35),transparent 35%),
url('/main-landing.png');background-size:cover;background-position:center;opacity:.9}
.labels{position:absolute;inset:0}
.label{position:absolute;border:1px solid rgba(96,165,250,.5);background:rgba(2,8,23,.55);padding:.7rem 1rem;border-radius:999px;font-weight:800;font-size:.85rem}
.g{top:18%;left:12%}.t{top:43%;left:7%}.p{bottom:28%;left:12%}.m{top:28%;right:8%}.l{top:52%;right:8%}.e{bottom:24%;right:10%}

.cards{max-width:1500px;margin:auto;padding:3rem 2rem 6rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:1rem}
.card{display:block;text-decoration:none;color:white;background:rgba(255,255,255,.03);border:1px solid rgba(96,165,250,.25);border-radius:18px;padding:1.5rem;min-height:210px;transition:.25s}
.card:hover{transform:translateY(-6px);border-color:#3b82f6;box-shadow:0 0 30px rgba(37,99,235,.22)}
.card h3{margin-bottom:.8rem}
.card p{color:#cbd5e1;line-height:1.55;font-size:.95rem}
.card span{display:block;color:#3b82f6;margin-top:1rem;font-weight:800}

.dogma{padding:4rem 2rem 7rem;text-align:center;background:#020817}
.dogma h2{font-size:4rem;line-height:1.05;margin-bottom:1rem}
.dogma p{color:#94a3b8;font-size:1.3rem;margin-bottom:2.5rem}
.dogma-img{max-width:1500px;margin:auto;border-radius:30px;overflow:hidden;box-shadow:0 0 80px rgba(37,99,235,.22)}
.dogma-img img{width:100%;display:block}

@media(max-width:1000px){
.header-container{flex-direction:column}
nav{justify-content:center}
.hero-grid{grid-template-columns:1fr;text-align:center}
.hero p{margin-left:auto;margin-right:auto}
.hero h1{font-size:3.5rem}
.dogma h2{font-size:2.7rem}
}
</style>
</head>

<body>

<header class="site-header">
  <div class="header-container">
    <a href="/" class="brand">
      <img src="/panoromics-logo.png" alt="PanorOmics Logo" />
      <div>
        <div class="brand-title">Panor<span>Omics</span></div>
        <div class="brand-sub">THE PANORAMIC OMICS SCIENCES CENTER</div>
      </div>
    </a>

    <nav>
      {navLinks.map(link => <a href={link.href}>{link.name}</a>)}
    </nav>
  </div>
</header>

<section class="hero">
  <div class="hero-grid">
    <div>
      <h1>
        Unifying <span class="blue">omics.</span><br />
        Advancing <span class="blue">health.</span><br />
        Transforming <span class="blue">lives.</span>
      </h1>

      <p>
        PanorOmics integrates multi-omics data, artificial intelligence,
        systems biology, and translational science to accelerate discovery,
        precision medicine, and biotechnology innovation.
      </p>

      <a href="/research" class="btn">Explore Our Research →</a>
    </div>

    <div class="dna-box">
      <div class="dna"></div>
      <div class="labels">
        <a class="label g" href="/research">GENOMICS</a>
        <a class="label t" href="/research">TRANSCRIPTOMICS</a>
        <a class="label p" href="/research">PROTEOMICS</a>
        <a class="label m" href="/research">METABOLOMICS</a>
        <a class="label l" href="/research">LIPIDOMICS</a>
        <a class="label e" href="/research">EPIGENOMICS</a>
      </div>
    </div>
  </div>
</section>

<section class="cards">
  {cards.map(card => (
    <a class="card" href={card[2]}>
      <h3>{card[0]}</h3>
      <p>{card[1]}</p>
      <span>Learn More →</span>
    </a>
  ))}
</section>

<section class="dogma">
  <h2>The Central Dogma of Omics Science</h2>
  <p>From information to function. From biology to impact.</p>

  <div class="dogma-img">
    <img src="/central-dogma.png" alt="Central Dogma of Omics Science" />
  </div>
</section>

</body>
</html>
