---
// PanorOmics Landing Page

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const omicsPillars = [
  {
    name: 'GENOMICS',
    border: '#2563eb',
    text: 'The complete set of DNA, including genes, variants, and genetic architecture.'
  },
  {
    name: 'TRANSCRIPTOMICS',
    border: '#00c853',
    text: 'Examine RNA molecules to understand gene expression and cellular function.'
  },
  {
    name: 'PROTEOMICS',
    border: '#c026ff',
    text: 'Analyze proteins to uncover biological function and pathways.'
  },
  {
    name: 'METABOLOMICS',
    border: '#ff1744',
    text: 'Profile metabolites to reveal biochemical activity and metabolic states.'
  },
  {
    name: 'LIPIDOMICS',
    border: '#ffb300',
    text: 'Investigate lipids and lipid species involved in signaling and metabolism.'
  },
  {
    name: 'EPIGENOMICS',
    border: '#7c4dff',
    text: 'Study epigenetic modifications that regulate gene activity.'
  }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PanorOmics</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      background:#010814;
      color:white;
      font-family:Arial, Helvetica, sans-serif;
      overflow-x:hidden;
    }

    /* HEADER */

    .site-header{
      width:100%;
      background:white;
      padding:18px 40px;
      position:sticky;
      top:0;
      z-index:1000;
    }

    .header-container{
      max-width:1400px;
      margin:auto;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .logo-wrapper{
      display:flex;
      align-items:center;
      gap:16px;
    }

    .logo-wrapper img{
      width:60px;
      height:60px;
      object-fit:contain;
    }

    .brand-text h1{
      color:#010814;
      font-size:2rem;
      line-height:1;
    }

    .brand-text p{
      color:#64748b;
      font-size:0.8rem;
      letter-spacing:2px;
      margin-top:4px;
    }

    .main-nav{
      display:flex;
      gap:24px;
      flex-wrap:wrap;
    }

    .main-nav a{
      color:#1e293b;
      text-decoration:none;
      font-weight:600;
      transition:0.2s;
    }

    .main-nav a:hover{
      color:#2563eb;
    }

    /* HERO */

    .hero{
      max-width:1400px;
      margin:auto;
      padding:80px 40px;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:60px;
      align-items:center;
    }

    .hero-text h2{
      font-size:5rem;
      line-height:1.05;
      font-weight:900;
      margin-bottom:30px;
    }

    .hero-text span{
      color:#3b82f6;
    }

    .hero-text p{
      color:#cbd5e1;
      font-size:1.2rem;
      line-height:1.8;
      margin-bottom:30px;
      max-width:700px;
    }

    .hero-button{
      display:inline-block;
      background:#2563eb;
      color:white;
      text-decoration:none;
      padding:18px 32px;
      border-radius:999px;
      font-weight:700;
      transition:0.2s;
    }

    .hero-button:hover{
      background:#1d4ed8;
    }

    .hero-image img{
      width:100%;
      border-radius:24px;
      box-shadow:0 0 50px rgba(37,99,235,0.35);
    }

    /* PILLARS */

    .pillars-section{
      max-width:1400px;
      margin:auto;
      padding:60px 40px 120px;
    }

    .pillars-top{
      text-align:center;
      margin-bottom:60px;
    }

    .pillars-top p{
      color:#64748b;
      letter-spacing:4px;
      margin-bottom:20px;
    }

    .pillars-top h3{
      font-size:4rem;
      font-weight:900;
    }

    .pillars-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
      gap:32px;
    }

    .pillar-card{
      background:rgba(255,255,255,0.03);
      border:2px solid;
      border-radius:24px;
      padding:40px;
      transition:0.3s;
    }

    .pillar-card:hover{
      transform:translateY(-8px);
      box-shadow:0 0 30px rgba(255,255,255,0.08);
    }

    .pillar-card h4{
      font-size:2rem;
      margin-bottom:20px;
    }

    .pillar-card p{
      color:#cbd5e1;
      line-height:1.8;
      font-size:1.1rem;
    }

    /* DOGMA */

    .dogma{
      max-width:1200px;
      margin:auto;
      padding:0 40px 120px;
      text-align:center;
    }

    .dogma h3{
      font-size:4rem;
      margin-bottom:20px;
    }

    .dogma p{
      color:#94a3b8;
      margin-bottom:40px;
      font-size:1.2rem;
    }

    .dogma img{
      width:100%;
      border-radius:24px;
      box-shadow:0 0 40px rgba(37,99,235,0.25);
    }

    @media(max-width:900px){

      .hero{
        grid-template-columns:1fr;
      }

      .hero-text h2{
        font-size:3.5rem;
      }

      .pillars-top h3{
        font-size:2.5rem;
      }

      .dogma h3{
        font-size:2.5rem;
      }

    }

  </style>
</head>

<body>

  <!-- HEADER -->

  <header class="site-header">
    <div class="header-container">

      <div class="logo-wrapper">

        <img src="/panoromics-logo.png" alt="PanorOmics Logo" />

        <div class="brand-text">
          <h1>PanorOmics</h1>
          <p>THE PANORAMIC OMICS SCIENCES CENTER</p>
        </div>

      </div>

      <nav class="main-nav">
        {navLinks.map(link => (
          <a href={link.href}>{link.name}</a>
        ))}
      </nav>

    </div>
  </header>

  <!-- HERO -->

  <section class="hero">

    <div class="hero-text">

      <h2>
        Unifying <span>omics.</span><br>
        Advancing <span>health.</span><br>
        Transforming <span>lives.</span>
      </h2>

      <p>
        PanorOmics integrates genomics, transcriptomics, proteomics,
        metabolomics, lipidomics, epigenomics, AI, and systems biology
        into one unified scientific ecosystem for discovery and precision medicine.
      </p>

      <a href="/research" class="hero-button">
        Explore Our Research →
      </a>

    </div>

    <div class="hero-image">
      <img src="/main-landing.png" alt="PanorOmics Main Landing" />
    </div>

  </section>

  <!-- PILLARS -->

  <section class="pillars-section">

    <div class="pillars-top">
      <p>THE SIX PILLARS OF OMICS SCIENCE</p>
      <h3>Integrated Omics Disciplines</h3>
    </div>

    <div class="pillars-grid">

      {omicsPillars.map((pillar) => (

        <div
          class="pillar-card"
          style={`border-color:${pillar.border}`}
        >

          <h4>{pillar.name}</h4>

          <p>{pillar.text}</p>

        </div>

      ))}

    </div>

  </section>

  <!-- CENTRAL DOGMA -->

  <section class="dogma">

    <h3>The Central Dogma of Omics Science</h3>

    <p>
      From information to function. From biology to impact.
    </p>

    <img src="/central-dogma.png" alt="Central Dogma of Omics Science" />

  </section>

</body>
</html>
