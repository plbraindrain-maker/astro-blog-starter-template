.card{
  background:rgba(8,15,35,.72);
  border:1px solid rgba(59,130,246,.10);
  border-radius:18px;
  padding:24px;
  transition:.3s ease;
}

.card:hover{
  border-color:#3b82f6;
  transform:translateY(-2px);
}

.card h3{
  color:#3b82f6;
  margin-bottom:8px;
  font-size:1.08rem;
}

.card p{
  color:#cbd5e1;
  line-height:1.7;
}

.quote{
  margin-top:42px;
  padding:26px;
  border-left:4px solid #3b82f6;
  background:rgba(59,130,246,.05);
  border-radius:12px;
}

.quote p{
  color:#e5edff;
  font-size:1.08rem;
  line-height:1.8;
}

.footer-note{
  margin-top:42px;
  font-size:1.15rem;
  font-weight:600;
  color:white;
}

