---
// src/components/KaiAssistant.astro

const assistantName = "Kai";
const welcomeMessage = `Hello, I'm ${assistantName}. I'm here to help you explore PanorOmics, find research areas, discover publications, and guide you around the site.`;
---

<div id="kai-assistant" class="kai-shell">
  <div id="kai-panel" class="kai-panel kai-hidden" aria-live="polite">
    <div class="kai-header">
      <div class="kai-header-left">
        <div class="kai-mini-avatar">
          <div class="kai-mini-head">K</div>
        </div>
        <div>
          <h3>Kai AI Assistant</h3>
          <p>Your PanorOmics guide</p>
        </div>
      </div>
      <button id="kai-minimize" class="kai-icon-btn" aria-label="Close Kai">×</button>
    </div>

    <div id="kai-messages" class="kai-messages">
      <div class="kai-msg kai-msg-bot">
        <div class="kai-bubble">
          {welcomeMessage}
        </div>
      </div>

      <div class="kai-msg kai-msg-bot">
        <div class="kai-bubble">
          I can help you:
          <ul class="kai-list">
            <li>Explore research sections</li>
            <li>Find publications</li>
            <li>Guide you around PanorOmics</li>
            <li>Take you to PanorOmics Online</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="kai-quick-actions">
      <button class="kai-chip" data-kai-action="show me around">Show me around</button>
      <button class="kai-chip" data-kai-action="research">Research</button>
      <button class="kai-chip" data-kai-action="publications">Publications</button>
      <button class="kai-chip" data-kai-action="genomics">Genomics</button>
      <button class="kai-chip" data-kai-action="online">PanorOmics Online</button>
    </div>

    <form id="kai-form" class="kai-input-row">
      <input
        id="kai-input"
        type="text"
        placeholder="Ask Kai a question..."
        autocomplete="off"
      />
      <button type="submit" class="kai-send">Send</button>
    </form>
  </div>

  <button id="kai-launcher" class="kai-launcher" aria-label="Open Kai AI Assistant">
    <div class="kai-burst">
      <div class="kai-ring">
        <div class="kai-face-wrap">
          <div class="kai-face">K</div>
        </div>
      </div>
    </div>
  </button>
</div>

<style>
  .kai-shell{
    position:fixed;
    right:20px;
    bottom:20px;
    z-index:9999;
    font-family:Inter,sans-serif;
  }

  .kai-hidden{
    display:none !important;
  }

  .kai-panel{
    width:340px;
    max-width:calc(100vw - 24px);
    height:480px;
    max-height:calc(100vh - 120px);
    margin-bottom:14px;
    display:flex;
    flex-direction:column;
    overflow:hidden;
    border-radius:24px;
    background:#f7fbff;
    border:1px solid rgba(141, 196, 255, .55);
    box-shadow:0 20px 60px rgba(12, 53, 96, .22);
    animation:kaiPop .22s ease;
  }

  .kai-header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:14px 16px;
    background:linear-gradient(180deg, #eef7ff 0%, #e8f3ff 100%);
    border-bottom:1px solid rgba(141, 196, 255, .45);
  }

  .kai-header-left{
    display:flex;
    align-items:center;
    gap:10px;
  }

  .kai-header h3{
    margin:0;
    font-size:1rem;
    line-height:1.1;
    color:#23415f;
    font-weight:800;
  }

  .kai-header p{
    margin:3px 0 0;
    font-size:.76rem;
    color:#6f86a0;
  }

  .kai-icon-btn{
    background:transparent;
    border:none;
    color:#6f86a0;
    font-size:1.6rem;
    line-height:1;
    cursor:pointer;
  }

  .kai-icon-btn:hover{
    color:#23415f;
  }

  .kai-mini-avatar{
    width:42px;
    height:42px;
    border-radius:50%;
    display:grid;
    place-items:center;
    background:#fff6da;
    border:2px solid #ffd36e;
    box-shadow:0 4px 12px rgba(0,0,0,.08);
  }

  .kai-mini-head{
    width:30px;
    height:30px;
    border-radius:50%;
    display:grid;
    place-items:center;
    background:#d9ecff;
    border:2px solid #94c8ff;
    color:#31557a;
    font-size:.95rem;
    font-weight:900;
  }

  .kai-messages{
    flex:1;
    overflow:auto;
    padding:14px;
    background:#f7fbff;
    display:flex;
    flex-direction:column;
    gap:12px;
  }

  .kai-msg{
    display:flex;
  }

  .kai-msg-bot{
    justify-content:flex-start;
  }

  .kai-msg-user{
    justify-content:flex-end;
  }

  .kai-bubble{
    max-width:88%;
    padding:12px 14px;
    border-radius:18px;
    line-height:1.55;
    font-size:.88rem;
    white-space:pre-wrap;
  }

  .kai-msg-bot .kai-bubble{
    background:#ffffff;
    color:#36516d;
    border:1px solid rgba(141, 196, 255, .45);
    box-shadow:0 4px 14px rgba(12,53,96,.06);
  }

  .kai-msg-user .kai-bubble{
    background:#dff0ff;
    color:#23415f;
    border:1px solid rgba(141, 196, 255, .45);
  }

  .kai-list{
    margin:8px 0 0 18px;
    padding:0;
  }

  .kai-list li{
    margin-bottom:4px;
  }

  .kai-quick-actions{
    padding:10px 14px 6px;
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    background:#eef7ff;
    border-top:1px solid rgba(141, 196, 255, .35);
  }

  .kai-chip{
    border:1px solid rgba(141, 196, 255, .55);
    background:#ffffff;
    color:#426280;
    border-radius:999px;
    padding:7px 11px;
    font-size:.78rem;
    font-weight:700;
    cursor:pointer;
  }

  .kai-chip:hover{
    background:#dff0ff;
  }

  .kai-input-row{
    display:flex;
    gap:10px;
    padding:12px 14px 14px;
    background:#eef7ff;
  }

  #kai-input{
    flex:1;
    border-radius:999px;
    border:1px solid rgba(141, 196, 255, .55);
    background:#ffffff;
    color:#23415f;
    padding:11px 14px;
    outline:none;
    font-size:.87rem;
  }

  #kai-input::placeholder{
    color:#8aa0b6;
  }

  .kai-send{
    border:none;
    border-radius:999px;
    background:#7fc2ff;
    color:#ffffff;
    padding:11px 16px;
    font-weight:800;
    cursor:pointer;
  }

  .kai-send:hover{
    background:#63b4fc;
  }

  .kai-launcher{
    border:none;
    background:transparent;
    padding:0;
    cursor:pointer;
    display:block;
    margin-left:auto;
  }

  .kai-burst{
    width:90px;
    height:90px;
    border-radius:50%;
    display:grid;
    place-items:center;
    background:
      conic-gradient(
        from 0deg,
        #f5c54a 0deg 12deg,
        transparent 12deg 30deg,
        #f5c54a 30deg 42deg,
        transparent 42deg 60deg,
        #f5c54a 60deg 72deg,
        transparent 72deg 90deg,
        #f5c54a 90deg 102deg,
        transparent 102deg 120deg,
        #f5c54a 120deg 132deg,
        transparent 132deg 150deg,
        #f5c54a 150deg 162deg,
        transparent 162deg 180deg,
        #f5c54a 180deg 192deg,
        transparent 192deg 210deg,
        #f5c54a 210deg 222deg,
        transparent 222deg 240deg,
        #f5c54a 240deg 252deg,
        transparent 252deg 270deg,
        #f5c54a 270deg 282deg,
        transparent 282deg 300deg,
        #f5c54a 300deg 312deg,
        transparent 312deg 330deg,
        #f5c54a 330deg 342deg,
        transparent 342deg 360deg
      );
    filter:drop-shadow(0 10px 20px rgba(0,0,0,.18));
  }

  .kai-ring{
    width:64px;
    height:64px;
    border-radius:50%;
    background:#ffffff;
    border:4px solid #b91c1c;
    display:grid;
    place-items:center;
    box-shadow:0 6px 16px rgba(0,0,0,.16);
  }

  .kai-face-wrap{
    width:48px;
    height:48px;
    border-radius:50%;
    background:#f3f4f6;
    border:2px solid #6b7280;
    display:grid;
    place-items:center;
  }

  .kai-face{
    color:#374151;
    font-size:1rem;
    font-weight:900;
  }

  @keyframes kaiPop{
    from{
      opacity:0;
      transform:translateY(10px) scale(.98);
    }
    to{
      opacity:1;
      transform:translateY(0) scale(1);
    }
  }

  @media(max-width:768px){
    .kai-shell{
      right:14px;
      bottom:14px;
    }

    .kai-panel{
      width:min(100vw - 20px, 340px);
      height:430px;
    }

    .kai-burst{
      width:82px;
      height:82px;
    }

    .kai-ring{
      width:58px;
      height:58px;
    }

    .kai-face-wrap{
      width:42px;
      height:42px;
    }
  }
</style>

<script is:inline>
  const panel = document.getElementById('kai-panel');
  const launcher = document.getElementById('kai-launcher');
  const minimize = document.getElementById('kai-minimize');
  const form = document.getElementById('kai-form');
  const input = document.getElementById('kai-input');
  const messages = document.getElementById('kai-messages');
  const chips = document.querySelectorAll('.kai-chip');

  function addMessage(text, who = 'bot') {
    const wrap = document.createElement('div');
    wrap.className = `kai-msg kai-msg-${who}`;

    const bubble = document.createElement('div');
    bubble.className = 'kai-bubble';
    bubble.textContent = text;

    wrap.appendChild(bubble);
    messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;
  }

  function answerKai(question) {
    const q = question.toLowerCase().trim();

    if (q.includes('show me around') || q.includes('show around') || q.includes('tour')) {
      return `Welcome to PanorOmics. Start with the homepage, explore the Research sections, visit the Publications Library for curated scientific literature, and use PanorOmics Online for courses and certificates.`;
    }

    if (q.includes('genomics')) {
      return `The Genomics section includes Genome Sequencing, Variant Discovery, Precision Medicine, and Population Genomics.`;
    }

    if (q.includes('research')) {
      return `PanorOmics Research is organized into major omics sciences sections including genomics, transcriptomics, proteomics, metabolomics, lipidomics, epigenomics, and microbiomics.`;
    }

    if (q.includes('publication') || q.includes('library') || q.includes('papers')) {
      return `The Publications Library helps visitors browse curated scientific literature, landmark discoveries, and thematic collections.`;
    }

    if (q.includes('online') || q.includes('course') || q.includes('certificate') || q.includes('learn')) {
      return `PanorOmics Online is the learning portal for courses, certificates, and educational resources.`;
    }

    if (q.includes('what is panoromics') || q.includes('omics')) {
      return `PanorOmics is a scientific knowledge platform focused on Omics Sciences as an integrated discipline connecting research, publications, and learning pathways.`;
    }

    return `I can help guide visitors through Research, the Publications Library, Genomics, and PanorOmics Online.`;
  }

  launcher?.addEventListener('click', () => {
    panel.classList.toggle('kai-hidden');
  });

  minimize?.addEventListener('click', () => {
    panel.classList.add('kai-hidden');
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const question = input.value.trim();
    if (!question) return;

    addMessage(question, 'user');
    const reply = answerKai(question);
    setTimeout(() => addMessage(reply, 'bot'), 220);
    input.value = '';
  });

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const question = chip.getAttribute('data-kai-action') || chip.textContent.trim();
      addMessage(question, 'user');
      const reply = answerKai(question);
      setTimeout(() => addMessage(reply, 'bot'), 180);
    });
  });
</script>
