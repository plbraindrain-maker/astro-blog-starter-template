--
import HeaderLink from './HeaderLink.astro';
---

<header style="background: white; border-bottom: 1px solid #eee; padding: 1rem 0;">
	<nav style="display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 0 1rem;">
		
		<!-- 1 & 2: LOGO SECTION (Lowercase & Full Name) -->
		<a href="/" style="display: flex; align-items: center; text-decoration: none; gap: 18px;">
			<img src="/logo.png" alt="PanorOmics Logo" style="height: 85px; width: auto;" />
			<div style="display: flex; flex-direction: column; line-height: 1.1;">
				<!-- Biggest size, lowercase -->
				<span style="font-size: 2.2rem; font-weight: 800; color: #0047AB; letter-spacing: -1px; text-transform: lowercase;">
					panoromics
				</span>
				<!-- Full name, smaller size -->
				<span style="font-size: 0.75rem; color: #666; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px;">
					The Panoramic Omics Sciences Center
				</span>
			</div>
		</a>

		<!-- RIGHT SIDE CONTROLS -->
		<div style="display: flex; align-items: center; gap: 20px;">
			<div class="dropdown">
				<button class="dropbtn">explore ▼</button>
				<div class="dropdown-content">
					<HeaderLink href="/research">Research</HeaderLink>
					<HeaderLink href="/education">Education and Learning</HeaderLink>
					<HeaderLink href="/news">News</HeaderLink>
					<HeaderLink href="/about">About Us</HeaderLink>
					<HeaderLink href="/give" style="font-weight: bold; color: #0047AB;">Give</HeaderLink>
				</div>
			</div>

			<button id="search-button" aria-label="Search" style="background: none; border: none; cursor: pointer; padding: 5px;">
				<svg xmlns="http://www.w3.org" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"></circle>
					<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
				</svg>
			</button>
		</div>
	</nav>
</header>

<!-- 3: INTRODUCTION SECTION -->
<section style="max-width: 900px; margin: 60px auto; padding: 0 1rem; text-align: center;">
	<h2 style="font-size: 1rem; text-transform: uppercase; color: #0047AB; letter-spacing: 2px; margin-bottom: 1rem;">
		The Central Dogma of Omics Science
	</h2>
	<p style="font-size: 1.25rem; line-height: 1.6; color: #444; font-weight: 400;">
		PanorOmics is dedicated to advancing precision medicine through multi-omics integration and innovative data science. Our center explores the complex biological landscape—integrating 
		<span style="font-weight: 600; color: #222;">Genomics, Transcriptomics, Epigenomics & Chromatin Dynamics, Proteomics, Metabolomics,</span> and 
		<span style="font-weight: 600; color: #222;">Computational Bioinformatics</span> 
		to solve pressing challenges in disease mechanisms.
	</p>
</section>

<script>
	const searchBtn = document.getElementById('search-button');
	searchBtn?.addEventListener('click', () => {
		const query = prompt("Search PanorOmics:");
		if (query) window.location.href = `/search?q=${encodeURIComponent(query)}`;
	});
</script>

<style>
	.dropdown { position: relative; display: inline-block; }
	.dropbtn { background: none; border: none; color: #333; font-weight: 600; font-size: 0.9rem; text-transform: lowercase; cursor: pointer; }
	.dropdown-content {
		display: none;
		position: absolute;
		right: 0;
		background: white;
		min-width: 200px;
		box-shadow: 0 10px 25px rgba(0,0,0,0.1);
		border-radius: 8px;
		overflow: hidden;
		z-index: 100;
	}
	.dropdown-content :global(a) { padding: 12px 20px; text-decoration: none; display: block; color: #333; font-size: 0.9rem; border-bottom: 1px solid #f5f5f5; }
	.dropdown-content :global(a:hover) { background: #f0f7ff; color: #0047AB; }
	.dropdown:hover .dropdown-content { display: block; }
</style>

