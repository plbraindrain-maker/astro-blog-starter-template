  padding:22px;
}

.paper h3{
  color:#3b82f6;
  margin-bottom:8px;
}

.meta{
  color:#94a3b8;
  font-size:.86rem;
  line-height:1.5;
}

.button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin-top:24px;
  padding:12px 24px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-weight:700;
}

.secondary-button{
  display:inline-flex;
