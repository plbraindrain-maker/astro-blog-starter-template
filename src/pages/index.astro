---
import KaiAssistant from "../components/KaiAssistant.astro";

const navLinks = [
  { name: 'Home', href: '/' }, 
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const cards = [
  ['Genomics', 'Comprehensive analysis of genetic variation to uncover biology and disease risk.', '/genomics', '/genomics-card.png'],
  ['Transcriptomics', 'Profiling RNA expression to understand gene activity and regulation.', '/transcriptomics', '/transcriptomics-card.png'],
  ['Proteomics', 'Characterizing proteins to reveal function, pathways, and biomarkers.', '/proteomics', '/proteomics-card.png'],
  ['Metabolomics', 'Measuring metabolites to capture biochemical phenotypes and pathways.', '/metabolomics', '/metabolomics-card.png'],
  ['Lipidomics', 'Analyzing lipid species to illuminate membrane biology and metabolism.', '/lipidomics', '/lipidomics-card.png'],
  ['Epigenomics', 'Studying epigenetic modifications that shape gene regulation.', '/epigenomics', '/epigenomics-card.png'],
  ['Microbiomics','Exploring microbial communities and their roles in health, disease, and ecosystems.','/microbiomics','/microbiomics-card.png'],
];
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>PanorOmics | The Panoramic Omics Sciences Center</title>

<link rel="icon" type="image/png" href="/icon-mark.png" />
<link rel="apple-touch-icon" href="/icon-mark.png" />

<meta name="theme-color" content="#020817" />

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
  overflow-x:hidden;
}

.header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  z-index:1000;
  background:rgba(2,8,23,.78);
  backdrop-filter:blur(18px);
  border-bottom:1px solid rgba(59,130,246,.10);
}

.header-inner{
  max-width:1450px;
  margin:0 auto;
  padding:12px 32px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.brand{
  display:flex;
  align-items:center;
  gap:12px;
  text-decoration:none;
}

.brand img{
  width:44px;
  height:44px;
  object-fit:contain;
}

.brand-title{
  font-size:1.45rem;
  font-weight:800;
  line-height:1;
  color:white;
  letter-spacing:-0.04em;
}

.brand-title span{
  color:#3b82f6;
}

.brand-sub{
  color:#94a3b8;
  font-size:.56rem;
  margin-top:2px;
  letter-spacing:.10em;
}

.nav{
  display:flex;
  gap:18px;
}

.nav a{
  color:#dbe4ff;
  text-decoration:none;
  font-size:.8rem;
  transition:.3s ease;
}

.nav a:hover{
  color:#3b82f6;
}

.menu-toggle{
  display:none;
  background:none;
  border:none;
  color:white;
  font-size:1.8rem;
  cursor:pointer;
}

.mobile-menu{
  display:none;
  flex-direction:column;
  position:fixed;
  top:68px;
  left:0;
  width:100%;
  z-index:999;
  background:#020817;
  border-bottom:1px solid rgba(59,130,246,.12);
  padding:16px 24px;
}

.mobile-menu a{
  color:#dbe4ff;
  text-decoration:none;
  font-size:.95rem;
  padding:12px 0;
  border-bottom:1px solid rgba(255,255,255,.06);
}

.mobile-menu.show{
  display:flex;
}

/* TOP SINGLE HUMAN CLIP */

.top-clip-section{
  padding:96px 6% 10px;
  background:
    radial-gradient(circle at center, rgba(59,130,246,.14), transparent 42%),
    #020817;
}

.top-clip-video{
  width:100%;
  max-width:1180px;
  margin:0 auto;
  border-radius:24px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.08);
  box-shadow:0 0 46px rgba(37,99,235,.12);
  position:relative;
  aspect-ratio:16/9;
  background:#020817;
}

.top-clip-video video{
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
}

.clip-glass-overlay{
  position:absolute;
  inset:0;
  z-index:2;
  background:rgba(2,8,23,.32);
}

.clip-glass-text{
  position:absolute;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
  z-index:3;
  width:min(92%, 1120px);
  color:white;
  text-align:center;
}

.clip-glass-text h2{
  font-size:clamp(1.6rem,4vw,3.4rem);
  line-height:1.15;
  letter-spacing:-.02em;
  font-weight:700;
  margin-bottom:clamp(14px,2vw,26px);
  color:#8C1515;
  text-shadow:0 3px 18px rgba(0,0,0,.85);
}

.clip-glass-text p{
  font-size:clamp(.9rem,1.75vw,1.55rem);
  line-height:2;
  font-weight:700;
  color:#8C1515;
  max-width:1040px;
  margin:0 auto;
  text-shadow:0 2px 14px rgba(0,0,0,.9);
}

/* ORIGINAL HERO WITH 3 ROTATING CLIPS */

.hero{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:30px;
  padding:34px 6% 24px;
  min-height:auto;
  overflow:hidden;
  background:
  radial-gradient(circle at center,
  rgba(59,130,246,.14),
  transparent 42%),
  #020817;
}

.hero-left{
  flex:1;
  max-width:480px;
}

.hero-kicker{
  color:#3b82f6;
  font-size:.7rem;
  letter-spacing:.26em;
  margin-bottom:14px;
  font-weight:700;
}

.hero-title{
  font-size:clamp(2.15rem,3.9vw,3.7rem);
  line-height:.96;
  letter-spacing:-0.055em;
  font-weight:900;
  margin-bottom:16px;
}

.hero-title span{
  color:#3b82f6;
}

.hero-description{
  font-size:.9rem;
  line-height:1.6;
  color:#cbd5e1;
  max-width:500px;
  margin-bottom:24px;
}

.hero-button{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:12px 24px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-size:.9rem;
  font-weight:700;
  transition:.35s ease;
}

.hero-button:hover{
  transform:translateY(-3px);
  box-shadow:0 12px 40px rgba(37,99,235,.35);
}

.hero-video{
  width:100%;
  max-width:670px;
  border-radius:20px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.06);
  box-shadow:0 0 42px rgba(37,99,235,.10);
  position:relative;
  aspect-ratio:16/9;
  background:#020817;
  flex:1;
}

.hero-video video{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
}

.hero-slide{
  opacity:0;
  transition:opacity 1.2s ease;
}

.hero-slide.active{
  opacity:1;
}

.hero-caption{
  position:absolute;
  left:22px;
  bottom:18px;
  z-index:3;
  color:rgba(255,255,255,.72);
  font-size:.72rem;
  letter-spacing:.08em;
  font-weight:600;
  text-shadow:0 2px 12px rgba(0,0,0,.65);
}

.section{
  padding:30px 7%;
}

.section-title{
  font-size:clamp(1.55rem,2.6vw,2.55rem);
  line-height:1.08;
  letter-spacing:-0.04em;
  margin-bottom:10px;
}

.section-title span{
  color:#3b82f6;
}

.section-description{
  font-size:.9rem;
  line-height:1.6;
  color:#cbd5e1;
  max-width:820px;
}

.omics-grid{
  margin-top:20px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
  gap:16px;
}

.omics-card{
  background:rgba(8,15,35,.72);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:18px;
  text-decoration:none;
  transition:.35s ease;
  overflow:hidden;
}

.omics-card:hover{
  transform:translateY(-5px);
  border-color:#3b82f6;
  box-shadow:0 18px 50px rgba(37,99,235,.11);
}

.omics-card img{
  width:100%;
  height:145px;
  object-fit:cover;
  border-radius:14px;
  margin-bottom:14px;
  display:block;
  border:1px solid rgba(59,130,246,.12);
}

.omics-card h3{
  font-size:1.12rem;
  margin-bottom:9px;
  color:#2563eb;
}

.omics-card p{
  color:#7f8ca3;
  line-height:1.55;
  font-size:.86rem;
}

.central-dogma{
  margin-top:20px;
  border-radius:22px;
  overflow:hidden;
  border:1px solid rgba(59,130,246,.10);
  box-shadow:0 0 42px rgba(37,99,235,.09);
}

.central-dogma img{
  width:100%;
  display:block;
}

.footer{
  background:#07111f;
  padding:28px 5% 14px;
  color:#dbe4ee;
  border-top:1px solid rgba(255,255,255,.06);
}

.footer-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:24px;
}

.footer-brand{
  display:flex;
  align-items:center;
  gap:14px;
}

.footer-logo{
  width:72px;
  height:72px;
  object-fit:contain;
}

.footer-brand h3{
  font-size:1.1rem;
  color:white;
  margin-bottom:2px;
}

.footer-brand p{
  font-size:.78rem;
  color:#94a3b8;
}

.footer-social{
  display:flex;
  gap:18px;
}

.footer-social a{
  color:#dbe4ee;
  font-size:1.45rem;
  transition:.25s ease;
}

.footer-social a:nth-child(1):hover{color:#0b3d91;}
.footer-social a:nth-child(2):hover{color:#000000;}
.footer-social a:nth-child(3):hover{color:#e1306c;}
.footer-social a:nth-child(4):hover{color:#ff0000;}
.footer-social a:nth-child(5):hover{color:#0a66c2;}
.footer-social a:nth-child(6):hover{color:#ffffff;}

.footer-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  margin-bottom:24px;
}

.footer-column{
  display:flex;
  flex-direction:column;
  gap:9px;
}

.footer-heading{
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:8px;
  color:white;
  font-size:.95rem;
  font-weight:800;
}

.footer-heading i{
  font-size:1.45rem;
  color:#dbe4ee;
}

.footer-column a{
  text-decoration:none;
  color:#94a3b8;
  font-size:.82rem;
  transition:.2s ease;
}

.footer-column a:hover{
  color:white;
}

.footer-bottom{
  border-top:1px solid rgba(255,255,255,.06);
  padding-top:14px;
  font-size:.78rem;
  color:#64748b;
  text-align:center;
}

@media(max-width:1100px){

  .hero{
    flex-direction:column;
    padding-top:34px;
  }

  .nav{
    display:none;
  }

  .menu-toggle{
    display:block;
  }

  .hero-video{
    max-width:100%;
  }
}

@media(max-width:900px){

  .footer-top{
    flex-direction:column;
    align-items:flex-start;
    gap:18px;
  }

  .footer-grid{
    grid-template-columns:1fr;
  }
}

@media(max-width:768px){

  .header-inner{
    padding:12px 16px;
  }

  .top-clip-section{
    padding:96px 18px 10px;
  }

    .clip-glass-overlay{
    background:
      linear-gradient(
        180deg,
        rgba(2,8,23,.80) 0%,
        rgba(2,8,23,.62) 45%,
        rgba(2,8,23,.80) 100%
      );
  }

  .clip-glass-text{
    left:50%;
    top:50%;
    transform:translate(-50%,-50%);
    width:88%;
    max-width:320px;
    text-align:center;
  }

  .clip-glass-text h2{
    font-size:1.35rem;
    line-height:1.15;
    font-weight:500;
    margin-bottom:12px;
  }

  .clip-glass-text p{
  font-size:.72rem;
  line-height:1.75;
  font-weight:400;
  max-width:340px;
  margin:0 auto;
}

  .hero{
    padding:34px 18px 34px;
  }

  .section{
    padding:28px 18px;
  }

  .hero-title{
    font-size:2.35rem;
  }

  .section-title{
    font-size:1.75rem;
  }

  .hero-description,
  .section-description{
    font-size:.88rem;
  }

  .brand-title{
    font-size:1.25rem;
  }

  .brand img{
    width:40px;
    height:40px;
  }

  .hero-button{
    width:100%;
    justify-content:center;
  }

  .omics-card img{
    height:170px;
  }
}
.clip-glass-text{
  animation: statementPulse 18s ease-in-out infinite;
}

@keyframes statementPulse{
  0%{
    opacity:0;
    transform:translate(-50%,-46%);
  }

  10%{
    opacity:1;
    transform:translate(-50%,-50%);
  }

  78%{
    opacity:1;
    transform:translate(-50%,-50%);
  }

  100%{
    opacity:0;
    transform:translate(-50%,-54%);
  }
}
@media(max-width:430px){

  .top-clip-video{
    aspect-ratio:4/5;
  }

  .clip-glass-text{
    width:86%;
    max-width:300px;
  }

  .clip-glass-text h2{
    font-size:1.25rem;
  }

  .clip-glass-text p{
    font-size:.68rem;
    line-height:1.42;
  }
}
.panoromics-online{
  color:#8C1515 !important;
  font-weight:700;
}

.panoromics-online:hover{
  color:#B1040E !important;
}

.integrity-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  margin-top:12px;
  padding:12px 24px;
  border-radius:999px;
  border:1px solid rgba(59,130,246,.25);
  background:rgba(59,130,246,.08);
  color:#dbe4ff;
  text-decoration:none;
  font-size:.9rem;
  font-weight:700;
  transition:.35s ease;
}

.integrity-button:hover{
  border-color:#3b82f6;
  background:rgba(59,130,246,.15);
  transform:translateY(-2px);
}
</style>

</head>

<body>

<header class="header">

  <div class="header-inner">

    <a class="brand" href="/">

      <img src="/panoromics-logo.png" alt="PanorOmics Logo">

      <div>

        <div class="brand-title">
          Panor<span>Omics</span>
        </div>

        <div class="brand-sub">
          INTEGRATING LIFE SCIENCES • DATA • DISCOVERY
        </div>

      </div>

    </a>

    <nav class="nav">

      {navLinks.map((link) => (
        <a href={link.href}>{link.name}</a>
      ))}

    </nav>

    <button class="menu-toggle" onclick="toggleMenu()">
      ☰
    </button>

  </div>

</header>

<div id="mobileMenu" class="mobile-menu">

  {navLinks.map((link) => (
    <a href={link.href}>{link.name}</a>
  ))}

</div>

<section class="top-clip-section">

  <div class="top-clip-video">

    <video autoplay muted loop playsinline preload="auto">
      <source src="/panoromics-hero-glass.mp4" type="video/mp4">
    </video>

    <div class="clip-glass-overlay"></div>

    <div class="clip-glass-text">
      <h2>
        Where Omics Sciences Converge
      </h2>

      <p>
        PanorOmics is where the omics sciences converge. We advance genomics,
        transcriptomics, proteomics, metabolomics, lipidomics, epigenomics,
        and microbiomics not as separate fields but as one integrated discipline
        for understanding life and disease in its full molecular complexity.
        Through research, education, data, and innovation, we make that science
        accessible to those who will use it to advance medicine, drive biotechnology,
        and deliver precision health.
      </p>
    </div>

  </div>

</section>

<section class="hero">

  <div class="hero-left">

    <div class="hero-kicker">
      PANOROMICS OMICS SCIENCES
    </div>

    <h1 class="hero-title">
      Unifying <span>omics.</span><br>
      Advancing <span>health.</span><br>
      Transforming <span>lives.</span>
    </h1>

    <p class="hero-description">
      PanorOmics integrates multi-omics sciences,
      computational biology, artificial intelligence,
      and translational biotechnology into a unified
      systems-level framework for discovery,
      precision medicine, and human health.
    </p>

    <a href="#research" class="hero-button">
      Explore Our Research →
    </a>

    <br><br>

    <a href="/scientific-integrity" class="hero-button">
      🛡 Scientific Integrity →
    </a>

  </div>

  <div class="hero-video">

    <video class="hero-slide active" autoplay muted loop playsinline preload="auto">
      <source src="/chicago-science-skyline-hero.mp4" type="video/mp4">
    </video>

    <video class="hero-slide" autoplay muted loop playsinline preload="auto">
      <source src="/pittsburgh-science-skyline-hero.mp4" type="video/mp4">
    </video>

    <video class="hero-slide" autoplay muted loop playsinline preload="auto">
      <source src="/panoromics-architecture-of-life-v1.mp4" type="video/mp4">
    </video>

    <div class="hero-caption" id="heroCaption">
      Rooted in Chicago
    </div>

  </div>

</section>

<section class="section">

  <h2 class="section-title">
    A Discipline, <span>Not a Toolbox</span>
  </h2>

  <p class="section-description">
    Omics Sciences is an emerging integrative discipline
    that unifies molecular biology, computational systems,
    artificial intelligence, biotechnology, and human health
    into a systems-level understanding of life.
  </p>

</section>

<section class="section">

  <div class="central-dogma">

    <img
      src="/panoromics-architecture-of-life-v1.png"
      alt="PanorOmics Architecture of Life"
    >

  </div>

</section>

<section class="section" id="research">

  <h2 class="section-title">
    The Architecture <span>of Life</span>
  </h2>

  <p class="section-description">
    PanorOmics explores interconnected biological layers
    across genome, epigenome, transcriptome, proteome,
    metabolome, lipidome, microbiome, and phenotype to
    advance translational discovery and precision biotechnology.
  </p>

  <div class="omics-grid">

    {cards.map(([title, desc, href, image]) => (

      <a href={href} class="omics-card">

        <img src={image} alt={`${title} card image`}>

        <h3>{title}</h3>

        <p>{desc}</p>

      </a>

    ))}

  </div>

</section>

<section class="section">

  <h2 class="section-title">
    The Central Dogma <span>of Omics Science</span>
  </h2>

  <p class="section-description">
    From biological information to molecular function.
    From systems biology to clinical impact.
  </p>

  <div class="central-dogma">

    <img
      src="/central-dogma-omics-science-v2.png"
      alt="Central Dogma of Omics Science"
    >

  </div>

</section>

<section class="section">

  <h2 class="section-title">
    Omics Sciences <span>in Real Lives</span>
  </h2>

  <p class="section-description">
    From molecular discovery to human impact.
  </p>

  <div id="realLivesGrid" style="
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:24px;
    margin-top:20px;
    max-width:900px;
    margin-left:auto;
    margin-right:auto;
    align-items:start;
  ">
  </div>

  <script is:inline>
    const realLivesStories = [
      {
        title: "Victoria Gray: A Living Breakthrough",
        image: "/victoria-gray-sickle-cell-crispr.png",
        alt: "Victoria Gray during treatment for sickle cell disease",
        credit: "Photo: NPR Health Shots / Meredith Rizzo",
        description: "Diagnosed with sickle cell disease as an infant, Victoria Gray lived with severe pain crises for more than three decades. Her story shows how genomics, CRISPR gene editing, and biotechnology can transform human lives.",
        href: "/victoria-gray",
        button: "Read Victoria Gray's Story →"
      },
      {
        title: "Emily Whitehead: A Living Drug Against Leukemia",
        image: "/emily-whitehead-car-t-therapy.png",
        alt: "Emily Whitehead before and after CAR T-cell therapy",
        credit: "Image source: Benjamin McLeod, LinkedIn public educational post on Emily Whitehead and CAR T-cell therapy; original photo credit to be confirmed.",
        description: "Emily Whitehead’s story became a landmark example of CAR T-cell therapy, showing how biotechnology, immunology, and cell engineering can reshape cancer treatment.",
        href: "/emily-whitehead",
        button: "Read Emily Whitehead's Story →"
      },
      {
        title: "Mila Makovec: A Tailor-Made Therapy",
        image: "/mila-makovec-rare-disease-genomics.png",
        alt: "Mila Makovec during rare disease treatment",
        credit: "Photo: Katherine C. Cohen / Boston Children’s Hospital, via STAT.",
        description: "Mila Makovec’s story became a landmark example of rare disease genomics, showing how whole-genome sequencing and RNA-targeted therapy can open new possibilities for individualized medicine.",
        href: "/mila-makovec",
        button: "Read Mila Makovec's Story →"
      },
      {
       title: "A Safer Dose Written in the Genome",
       image: "/pharmacogenomics-drug-response.png",
       alt: "Pharmacogenomics illustration showing DNA, medication, and individualized drug response",
       credit: "Illustration: Pharmacogenomics connects DNA variation with medication response.",
       description: "A pharmacogenomics story showing how genetic variation can influence medication response, helping explain why the same medicine may require different dosing or monitoring across individuals.",
       href: "/pharmacogenomics-drug-response",
       button: "Read Pharmacogenomics Story →"
      },
      {
       title: "When Pathogens Leave Genetic Footprints",
       image: "/pathogen-genomic-surveillance.png",
       alt: "COVID-19 genomic surveillance illustration showing viral sequencing, variant tracking, and public-health response",
       credit: "Illustration: COVID-19 genomic surveillance connects pathogen sequencing with variant tracking and public-health response.",
       description: "An infectious disease genomics story showing how viral sequencing can help track outbreaks, identify variants, monitor transmission patterns, and support public-health action.",
       href: "/pathogen-genomic-surveillance",
       button: "Read Genomic Surveillance Story →"
      },
      {
      title: "When the Microbiome Becomes Medicine",
      image: "/microbiome-therapy-cdiff.png",
      alt: "Microbiome therapy illustration showing gut microbial restoration after recurrent infection",
      credit: "Illustration: Microbiome-based therapy shows how restoring gut microbial balance can help protect the intestinal ecosystem after recurrent infection.",
      description: "A microbiome story showing how restoring gut microbial balance can help treat recurrent infection and reveal the therapeutic power of microbial ecosystems.",
      href: "/microbiome-therapy-cdiff",
      button: "Read Microbiome Therapy Story →"
      },
      {
        title: "When Cancer Leaves Molecular Clues",
        image: "/cancer-molecular-clues-hero-v1.png",
        alt: "Cancer Molecular Clues Multi-omics Story",
        credit: "",
        description: "Cancer does not begin as a visible disease. It begins as molecular disruption — changes in DNA, RNA, proteins, metabolism, lipids, epigenetic regulation, immunity, and the surrounding biological environment.",
        href: "/cancer-molecular-clues",
        button: "Read Cancer Molecular Clues Story →"
      }
    ];

    const storiesPerWeek = 2;
    const weekNumber = Math.floor(Date.now() / (1000 * 60 * 60 * 24 * 7));
    const startIndex = (weekNumber * storiesPerWeek) % realLivesStories.length;

    const visibleStories = [
      realLivesStories[startIndex],
      realLivesStories[(startIndex + 1) % realLivesStories.length]
    ];

    const grid = document.getElementById("realLivesGrid");

    grid.innerHTML = visibleStories.map(story => `
      <div style="
        background:rgba(8,15,35,.72);
        border:1px solid rgba(59,130,246,.12);
        border-radius:18px;
        padding:18px;
        overflow:hidden;
        transition:.35s ease;
