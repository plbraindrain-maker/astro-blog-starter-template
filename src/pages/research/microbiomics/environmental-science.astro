}

.hero-image{
  margin-top:36px;
  width:100vw;
  margin-left:calc(50% - 50vw);
}

.hero-image img{
  width:100%;
  display:block;
  border-radius:24px;
  border:1px solid rgba(59,130,246,.14);
}

.section{
  margin-top:64px;
}

.section h2{
