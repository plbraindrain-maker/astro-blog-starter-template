  border-radius:999px;
  background:#8C1515;
  color:#ffffff;
  border:1px solid #A77A7A;
  text-decoration:none;
  font-weight:700;
  transition:.25s ease;
}

.secondary-button:hover{
  background:#6F1111;
  border-color:#8C1515;
  transform:translateY(-2px);
}

@media(max-width:768px){
  .container{
    padding:70px 20px 55px;
  }

  .timeline-item{
    grid-template-columns:1fr;
  }
}
</style>
