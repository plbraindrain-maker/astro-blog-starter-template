  'Genomics',
  'Transcriptomics',
  'Proteomics',
  'Metabolomics',
  'Lipidomics',
  'Epigenomics',
  'Microbiomics',
];

const publicationTypes = [
  'All Types',
  'Research Articles',
  'Reviews',
  'Clinical Studies',
  'Case Studies',
  'Protocols',
  'Datasets',
  'Books',
  'Educational Resources',
];

const keywords = [
  'Cancer',
  'CRISPR',
  'AI Biology',
  'Non-coding RNA',
  'Precision Medicine',
  'Single Cell',
  'Aging',
  'Stem Cells',
  'Biomarkers',
  'Drug Discovery',
