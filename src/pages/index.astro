---
// Clean Operational Presentation Canvas for PanorOmics
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/panoromics-logo.png" />
		<title>PanorOmics | Unifying Omics. Advancing Health. Transforming Lives.</title>
		<style>
			/* Strip browser defaults */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				scroll-behavior: smooth;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED LIGHTER NAV BAR HEADER FOR TEXT CONTRAST */
			.site-header {
				background-color: #f4f7fa; /* Clean, light science-lab background to make dark blue letters pop */
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			/* Controlled Small Header Icon Size */
			.header-logo-icon {
				height: 45px;
				width: auto;
				display: block;
				border-radius: 8px;
			}

			/* Typography Identity Block */
			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			/* Dark Blue Main Brand Label */
			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; /* Deep clinical dark blue representing authority and science */
				letter-spacing: -0.5px;
			}

			/* Subtitle Center Label */
			.brand-subtitle {
				font-size: 0.7rem;
				color: #4a607a; /* Muted corporate blue-gray for the full academic title */
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				margin-top: 1px;
			}

			/* PAGE CONTENT LAYOUT */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			.page-section {
				width: 100%;
				max-width: 1920px;
				display: flex;
				justify-content: center;
			}

			.full-page-asset {
				width: 100%;
				height: auto;
				display: block;
			}
		</style>
	</head>
	<body>

		<!-- FIXED STICKY NAVIGATION BAR -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<img src="/panoromics-logo.png" alt="PanorOmics" class="header-logo-icon" />
					
						<span class="brand-text">PanorOmics</span>
						<span class="brand-subtitle">The Panoramic Omics Sciences Center</span>
					</div>
				</a>
			</div>
		</header>

		<!-- MAIN INFOGRAPHIC SCROLLING SECTIONS -->
		<div class="landing-container">
			
			<!-- SECTION 1: HERO & ECOSYSTEM OVERVIEW -->
			<section class="page-section">
				<img 
					src="/panoromics-logo.png" 
					alt="PanorOmics - Unifying Omics. Advancing Health. Transforming Lives." 
					class="full-page-asset"
				/>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA & SIX PILLARS MAP -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>
			</section>

		</div>
	</body>
</html>
