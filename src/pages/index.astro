---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const omicsPillars = [
  {
    name: 'GENOMICS',
    border: '#2563eb',
    text: 'The complete set of DNA, including genes, variants, and genetic architecture.'
  },
  {
    name: 'TRANSCRIPTOMICS',
    border: '#00c853',
    text: 'Examine RNA molecules to understand gene expression and cellular function.'
  },
  {
    name: 'PROTEOMICS',
    border: '#a855f7',
    text: 'Analyze the full complement of proteins to uncover function, interactions, and pathways.'
  },
  {
    name: 'METABOLOMICS',
    border: '#ff1744',
    text: 'Profile small-molecule metabolites to reveal biochemical activity and metabolic states.'
  },
  {
    name: 'LIPIDOMICS',
    border: '#f59e0b',
    text: 'Investigate lipids and lipid species to understand membrane biology and signaling.'
  },
  {
    name: 'EPIGENOMICS',
    border: '#4f46e5',
    text: 'Explore epigenetic modifications regulating gene activity without changing DNA.'
  }
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>PanorOmics</title>

  <style>

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: #010816;
      color: white;
      font-family: Arial, Helvetica, sans-serif;
      overflow-x: hidden;
    }

    /* HEADER */

    .site-header {
      width: 100%;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 999;
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }

    .header-container {
      max-width: 1400px;
      margin: auto;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }

    .branding {
      display: flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
    }

    .branding img {
      height: 62px;
      width: auto;
    }

    .branding-text {
      display: flex;
      flex-direction: column;
    }

    .brand-title {
      color: #020817;
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
    }

    .brand-sub {
      color: #64748b;
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-top: 0.2rem;
    }

    .main-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .nav-link {
      color: #1e293b;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: 0.2s ease;
    }

    .nav-link:hover {
      color: #2563eb;
    }

    /* HERO */

    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 5rem 2rem;
      background:
        radial-gradient(circle at center, rgba(37,99,235,0.18), transparent 45%),
        #010816;
    }

    .hero-container {
      max-width: 1400px;
      width: 100%;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .hero-text h1 {
      font-size: 6rem;
      line-height: 0.95;
      font-weight: 900;
      margin-bottom: 2rem;
    }

    .hero-text .blue {
      color: #3b82f6;
    }

    .hero-text p {
      font-size: 1.4rem;
      line-height: 1.8;
      color: #cbd5e1;
      max-width: 700px;
      margin-bottom: 2rem;
    }

    .hero-btn {
      display: inline-block;
      background: #2563eb;
      color: white;
      text-decoration: none;
      padding: 1rem 2rem;
      border-radius: 999px;
      font-size: 1rem;
      font-weight: 700;
      transition: 0.3s ease;
    }

    .hero-btn:hover {
      background: #1d4ed8;
      transform: translateY(-2px);
    }

    .hero-image img {
      width: 100%;
      border-radius: 28px;
      box-shadow: 0 0 50px rgba(37,99,235,0.25);
    }

    /* PILLARS */

    .pillars-section {
      max-width: 1400px;
      margin: auto;
      padding: 6rem 2rem;
    }

    .pillars-label {
      text-align: center;
      color: #64748b;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    .pillars-title {
      text-align: center;
      font-size: 4rem;
      font-weight: 900;
      margin-bottom: 4rem;
    }

    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 2rem;
    }

    .pillar-card {
      background: rgba(255,255,255,0.02);
      border: 2px solid;
      border-radius: 28px;
      padding: 2.5rem;
      transition: 0.3s ease;
    }

    .pillar-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 0 30px rgba(255,255,255,0.08);
    }

    .pillar-card h3 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      font-weight: 800;
    }

    .pillar-card p {
      color: #cbd5e1;
      font-size: 1.15rem;
      line-height: 1.9;
    }

    /* DOGMA */

    .dogma-section {
      max-width: 1400px;
      margin: auto;
      padding: 6rem 2rem 8rem;
      text-align: center;
    }

    .dogma-section h2 {
      font-size: 4rem;
      font-weight: 900;
      margin-bottom: 1rem;
    }

    .dogma-section p {
      color: #94a3b8;
      font-size: 1.4rem;
      margin-bottom: 3rem;
    }

    .dogma-image {
      width: 100%;
      border-radius: 30px;
      overflow: hidden;
      box-shadow: 0 0 60px rgba(37,99,235,0.15);
    }

    .dogma-image img {
      width: 100%;
      display: block;
    }

    /* MOBILE */

    @media (max-width: 1000px) {

      .hero-container {
        grid-template-columns: 1fr;
      }

      .hero-text {
        text-align: center;
      }

      .hero-text p {
        margin-inline: auto;
      }

      .hero-text h1 {
        font-size: 4rem;
      }

      .pillars-title {
        font-size: 2.8rem;
      }

      .dogma-section h2 {
        font-size: 2.8rem;
      }

    }

    @media (max-width: 768px) {

      .header-container {
        flex-direction: column;
      }

      .main-nav {
        justify-content: center;
      }

      .hero-text h1 {
        font-size: 3rem;
      }

      .hero-text p {
        font-size: 1.1rem;
      }

      .pillars-title {
        font-size: 2.2rem;
      }

      .dogma-section h2 {
        font-size: 2.2rem;
      }

    }

  </style>
</head>

<body>

  <!-- HEADER -->

  <header class="site-header">

    <div class="header-container">

      <a href="/" class="branding">

        <img src="/panoromics-logo.png" alt="PanorOmics Logo" />

        <div class="branding-text">
          <span class="brand-title">PanorOmics</span>
          <span class="brand-sub">
            THE PANORAMIC OMICS SCIENCES CENTER
          </span>
        </div>

      </a>

      <nav class="main-nav">

        {navLinks.map(link => (
          <a href={link.href} class="nav-link">
            {link.name}
          </a>
        ))}

      </nav>

    </div>

  </header>

  <!-- HERO -->

  <section class="hero">

    <div class="hero-container">

      <div class="hero-text">

        <h1>
          Unifying <span class="blue">omics.</span><br />
          Advancing <span class="blue">health.</span><br />
          Transforming <span class="blue">lives.</span>
        </h1>

        <p>
          PanorOmics integrates genomics, transcriptomics,
          proteomics, metabolomics, AI, and systems biology
          into one unified scientific ecosystem for discovery,
          precision medicine, and biotechnology innovation.
        </p>

        <a href="/research" class="hero-btn">
          Explore Our Research →
        </a>

      </div>

      <div class="hero-image">
        <img src="/main-landing.png" alt="PanorOmics Main Landing" />
      </div>

    </div>

  </section>

  <!-- PILLARS -->

  <section class="pillars-section">

    <div class="pillars-label">
      THE SIX PILLARS OF OMICS SCIENCE
    </div>

    <h2 class="pillars-title">
      Integrated Omics Disciplines
    </h2>

    <div class="pillars-grid">

      {omicsPillars.map(pillar => (

        <div
          class="pillar-card"
          style={`border-color: ${pillar.border}`}
        >

          <h3>{pillar.name}</h3>

          <p>{pillar.text}</p>

        </div>

      ))}

    </div>

  </section>

  <!-- DOGMA -->

  <section class="dogma-section">

    <h2>
      The Central Dogma of Omics Science
    </h2>

    <p>
      From information to function. From biology to impact.
    </p>

    <div class="dogma-image">

      <img
        src="/central-dogma.png"
        alt="Central Dogma"
      />

    </div>

  </section>

</body>
</html>
