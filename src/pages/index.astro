---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>PanorOmics | The Panoramic Omics Sciences Center</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: #010816;
      color: #ffffff;
      font-family: Arial, Helvetica, sans-serif;
      overflow-x: hidden;
    }

    .site-header {
      width: 100%;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .header-container {
      max-width: 1480px;
      margin: 0 auto;
      padding: 1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
    }

    .brand img {
      width: 64px;
      height: 64px;
      object-fit: contain;
      border-radius: 10px;
    }

    .brand-title {
      color: #020817;
      font-size: 2rem;
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .brand-subtitle {
      color: #64748b;
      font-size: 0.76rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-top: 0.35rem;
      font-weight: 600;
    }

    .main-nav {
      display: flex;
      align-items: center;
      gap: 1.35rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .main-nav a {
      color: #1e293b;
      text-decoration: none;
      font-size: 0.96rem;
      font-weight: 700;
      transition: color 0.2s ease;
    }

    .main-nav a:hover {
      color: #2563eb;
    }

    .hero {
      min-height: calc(100vh - 96px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 4.5rem 2.5rem 5rem;
      background:
        radial-gradient(circle at 78% 42%, rgba(37, 99, 235, 0.22), transparent 34%),
        radial-gradient(circle at 18% 55%, rgba(30, 64, 175, 0.15), transparent 34%),
        linear-gradient(180deg, #010816 0%, #020b1d 100%);
    }

    .hero-container {
      max-width: 1480px;
      width: 100%;
      display: grid;
      grid-template-columns: 0.92fr 1.08fr;
      gap: 5rem;
      align-items: center;
    }

    .hero-kicker {
      color: #60a5fa;
      font-size: 0.86rem;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 1.4rem;
    }

    .hero h1 {
      font-size: clamp(4rem, 6.4vw, 7rem);
      line-height: 0.94;
      font-weight: 950;
      letter-spacing: -0.065em;
      margin-bottom: 2rem;
    }

    .blue {
      color: #3b82f6;
    }

    .hero p {
      max-width: 680px;
      color: #cbd5e1;
      font-size: 1.25rem;
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-primary,
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0 1.7rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 800;
      transition: all 0.25s ease;
    }

    .btn-primary {
      background: #2563eb;
      color: #ffffff;
      box-shadow: 0 18px 40px rgba(37, 99, 235, 0.28);
    }

    .btn-primary:hover {
      background: #3b82f6;
      transform: translateY(-2px);
    }

    .btn-secondary {
      color: #dbeafe;
      border: 1px solid rgba(96, 165, 250, 0.45);
      background: rgba(37, 99, 235, 0.08);
    }

    .btn-secondary:hover {
      background: rgba(37, 99, 235, 0.18);
      transform: translateY(-2px);
    }

    .hero-visual {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-visual::before {
      content: "";
      position: absolute;
      width: 84%;
      height: 84%;
      border-radius: 999px;
      background: rgba(37, 99, 235, 0.18);
      filter: blur(70px);
      z-index: 0;
    }

    .hero-visual img {
      position: relative;
      z-index: 1;
      width: min(100%, 760px);
      border-radius: 30px;
      box-shadow:
        0 0 0 1px rgba(96, 165, 250, 0.18),
        0 35px 90px rgba(37, 99, 235, 0.28);
    }

    .dogma-section {
      padding: 5rem 2.5rem 8rem;
      background:
        radial-gradient(circle at center top, rgba(37, 99, 235, 0.13), transparent 38%),
        #010816;
    }

    .dogma-container {
      max-width: 1480px;
      margin: 0 auto;
      text-align: center;
    }

    .dogma-kicker {
      color: #64748b;
      font-size: 0.9rem;
      font-weight: 800;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      margin-bottom: 1.2rem;
    }

    .dogma-container h2 {
      font-size: clamp(2.5rem, 4.6vw, 5rem);
      line-height: 1.05;
      font-weight: 950;
      letter-spacing: -0.045em;
      margin-bottom: 1rem;
    }

    .dogma-container p {
      color: #94a3b8;
      font-size: 1.25rem;
      line-height: 1.6;
      margin-bottom: 3.5rem;
    }

    .dogma-image-wrap {
      position: relative;
      border-radius: 34px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.03);
      box-shadow:
        0 0 0 1px rgba(96, 165, 250, 0.16),
        0 35px 90px rgba(37, 99, 235, 0.18);
    }

    .dogma-image-wrap img {
      display: block;
      width: 100%;
      height: auto;
    }

    .next-section {
      border-top: 1px solid rgba(148, 163, 184, 0.14);
      padding: 5rem 2.5rem;
      background: #020b1d;
    }

    .next-container {
      max-width: 1200px;
      margin: 0 auto;
      text-align: center;
    }

    .next-container h2 {
      font-size: clamp(2rem, 4vw, 4rem);
      font-weight: 950;
      letter-spacing: -0.04em;
      margin-bottom: 1rem;
    }

    .next-container p {
      max-width: 850px;
      margin: 0 auto;
      color: #cbd5e1;
      font-size: 1.2rem;
      line-height: 1.8;
    }

    @media (max-width: 1100px) {
      .header-container {
        flex-direction: column;
      }

      .main-nav {
        justify-content: center;
      }

      .hero-container {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .hero-copy {
        text-align: center;
      }

      .hero p {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-actions {
        justify-content: center;
      }
    }

    @media (max-width: 720px) {
      .header-container {
        padding: 1rem;
      }

      .brand {
        align-items: center;
      }

      .brand img {
        width: 54px;
        height: 54px;
      }

      .brand-title {
        font-size: 1.55rem;
      }

      .brand-subtitle {
        font-size: 0.58rem;
        letter-spacing: 0.14em;
      }

      .main-nav {
        gap: 0.8rem;
      }

      .main-nav a {
        font-size: 0.82rem;
      }

      .hero {
        padding: 3.5rem 1.25rem;
      }

      .hero h1 {
        font-size: 3.5rem;
      }

      .hero p {
        font-size: 1.05rem;
      }

      .dogma-section {
        padding: 3.5rem 1.25rem 5rem;
      }

      .dogma-container p {
        font-size: 1.05rem;
      }

      .next-section {
        padding: 4rem 1.25rem;
      }
    }
  </style>
</head>

<body>

  <header class="site-header">
    <div class="header-container">

      <a href="/" class="brand">
        <img src="/panoromics-logo.png" alt="PanorOmics Logo" />
        <div>
          <div class="brand-title">PanorOmics</div>
          <div class="brand-subtitle">The Panoramic Omics Sciences Center</div>
        </div>
      </a>

      <nav class="main-nav">
        {navLinks.map((link) => (
          <a href={link.href}>{link.name}</a>
        ))}
      </nav>

    </div>
  </header>

  <main>

    <section class="hero">
      <div class="hero-container">

        <div class="hero-copy">
          <div class="hero-kicker">Integrating life sciences • data • discovery</div>

          <h1>
            Unifying <span class="blue">omics.</span><br />
            Advancing <span class="blue">health.</span><br />
            Transforming <span class="blue">lives.</span>
          </h1>

          <p>
            PanorOmics integrates multi-omics data, advanced analytics,
            artificial intelligence, and systems biology to accelerate discovery,
            enable precision medicine, and improve human health.
          </p>

          <div class="hero-actions">
            <a href="/research" class="btn-primary">Explore Research →</a>
            <a href="/education" class="btn-secondary">View Education Programs</a>
          </div>
        </div>

        <div class="hero-visual">
          <img src="/main-landing.png" alt="PanorOmics landing page visualization" />
        </div>

      </div>
    </section>

    <section class="dogma-section">
      <div class="dogma-container">

        <div class="dogma-kicker">Signature Scientific Framework</div>

        <h2>The Central Dogma of Omics Science</h2>

        <p>
          From information to function. From biology to impact.
        </p>

        <div class="dogma-image-wrap">
          <img src="/central-dogma.png" alt="The Central Dogma of Omics Science" />
        </div>

      </div>
    </section>

    <section class="next-section">
      <div class="next-container">
        <h2>Building the Future of Omics Science</h2>
        <p>
          PanorOmics connects research, education, data platforms, and translational biotechnology into one integrated ecosystem for discovery and innovation.
        </p>
      </div>
    </section>

  </main>

</body>
</html>
