---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>PanorOmics | The Panoramic Omics Sciences Center</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: #010816;
      color: white;
      font-family: Arial, Helvetica, sans-serif;
      overflow-x: hidden;
    }

    /* HEADER */

    .site-header {
      width: 100%;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .header-container {
      max-width: 1480px;
      margin: 0 auto;
      padding: 1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
    }

    .brand img {
      width: 64px;
      height: 64px;
      object-fit: contain;
      border-radius: 10px;
    }

    .brand-title {
      color: #020817;
      font-size: 2rem;
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .brand-subtitle {
      color: #64748b;
      font-size: 0.76rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-top: 0.35rem;
      font-weight: 600;
    }

    .main-nav {
      display: flex;
      align-items: center;
      gap: 1.35rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .main-nav a {
      color: #1e293b;
      text-decoration: none;
      font-size: 0.96rem;
      font-weight: 700;
      transition: color 0.2s ease;
    }

    .main-nav a:hover {
      color: #2563eb;
    }

    /* HERO — FULL LANDING PAGE IMAGE */

    .hero {
      min-height: calc(100vh - 96px);
      padding: 2.5rem 2rem 4rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at center, rgba(37, 99, 235, 0.18), transparent 42%),
        linear-gradient(180deg, #010816 0%, #020b1d 100%);
    }

    .hero-container {
      width: 100%;
      max-width: 1540px;
      margin: 0 auto;
    }

    .hero-image-wrap {
      width: 100%;
      border-radius: 34px;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(96, 165, 250, 0.18),
        0 40px 100px rgba(37, 99, 235, 0.28);
      background: rgba(255, 255, 255, 0.03);
    }

    .hero-image-wrap img {
      width: 100%;
      display: block;
      height: auto;
    }

    /* CENTRAL DOGMA */

    .dogma-section {
      padding: 5rem 2rem 8rem;
      background:
        radial-gradient(circle at center top, rgba(37, 99, 235, 0.13), transparent 38%),
        #010816;
    }

    .dogma-container {
      max-width: 1480px;
      margin: 0 auto;
      text-align: center;
    }

    .dogma-kicker {
      color: #64748b;
      font-size: 0.9rem;
      font-weight: 800;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      margin-bottom: 1.2rem;
    }

    .dogma-container h1 {
      font-size: clamp(2.8rem, 5vw, 5.2rem);
      line-height: 1.05;
      font-weight: 950;
      letter-spacing: -0.045em;
      margin-bottom: 1rem;
    }

    .dogma-container p {
      color: #94a3b8;
      font-size: 1.25rem;
      line-height: 1.6;
      margin-bottom: 3.5rem;
    }

    .dogma-image-wrap {
      border-radius: 34px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.03);
      box-shadow:
        0 0 0 1px rgba(96, 165, 250, 0.16),
        0 35px 90px rgba(37, 99, 235, 0.18);
    }

    .dogma-image-wrap img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* FOOTER */

    .footer {
      border-top: 1px solid rgba(148, 163, 184, 0.14);
      padding: 3rem 2rem;
      background: #020b1d;
      text-align: center;
      color: #94a3b8;
    }

    .footer strong {
      color: white;
    }

    /* RESPONSIVE */

    @media (max-width: 1100px) {
      .header-container {
        flex-direction: column;
      }

      .main-nav {
        justify-content: center;
      }

      .hero {
        padding: 2rem 1.25rem 3.5rem;
      }
    }

    @media (max-width: 720px) {
      .header-container {
        padding: 1rem;
      }

      .brand img {
        width: 54px;
        height: 54px;
      }

      .brand-title {
        font-size: 1.55rem;
      }

      .brand-subtitle {
        font-size: 0.58rem;
        letter-spacing: 0.14em;
      }

      .main-nav {
        gap: 0.8rem;
      }

      .main-nav a {
        font-size: 0.82rem;
      }

      .hero-image-wrap,
      .dogma-image-wrap {
        border-radius: 18px;
      }

      .dogma-section {
        padding: 3.5rem 1.25rem 5rem;
      }

      .dogma-container p {
        font-size: 1.05rem;
      }
    }
  </style>
</head>

<body>

  <header class="site-header">
    <div class="header-container">

      <a href="/" class="brand">
        <img src="/panoromics-logo.png" alt="PanorOmics Logo" />

        <div>
          <div class="brand-title">PanorOmics</div>
          <div class="brand-subtitle">The Panoramic Omics Sciences Center</div>
        </div>
      </a>

      <nav class="main-nav">
        {navLinks.map((link) => (
          <a href={link.href}>{link.name}</a>
        ))}
      </nav>

    </div>
  </header>

  <main>

    <!-- FULL LANDING PAGE HERO IMAGE -->
    <section class="hero">
      <div class="hero-container">
        <div class="hero-image-wrap">
          <img src="/main-landing.png" alt="PanorOmics landing page" />
        </div>
      </div>
    </section>

    <!-- CENTRAL DOGMA LANDMARK -->
    <section class="dogma-section">
      <div class="dogma-container">

        <div class="dogma-kicker">Signature Scientific Framework</div>

        <h1>The Central Dogma of Omics Science</h1>

        <p>From information to function. From biology to impact.</p>

        <div class="dogma-image-wrap">
          <img src="/central-dogma.png" alt="The Central Dogma of Omics Science" />
        </div>

      </div>
    </section>

    <footer class="footer">
      <p>
        <strong>PanorOmics</strong> — integrating life sciences • data • discovery
      </p>
    </footer>

  </main>

</body>
</html>
