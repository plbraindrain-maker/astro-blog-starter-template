---
const coreAreas = [
  ['Environmental Microbiome Profiling', 'Studying microbial communities across soil, water, air, built environments, and ecological systems.'],
  ['Microbial Ecology', 'Analyzing how microbes interact with each other, their hosts, nutrients, pollutants, and environmental conditions.'],
  ['Biogeochemical Cycling', 'Investigating microbial roles in carbon, nitrogen, sulfur, phosphorus, and nutrient cycling across ecosystems.'],
  ['Environmental Health and Surveillance', 'Using microbiome data to monitor contamination, ecosystem disruption, antimicrobial resistance, and environmental risk.'],
];

const technologies = [
  ['16S rRNA Sequencing', 'Amplicon sequencing used to profile bacterial and archaeal community composition across environmental samples.'],
  ['Shotgun Metagenomics', 'Whole-community DNA sequencing used to characterize microbial diversity, functional genes, pathways, and ecological potential.'],
  ['Metatranscriptomics', 'RNA-based profiling used to study active microbial gene expression and functional responses in environmental systems.'],
  ['Environmental DNA Analysis', 'eDNA methods used to detect organisms and microbial signatures from environmental samples such as soil, water, and sediment.'],
  ['AI-Assisted Environmental Microbiomics', 'Computational approaches that support microbial classification, ecosystem pattern discovery, risk prediction, and functional interpretation.'],
];

const modalities = [
  ['Soil Microbiomics', 'Studies microbial communities involved in nutrient cycling, plant health, agriculture, and ecosystem stability.'],
  ['Water Microbiomics', 'Profiles microbial communities in freshwater, marine, wastewater, and drinking water environments.'],
  ['Built Environment Microbiomics', 'Analyzes microbial communities in homes, hospitals, laboratories, schools, transportation systems, and urban spaces.'],
  ['Pollution and Exposure Microbiomics', 'Studies how pollutants, chemicals, climate stressors, and environmental exposures alter microbial communities.'],
  ['Antimicrobial Resistance Surveillance', 'Uses microbiome and metagenomic data to monitor resistance genes across environmental reservoirs.'],
  ['Ecosystem Microbiome Monitoring', 'Tracks microbial community changes over time to assess environmental health, biodiversity, and ecological disturbance.'],
];

const timeline = [
  [
    '1970s–1990s',
    'Environmental Microbial Ecology',
    'Environmental microbiology established microbes as essential drivers of ecosystem function, nutrient cycling, and environmental health.'
  ],
  [
    '1990s–2000s',
    'Molecular Microbial Ecology',
    'DNA-based methods expanded environmental microbiology beyond culture-based analysis toward community-level microbial profiling.'
  ],
  [
    '2005–Present',
    'Environmental Metagenomics',
    'Shotgun metagenomics enabled direct study of microbial communities, functional genes, and ecological pathways from environmental samples.'
  ],
  [
    '2010s–Present',
    'Environmental DNA and Ecosystem Monitoring',
    'eDNA approaches expanded microbial and biodiversity surveillance across water, soil, sediment, and ecological systems.'
  ],
  [
    '2015–Present',
    'Microbiomes and Climate Systems',
    'Environmental microbiomics increasingly connects microbial communities with climate change, carbon cycling, pollution, and ecosystem resilience.'
  ],
  [
    '2018–Present',
    'Metagenomic Surveillance',
    'Environmental microbiome data increasingly supports monitoring of pathogens, antimicrobial resistance, contamination, and public health risk.'
  ],
  [
    'Present',
    'AI-Assisted Environmental Microbiome Interpretation',
    'AI increasingly supports microbial classification, ecological pattern discovery, functional prediction, environmental surveillance, and ecosystem modeling.'
  ],
];

const publications = [
  ['Metagenomics: Genomic Analysis of Microbial Communities', 'Environmental metagenomics studies', 'Nature Reviews Microbiology / Science'],
  ['The Earth Microbiome Project', 'Earth Microbiome Project Consortium', 'Nature • 2017'],
  ['Environmental DNA for Biodiversity Monitoring', 'eDNA studies', 'Nature Ecology & Evolution / Molecular Ecology'],
  ['Microbial Ecology and Biogeochemical Cycling', 'Environmental microbiology studies', 'Nature Reviews Microbiology / ISME Journal'],
  ['Metagenomic Surveillance of Antimicrobial Resistance', 'Environmental AMR studies', 'Nature Microbiology / The Lancet Microbe'],
  ['AI and Environmental Microbiome Analysis', 'Computational microbiomics studies', 'Nature Methods / Microbiome'],
];

const related = [
  ['Human Health', '/research/microbiomics/human-health'],
  ['Precision Medicine', '/research/microbiomics/precision-medicine'],
  ['Infectious Diseases', '/research/microbiomics/infectious-diseases'],
];
