---
// Completely self-contained page. No imports to break.
const navLinks = [
	{ name: 'Home', href: '/' },
	{ name: 'About', href: '/about' },
	{ name: 'Research', href: '/research' },
	{ name: 'Education', href: '/education' },
	{ name: 'Platforms', href: '/platforms' },
	{ name: 'Data', href: '/data' },
	{ name: 'Publications', href: '/publications' },
	{ name: 'News', href: '/news' },
	{ name: 'Contact', href: '/contact' },
];

const omicsPillars = [
	{ id: 'genomics', name: 'GENOMICS', border: '#1e3a8a', text: 'The complete set of DNA, including genes, variants, and genetic architecture.' },
	{ id: 'transcriptomics', name: 'TRANSCRIPTOMICS', border: '#166534', text: 'Examine RNA molecules to understand gene expression and cellular function.' },
	{ id: 'proteomics', name: 'PROTEOMICS', border: '#5b21b6', text: 'Analyze the full complement of proteins to uncover function, interactions, and pathways.' },
	{ id: 'metabolomics', name: 'METABOLOMICS', border: '#991b1b', text: 'Profile small-molecule metabolites to reveal biochemical activity and metabolic states.' },
	{ id: 'lipidomics', name: 'LIPIDOMICS', border: '#854d0e', text: 'Investigate lipids and lipid species to understand membrane biology and signaling.' },
	{ id: 'epigenomics', name: 'EPIGENOMICS', border: '#3730a3', text: 'Explore epigenetic modifications that regulate gene activity without changing DNA.' },
];

const missionRibbon = [
	{ title: 'KNOWLEDGE', text: 'Generate and integrate biological knowledge across omics layers.', icon: '🧠' },
	{ title: 'INSIGHT', text: 'Uncover mechanisms, biomarkers, and targets with greater precision.', icon: '👁️' },
	{ title: 'ACTION', text: 'Translate insights into strategies and innovative solutions.', icon: '🎯' },
	{ title: 'BIOTECH', text: 'Drive biotechnology innovation and therapeutic development.', icon: '🧬' },
	{ title: 'CURE', text: 'Accelerate the discovery of cures and improve treatment outcomes.', icon: '❤️' },
	{ title: 'BETTER LIFE', text: 'Improve human health and quality of life for generations to come.', icon: '🌐' }
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PanorOmics</title>
  <style>
    /* Global Resets */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    html, body {
      background-color: #010610;
      color: #ffffff;
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      width: 100%;
      overflow-x: hidden;
    }
    /* Top Header */
    .site-header {
      width: 100%;
      background-color: #ffffff;
      padding: 0.75rem 2rem;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-container {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .branding-text {
      display: flex;
      flex-direction: column;
    }
    .brand-title {
      font-weight: 700;
      font-size: 1.25rem;
      color: #010610;
    }
    .brand-sub {
      font-size: 0.65rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .main-nav {
      display: flex;
      gap: 1.5rem;
    }
    .nav-link {
      color: #333;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
    /* Portal Hero */
.portal-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 3rem 1rem 1rem 1rem;
  text-align: center;
  order: 1;
}
    .portal-title {
      font-size: 4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .portal-title span {
      color: #3b82f6;
    }
    .portal-tagline {
      font-size: 1.25rem;
      color: #94a3b8;
    }
    /* Pillars Section */
     order: 2;
    .pillars-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }
    .pillars-heading {
      text-align: center;
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      color: #64748b;
      margin-bottom: 2rem;
      text-transform: uppercase;
    }
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .pillar-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .pillar-name {
      display: block;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: 0.05em;
    }
    /* Dogma Section (Picture Last) */
    .dogma-container {
       order: 3;
      max-width: 1000px;
      margin: 0 auto;
      padding: 4rem 1rem;
      text-align: center;
    }
    .dogma-container h2 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    .dogma-subtitle {
      color: #94a3b8;
      margin-bottom: 2rem;
    }
    .dogma-graphic-wrapper {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
    }
    .dogma-graphic-wrapper img {
      width: 100%;
      height: auto;
      display: block;
    }
    .explore-overlay-btn {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      background: #3b82f6;
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 9999px;
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</head>
<body>

  <header class="site-header">
    <div class="header-container">
      <div class="branding-text">
        <span class="brand-title">PanorOmics</span>
        <span class="brand-sub">THE PANORAMIC OMICS SCIENCES CENTER</span>
      </div>
      <nav class="main-nav">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link">{link.name}</a>
        ))}
      </nav>
    </div>
  </header>

  <!-- 1. NAME AND TAGLINE AT THE TOP -->
  <main class="portal-hero">
    <div class="hero-content">
      <h1 class="portal-title">Panor<span>Omics</span></h1>
      <p class="portal-tagline">integrating life sciences • data • discovery</p>
    </div>
  </main>

  <!-- 2. SIX PILLARS GRID NEXT -->
  <section class="pillars-section">
    <p class="pillars-heading">• THE SIX PILLARS OF OMICS SCIENCE •</p>
    <div class="pillars-grid">
      {omicsPillars.map(pillar => (
        <div class="pillar-card" style={`--accent-color: ${pillar.color}`}>
          <span class="pillar-name">{pillar.name}</span>
          <p class="pillar-description">{pillar.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- 3. CENTRAL DOGMA PICTURE LAST -->
  <section class="dogma-container">
    <h2>The Central Dogma of Omics Science</h2>
    <p class="dogma-subtitle">From Information to Function. From Biology to Impact.</p>
    <div class="dogma-graphic-wrapper">
      <img src="/main-landing.png" alt="The Central Dogma Flow Diagrams" />
      <a href="/research" class="explore-overlay-btn">Explore Our Research →</a>
    </div>
  </section>

</body>
</html>

