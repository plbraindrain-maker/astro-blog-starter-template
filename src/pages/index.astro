---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const cards = [
  ['Genomics', 'Comprehensive analysis of genetic variation to uncover biology and disease risk.', '/research'],
  ['Transcriptomics', 'Profiling RNA expression to understand gene activity and regulation.', '/research'],
  ['Proteomics', 'Characterizing proteins to reveal function, pathways, and biomarkers.', '/research'],
  ['Metabolomics', 'Measuring metabolites to capture biochemical phenotypes and pathways.', '/research'],
  ['Lipidomics', 'Analyzing lipid species to illuminate membrane biology and metabolism.', '/research'],
  ['Epigenomics', 'Studying epigenetic modifications that shape gene regulation.', '/research'],
];
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>PanorOmics | The Panoramic Omics Sciences Center</title>

<link rel="icon" type="image/png" href="/icon-mark.png" />
<link rel="apple-touch-icon" href="/icon-mark.png" />

<meta name="theme-color" content="#020817" />

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
  overflow-x:hidden;
}

/* =========================================
   HEADER
========================================= */

.header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  z-index:1000;

  background:rgba(2,8,23,.78);

  backdrop-filter:blur(18px);

  border-bottom:1px solid rgba(59,130,246,.10);
}

.header-inner{
  max-width:1450px;
  margin:0 auto;

  padding:14px 34px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.brand{
  display:flex;
  align-items:center;
  gap:14px;

  text-decoration:none;
}

.brand img{
  width:52px;
  height:52px;
  object-fit:contain;
}

.brand-title{
  font-size:1.7rem;
  font-weight:800;
  line-height:1;
  color:white;
  letter-spacing:-0.04em;
}

.brand-title span{
  color:#3b82f6;
}

.brand-sub{
  color:#94a3b8;
  font-size:.64rem;
  margin-top:2px;
  letter-spacing:.14em;
}

.nav{
  display:flex;
  gap:24px;
}

.nav a{
  color:#dbe4ff;
  text-decoration:none;
  font-size:.88rem;
  transition:.3s ease;
}

.nav a:hover{
  color:#3b82f6;
}

/* =========================================
   HERO
========================================= */

.hero{

  display:flex;

  align-items:center;

  justify-content:space-between;

  gap:42px;

  padding:110px 7% 55px;

  min-height:82vh;

  overflow:hidden;

  background:
  radial-gradient(circle at center,
  rgba(59,130,246,.16),
  transparent 42%),
  #020817;
}

.hero-left{
  flex:1;
  max-width:560px;
}

.hero-kicker{
  color:#3b82f6;
  font-size:.82rem;
  letter-spacing:.28em;
  margin-bottom:18px;
  font-weight:700;
}

.hero-title{

  font-size:clamp(3rem,5vw,5rem);

  line-height:.94;

  letter-spacing:-0.06em;

  font-weight:900;

  margin-bottom:22px;
}

.hero-title span{
  color:#3b82f6;
}

.hero-description{

  font-size:1rem;

  line-height:1.72;

  color:#cbd5e1;

  max-width:560px;

  margin-bottom:34px;
}

.hero-button{

  display:inline-flex;

  align-items:center;

  gap:10px;

  padding:16px 30px;

  border-radius:999px;

  background:#2563eb;

  color:white;

  text-decoration:none;

  font-weight:700;

  transition:.35s ease;
}

.hero-button:hover{

  transform:translateY(-3px);

  box-shadow:
  0 12px 40px rgba(37,99,235,.35);
}

/* =========================================
   HERO VIDEO
========================================= */

.hero-video-wrap{
  flex:1;
  display:flex;
  justify-content:center;
}

.hero-video{

  width:100%;

  max-width:760px;

  border-radius:24px;

  overflow:hidden;

  border:1px solid rgba(59,130,246,.14);

  box-shadow:
  0 0 80px rgba(37,99,235,.16);
}

.hero-video video{

  width:100%;

  display:block;

  object-fit:cover;
}

/* =========================================
   SECTION
========================================= */

.section{
  padding:52px 7%;
}

.section-title{

  font-size:clamp(2.3rem,4vw,4rem);

  line-height:1.04;

  letter-spacing:-0.05em;

  margin-bottom:18px;
}

.section-title span{
  color:#3b82f6;
}

.section-description{

  font-size:1rem;

  line-height:1.8;

  color:#cbd5e1;

  max-width:980px;
}

/* =========================================
   OMICS GRID
========================================= */

.omics-grid{

  margin-top:34px;

  display:grid;

  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));

  gap:20px;
}

.omics-card{

  background:rgba(8,15,35,.72);

  border:1px solid rgba(59,130,246,.12);

  border-radius:22px;

  padding:24px;

  text-decoration:none;

  transition:.35s ease;
}

.omics-card:hover{

  transform:translateY(-6px);

  border-color:#3b82f6;

  box-shadow:
  0 20px 60px rgba(37,99,235,.12);
}

.omics-card h3{

  font-size:1.45rem;

  margin-bottom:14px;

  color:#2563eb;
}

.omics-card p{

  color:#94a3b8;

  line-height:1.7;

  font-size:.96rem;
}

/* =========================================
   CENTRAL DOGMA
========================================= */

.central-dogma{

  margin-top:34px;

  border-radius:26px;

  overflow:hidden;

  border:1px solid rgba(59,130,246,.14);

  box-shadow:
  0 0 60px rgba(37,99,235,.12);
}

.central-dogma img{
  width:100%;
  display:block;
}

/* =========================================
   FOOTER
========================================= */

.footer{

  padding:42px 7%;

  border-top:1px solid rgba(59,130,246,.10);

  text-align:center;

  color:#94a3b8;

  font-size:.95rem;
}

/* =========================================
   MOBILE
========================================= */

@media(max-width:1100px){

  .hero{
    flex-direction:column;
    padding-top:120px;
  }

  .nav{
    display:none;
  }

  .hero-video{
    max-width:100%;
  }
}

@media(max-width:768px){

  .header-inner{
    padding:16px 20px;
  }

  .hero{
    padding:120px 20px 60px;
  }

  .section{
    padding:46px 20px;
  }

  .hero-title{
    font-size:3rem;
  }

  .section-title{
    font-size:2.4rem;
  }

  .hero-description,
  .section-description{
    font-size:.96rem;
  }

  .brand-title{
    font-size:1.45rem;
  }

  .hero-button{
    width:100%;
    justify-content:center;
  }
}

</style>

</head>

<body>

<!-- =========================================
     HEADER
========================================= -->

<header class="header">

  <div class="header-inner">

    <a class="brand" href="/">

      <img src="/panoromics-logo.png" alt="PanorOmics Logo">

      <div>

        <div class="brand-title">
          Panor<span>Omics</span>
        </div>

        <div class="brand-sub">
          INTEGRATING LIFE SCIENCES • DATA • DISCOVERY
        </div>

      </div>

    </a>

    <nav class="nav">

      {navLinks.map((link) => (
        <a href={link.href}>{link.name}</a>
      ))}

    </nav>

  </div>

</header>

<!-- =========================================
     HERO
========================================= -->

<section class="hero">

  <div class="hero-left">

    <div class="hero-kicker">
      PANOROMICS OMICS SCIENCES
    </div>

    <h1 class="hero-title">
      Unifying <span>omics.</span><br>
      Advancing <span>health.</span><br>
      Transforming <span>lives.</span>
    </h1>

    <p class="hero-description">
      PanorOmics integrates multi-omics sciences,
      computational biology, artificial intelligence,
      and translational biotechnology into a unified
      systems-level framework for discovery,
      precision medicine, and human health.
    </p>

    <a href="#research" class="hero-button">
      Explore Our Research →
    </a>

  </div>

  <div class="hero-video-wrap">

    <div class="hero-video">

      <video
        autoplay
        muted
        loop
        playsinline
      >

        <source
          src="/architecture-of-life.mp4"
          type="video/mp4"
        >

      </video>

    </div>

  </div>

</section>

<!-- =========================================
     ABOUT
========================================= -->

<section class="section">

  <h2 class="section-title">
    A Discipline, <span>Not a Toolbox</span>
  </h2>

  <p class="section-description">
    Omics Sciences is an emerging integrative discipline
    that unifies molecular biology, computational systems,
    artificial intelligence, biotechnology, and human health
    into a systems-level understanding of life.
  </p>

</section>
<!-- =========================================
     RESEARCH CARDS
========================================= -->

<section class="section" id="research">

  <h2 class="section-title">
    The Architecture <span>of Life</span>
  </h2>

  <p class="section-description">
    PanorOmics explores interconnected biological layers
    across genome, epigenome, transcriptome, proteome,
    metabolome, and phenotype to advance translational
    discovery and precision biotechnology.
  </p>

  <div class="omics-grid">

    {cards.map(([title, desc, href]) => (

      <a href={href} class="omics-card">

        <h3>{title}</h3>

        <p>{desc}</p>

      </a>

    ))}

  </div>

</section>

<!-- =========================================
     CENTRAL DOGMA
========================================= -->

<section class="section">

  <h2 class="section-title">
    The Central Dogma <span>of Omics Science</span>
  </h2>

  <p class="section-description">
    From biological information to molecular function.
    From systems biology to clinical impact.
  </p>

  <div class="central-dogma">

    <img
      src="/central-dogma.png"
      alt="Central Dogma of Omics Science"
    >

  </div>

</section>

<!-- =========================================
     FOOTER
========================================= -->

<footer class="footer">

  © 2026 PanorOmics • Integrating Life Sciences • Data • Discovery

</footer>

</body>

</html>
