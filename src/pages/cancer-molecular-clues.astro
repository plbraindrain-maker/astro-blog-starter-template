---
const omicsLayers = [
  ['Genomics', 'Mutations and inherited variation can help researchers understand why cells begin behaving abnormally.'],
  ['Transcriptomics', 'RNA patterns can show which genes are unusually active or silent during disease development.'],
  ['Proteomics', 'Protein changes can reveal altered signaling, growth pathways, immune response, and therapeutic targets.'],
  ['Metabolomics', 'Metabolite shifts can reflect changes in energy use, cellular stress, and biochemical activity.'],
  ['Lipidomics', 'Lipid patterns can connect membrane remodeling, inflammation, signaling, and tumor biology.'],
  ['Epigenomics', 'DNA methylation and chromatin changes can show how gene regulation becomes disrupted.'],
  ['Microbiomics', 'Microbial communities may influence inflammation, immune balance, metabolism, and disease environment.'],
];

const storyCards = [
  ['Before Symptoms', 'Molecular changes may begin long before disease becomes clinically visible. Omics sciences help researchers study those hidden biological signals.'],
  ['Across Many Layers', 'Cancer is not explained by one molecule alone. It often involves DNA, RNA, proteins, metabolites, lipids, epigenetic regulation, immunity, and environment.'],
  ['From Data to Meaning', 'The goal is not just to collect data, but to understand how molecular patterns connect to disease risk, progression, treatment response, and human health.'],
];
