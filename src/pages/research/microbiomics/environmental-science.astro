  font-size:1rem;
  margin-bottom:16px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:20px;
  margin-top:24px;
}

.card{
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:24px;
}

.card h3{
  color:#3b82f6;
  margin-bottom:10px;
  line-height:1.3;
}

.card p{
