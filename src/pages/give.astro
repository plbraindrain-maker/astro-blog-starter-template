<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Give | PanorOmics</title>

<style>

body{
  margin:0;
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
}

.give-hero{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:80px 8%;
}

.give-container{
  max-width:1200px;
  width:100%;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:center;
}

.give-left h1{
  font-size:4rem;
  line-height:.95;
  margin-bottom:24px;
  letter-spacing:-0.05em;
}

.give-left h1 span{
  color:#3b82f6;
}

.give-left p{
  color:#cbd5e1;
  font-size:1rem;
  line-height:1.8;
  max-width:560px;
  margin-bottom:32px;
}

.give-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:16px 28px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-weight:700;
  transition:.3s ease;
}

.give-button:hover{
  transform:translateY(-3px);
}

.give-right{
  display:flex;
  justify-content:center;
}

.give-right img{
  width:100%;
  max-width:420px;
  object-fit:contain;
}

@media(max-width:900px){

  .give-container{
    grid-template-columns:1fr;
    text-align:center;
  }

  .give-left p{
    margin:auto auto 32px;
  }

  .give-left h1{
    font-size:3rem;
  }
}

</style>

</head>

<body>

<section class="give-hero">

  <div class="give-container">

    <div class="give-left">

      <h1>
        Advance the Future of <span>Omics Sciences</span>
      </h1>

      <p>
        Support education, translational research,
        computational biology, artificial intelligence,
        and the future of precision medicine through
        next-generation omics sciences.
      </p>

      <a href="/contact" class="give-button">
        Support PanorOmics
      </a>

    </div>

    <div class="give-right">

      <img
        src="/panoromics-give-logo.png"
        alt="PanorOmics Give"
      >

    </div>

  </div>

</section>

</body>

</html>
