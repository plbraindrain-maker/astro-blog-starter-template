---
const coreAreas = [
  ['Microbiome-Based Patient Stratification', 'Using microbial community patterns to classify patients by disease risk, treatment response, immune state, and clinical phenotype.'],
  ['Personalized Microbiome Therapeutics', 'Studying how microbiome data can guide probiotics, prebiotics, dietary strategies, microbial therapies, and treatment optimization.'],
  ['Drug–Microbiome Interactions', 'Analyzing how microbial communities influence drug metabolism, therapeutic efficacy, adverse effects, and individualized treatment response.'],
  ['Microbiome Biomarker Discovery', 'Identifying microbial signatures that support diagnosis, prognosis, disease monitoring, therapeutic response prediction, and precision health research.'],
];

const technologies = [
  ['16S rRNA Sequencing', 'Amplicon sequencing used to profile microbial community composition for patient stratification and clinical microbiome research.'],
  ['Shotgun Metagenomics', 'Whole-community sequencing used to identify microbial species, genes, pathways, resistance markers, and functional potential.'],
  ['Metabolomics Integration', 'Combines microbiome profiles with metabolite data to understand host–microbe biochemical interactions and treatment response.'],
  ['Clinical Multi-omics', 'Integrates microbiome data with genomics, transcriptomics, proteomics, metabolomics, lipidomics, immune profiling, and clinical outcomes.'],
  ['AI-Assisted Precision Microbiomics', 'Computational approaches that support patient stratification, biomarker discovery, response prediction, and personalized microbiome interpretation.'],
];

const modalities = [
  ['Gut Microbiome Precision Health', 'Uses gut microbiome profiles to study metabolic health, inflammation, nutrition, immune function, and disease risk.'],
  ['Microbiome-Based Risk Prediction', 'Identifies microbial signatures associated with disease susceptibility, progression, recurrence, or treatment outcome.'],
  ['Therapeutic Response Modeling', 'Studies how microbiome features influence response to drugs, immunotherapy, antibiotics, diet, and microbial interventions.'],
  ['Nutrition and Microbiome Personalization', 'Connects diet, microbial metabolism, host response, and individualized nutritional strategies.'],
  ['Pharmacomicrobiomics', 'Examines how microbial communities modify drugs, influence pharmacology, and contribute to variable treatment response.'],
  ['Multi-omics Precision Medicine', 'Combines microbiome data with molecular and clinical data to support individualized health and disease interpretation.'],
];

const timeline = [
  [
    '2007–2012',
    'Human Microbiome Project',
    'Large-scale human microbiome mapping established reference frameworks for linking microbial communities with health and disease.'
  ],
  [
    '2010s–Present',
    'Microbiome and Disease Stratification',
    'Microbiome studies increasingly identified microbial signatures associated with disease risk, disease subtypes, and clinical outcomes.'
  ],
  [
    '2012–Present',
    'Microbiome Therapeutics',
    'Microbial interventions, including fecal microbiota transplantation and defined microbial therapies, expanded interest in microbiome-guided treatment.'
  ],
  [
    '2015–Present',
    'Pharmacomicrobiomics',
    'Research increasingly showed that microbial communities can influence drug metabolism, therapeutic response, toxicity, and treatment variability.'
  ],
  [
    '2016–Present',
    'Microbiome and Immunotherapy Response',
    'Studies connected gut microbiome composition with cancer immunotherapy response, immune regulation, and treatment outcomes.'
  ],
  [
    '2018–Present',
    'Multi-omics Precision Microbiomics',
    'Integrated omics approaches connect microbiome profiles with host genomics, immune activity, metabolites, proteins, lipids, and clinical phenotypes.'
  ],
  [
    'Present',
    'AI-Assisted Precision Microbiome Interpretation',
    'AI increasingly supports microbiome biomarker discovery, patient stratification, therapeutic response prediction, and personalized health modeling.'
  ],
];

const publications = [
  ['Structure, Function and Diversity of the Healthy Human Microbiome', 'Human Microbiome Project Consortium', 'Nature • 2012'],
  ['A Framework for Human Microbiome Research', 'Human Microbiome Project Consortium', 'Nature • 2012'],
  ['The Microbiome and Precision Medicine', 'Precision microbiome studies', 'Nature Medicine / Cell Host & Microbe'],
  ['Gut Microbiome and Cancer Immunotherapy Response', 'Immunotherapy microbiome studies', 'Science / Nature / Cell'],
  ['Pharmacomicrobiomics and Drug Response', 'Drug–microbiome interaction studies', 'Nature Reviews / Cell'],
  ['AI and Precision Microbiome Analysis', 'Computational microbiome studies', 'Nature Methods / Microbiome'],
];

const related = [
  ['Environmental Science', '/research/microbiomics/environmental-science'],
  ['Human Health', '/research/microbiomics/human-health'],
  ['Infectious Diseases', '/research/microbiomics/infectious-diseases'],
];
