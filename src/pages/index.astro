---
const tracks = [
  {
    title: "Omics Sciences",
    desc: "Integrated systems-level biology across multi-omics sciences.",
    href: "/courses"
  },
  {
    title: "AI Omics Academy",
    desc: "AI biology, bioinformatics, and computational omics.",
    href: "/ai-academy"
  },
  {
    title: "Scientific Writing",
    desc: "Scientific communication, editing, and publication support.",
    href: "/writing"
  },
  {
    title: "Workshops",
    desc: "Short courses, bootcamps, and continuing education.",
    href: "/workshops"
  }
];
---

<html lang="en">
<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>PanEd | Omics Education Platform</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:#020817;
  color:white;
  font-family:Inter,sans-serif;
}

.hero{
  min-height:80vh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:40px 20px;
}

.hero h1{
  font-size:clamp(3rem,7vw,5rem);
  font-weight:900;
  letter-spacing:-0.05em;
  margin-bottom:20px;
}

.hero h1 span{
  color:#3b82f6;
}

.hero p{
  max-width:760px;
  font-size:1.1rem;
  line-height:1.7;
  color:#cbd5e1;
  margin-bottom:32px;
}

.hero-buttons{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
  justify-content:center;
}

.hero-buttons a{
  padding:14px 26px;
  border-radius:999px;
  text-decoration:none;
  font-weight:700;
  transition:.3s ease;
}

.primary{
  background:#2563eb;
  color:white;
}

.secondary{
  border:1px solid rgba(255,255,255,.12);
  color:white;
}

.section{
  padding:80px 8%;
}

.section-title{
  font-size:2.4rem;
  margin-bottom:16px;
}

.section-description{
  max-width:800px;
  color:#94a3b8;
  line-height:1.7;
  margin-bottom:40px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

.card{
  background:rgba(15,23,42,.7);
  border:1px solid rgba(59,130,246,.12);
  border-radius:22px;
  padding:24px;
  text-decoration:none;
  transition:.3s ease;
}

.card:hover{
  transform:translateY(-6px);
  border-color:#3b82f6;
}

.card h3{
  color:#3b82f6;
  margin-bottom:12px;
  font-size:1.2rem;
}

.card p{
  color:#94a3b8;
  line-height:1.6;
}

.footer{
  padding:40px 20px;
  text-align:center;
  border-top:1px solid rgba(255,255,255,.06);
  color:#64748b;
}

</style>

</head>

<body>

<section class="hero">

  <h1>
    Pan<span>Ed</span>
  </h1>

  <p>
    Modern Omics Education for the AI Biology Era.
    Systems-level education in genomics, epigenomics,
    AI biology, scientific writing, and translational omics sciences.
  </p>

  <div class="hero-buttons">

    <a href="/courses" class="primary">
      Explore Courses
    </a>

    <a href="/about" class="secondary">
      Learn About PanEd
    </a>

  </div>

</section>

<section class="section">

  <h2 class="section-title">
    Learning Tracks
  </h2>

  <p class="section-description">
    Explore modern educational pathways across omics sciences,
    AI biology, scientific communication, and systems-level biotechnology.
  </p>

  <div class="grid">

    {tracks.map((track) => (

      <a href={track.href} class="card">

        <h3>{track.title}</h3>

        <p>{track.desc}</p>

      </a>

    ))}

  </div>

</section>

<footer class="footer">

  PanEd by PanorOmics

</footer>

</body>
</html>
