  font-size:.9rem;
  font-weight:700;
}

.hero{
  margin-top:34px;
}

.hero h1{
  font-size:clamp(2.7rem,5vw,4.8rem);
  line-height:.95;
  letter-spacing:-.055em;
  margin-bottom:18px;
}

.hero h1 span{
  color:#3b82f6;
}

.hero p{
  color:#cbd5e1;
  font-size:1rem;
  line-height:1.8;
  max-width:900px;
}

.hero-image{
  margin-top:36px;
  width:100vw;
  margin-left:calc(50% - 50vw);
}

.hero-image img{
  width:100%;
  display:block;
  border-radius:24px;
  border:1px solid rgba(59,130,246,.14);
}

.section{
  margin-top:64px;
}

.section h2{
  font-size:2rem;
  margin-bottom:16px;
}

.section h2 span{
  color:#3b82f6;
}

.section p{
  color:#cbd5e1;
  line-height:1.9;
  font-size:1rem;
  margin-bottom:16px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:20px;
  margin-top:24px;
}

.card{
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:24px;
}

.card h3{
  color:#3b82f6;
  margin-bottom:10px;
  line-height:1.3;
}

.card p{
  margin:0;
  font-size:.92rem;
  color:#cbd5e1;
}

.timeline{
  display:grid;
  gap:16px;
  margin-top:24px;
}

.timeline-item{
  display:grid;
  grid-template-columns:120px 1fr;
  gap:18px;
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:20px;
}

.year{
  color:#3b82f6;
  font-weight:900;
  font-size:1.15rem;
}

.paper{
  background:rgba(8,15,35,.75);
  border:1px solid rgba(59,130,246,.12);
  border-radius:18px;
  padding:22px;
}

.paper h3{
  color:#3b82f6;
  margin-bottom:8px;
}

.meta{
  color:#94a3b8;
  font-size:.86rem;
  line-height:1.5;
}

.button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin-top:24px;
  padding:12px 24px;
  border-radius:999px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  font-weight:700;
}

.secondary-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin-top:12px;
  padding:14px 30px;
  border-radius:999px;
  background:#8C1515;
  color:#ffffff;
  border:1px solid #A77A7A;
  text-decoration:none;
  font-weight:700;
  transition:.25s ease;
}

.secondary-button:hover{
  background:#6F1111;
  border-color:#8C1515;
  transform:translateY(-2px);
}

@media(max-width:768px){
  .container{
    padding:70px 20px 55px;
  }

  .timeline-item{
    grid-template-columns:1fr;
  }
}
</style>
</head>

