  background:rgba(59,130,246,.08);
  border:1px solid rgba(59,130,246,.18);
  color:white;
  font-weight:700;
}

.section{
  margin-top:42px;
  padding-top:32px;
  border-top:1px solid rgba(59,130,246,.10);
}

.section h2{
  font-size:1.65rem;
  margin-bottom:14px;
}

.section p{
  color:#cbd5e1;
  line-height:1.85;
}

.principles{
  display:grid;
  gap:18px;
  margin-top:24px;
