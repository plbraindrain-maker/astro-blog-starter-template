{timeline.map(([year, title, text]) => (

  <div class="timeline-item">
    <div class="year">{year}</div>
    <div>
      <h3>{title}</h3>
      <p>{text}</p>
    </div>
  </div>

))}

</div>

</section>

<section class="section">

<h2>
Featured <span>Publications</span>
</h2>

