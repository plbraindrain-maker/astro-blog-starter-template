---
const coreAreas = [
  [
    'Cancer Genomics',
    'Using tumor genomic profiling to guide diagnosis, prognosis, targeted therapy selection, and precision oncology decision-making.',
  ],
  [
    'Rare & Inherited Diseases',
    'Identifying pathogenic variants to improve diagnosis, family counseling, disease classification, and individualized patient management.',
  ],
  [
    'Pharmacogenomics',
    'Understanding how genetic variation influences drug metabolism, efficacy, toxicity, and precision prescribing.',
  ],
  [
    'Clinical Decision Support',
    'Integrating genomic findings into routine healthcare through interpretation frameworks, evidence-based guidelines, and AI-assisted clinical workflows.',
  ],
];

const workflow = [
  ['Patient', 'A patient presents with clinical symptoms, cancer, inherited disease risk, or a need for precision treatment guidance.'],
  ['Clinical Assessment', 'Clinicians evaluate history, symptoms, pathology, family background, and diagnostic context.'],
  ['DNA Sequencing', 'Genomic testing is performed through clinical sequencing, targeted panels, exomes, or whole genomes.'],
  ['Variant Discovery', 'Relevant inherited or somatic variants are detected and prioritized from sequencing data.'],
  ['Clinical Interpretation', 'Variants are linked to genes, disease mechanisms, evidence levels, therapeutic implications, and reporting standards.'],
  ['Treatment Selection', 'Genomic results inform diagnosis, targeted therapy, surveillance, risk assessment, and patient-specific care plans.'],
  ['Patient Follow-up', 'Longitudinal monitoring tracks response, progression, resistance, and future precision care decisions.'],
];

const technologies = [
  ['Clinical NGS', 'Clinical next-generation sequencing platforms support inherited disease testing, oncology panels, and precision diagnostics.'],
  ['Liquid Biopsy', 'Blood-based genomic testing enables noninvasive detection of tumor-derived DNA, monitoring, and resistance tracking.'],
  ['Companion Diagnostics', 'Molecular assays connect specific genomic biomarkers to therapeutic eligibility and treatment selection.'],
  ['Polygenic Risk Scores', 'Aggregated genetic risk models support disease risk stratification and preventive precision medicine.'],
  ['Digital Pathology', 'Computational pathology and molecular pathology integration enhance precision diagnosis and tumor classification.'],
  ['AI Clinical Decision Support', 'AI-assisted systems help interpret genomic findings, prioritize evidence, and support clinical recommendations.'],
];

const clinicalApplications = [
  ['Oncology', 'Precision genomics guides molecular classification, targeted therapies, resistance analysis, and immunotherapy biomarkers.'],
  ['Rare Disease', 'Genome-informed diagnosis improves disease discovery, family counseling, and clinical management.'],
  ['Cardiovascular Medicine', 'Genomic risk, inherited cardiomyopathies, arrhythmia syndromes, and precision prevention strategies are increasingly integrated into care.'],
  ['Neurological Disorders', 'Genetic testing supports diagnosis and subtype classification of neurodevelopmental and neurodegenerative disease.'],
  ['Prenatal & Newborn Care', 'Genomic testing informs screening, early diagnosis, and personalized clinical intervention in developmental disorders.'],
  ['Pharmacology', 'Drug-gene relationships help optimize dosing, reduce toxicity, and improve treatment response.'],
];

const timeline = [
  ['1990', 'Human Genome Project', 'Established the genomic foundation for modern molecular medicine and precision healthcare.'],
  ['1994', 'BRCA1 / BRCA2 Testing', 'Inherited cancer risk testing became one of the earliest high-impact examples of clinical genomics.'],
  ['1998', 'HER2-targeted Therapy', 'Molecular biomarker-guided treatment showed how targeted therapy could transform oncology.'],
  ['2004', 'EGFR-targeted Lung Cancer Therapy', 'Tumor mutation profiling became central to selecting molecularly matched therapies.'],
  ['2010s', 'Pharmacogenomics Implementation', 'Clinical pharmacogenomics expanded personalized prescribing and drug-response prediction.'],
  ['Present', 'AI-assisted Precision Medicine', 'AI now accelerates genomic interpretation, biomarker analysis, and decision support in clinical practice.'],
];

const publications = [
  ['A Strategy for Using Multigene Testing in Precision Oncology', 'Precision oncology and biomarker-guided treatment studies', 'Nature Reviews Clinical Oncology / NEJM'],
  ['Identification of BRCA1 and BRCA2 in Hereditary Cancer Risk', 'Foundational inherited cancer genomics studies', 'Science / Nature Genetics'],
  ['HER2 as a Therapeutic Target in Breast Cancer', 'Targeted therapy landmark studies', 'Science / NEJM'],
  ['EGFR Mutations and Targeted Therapy in Lung Cancer', 'Clinical genomics and precision oncology studies', 'NEJM / Science Translational Medicine'],
  ['Pharmacogenomics in Clinical Practice', 'Precision prescribing and genomic medicine implementation studies', 'Clinical Pharmacology & Therapeutics'],
  ['Genome Sequencing for Diagnosis in Rare Disease', 'Clinical genomics diagnostic studies', 'NEJM / Genetics in Medicine'],
];

const related = [
  ['Genome Sequencing', '/research/genomics/genome-sequencing'],
  ['Variant Discovery', '/research/genomics/variant-discovery'],
  ['Population Genomics', '/research/genomics/population-genomics'],
];
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Precision Medicine | PanorOmics Research</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      background:#020817;
      color:white;
      font-family:Inter,sans-serif;
      overflow-x:hidden;
    }

    .container{
      max-width:1200px;
      margin:auto;
      padding:80px 7% 70px;
    }

    .back{
      color:#3b82f6;
      text-decoration:none;
      font-size:.9rem;
      font-weight:700;
    }

    .hero{
      margin-top:34px;
    }

    .hero h1{
      font-size:clamp(2.7rem,5vw,4.8rem);
      line-height:.95;
      letter-spacing:-.055em;
      margin-bottom:18px;
    }

    .hero h1 span{
      color:#3b82f6;
    }

    .hero p{
      color:#cbd5e1;
      font-size:1rem;
      line-height:1.8;
      max-width:900px;
    }

    .hero-image{
      margin-top:36px;
      width:100vw;
      margin-left:calc(50% - 50vw);
    }

    .hero-image img{
      width:100%;
      display:block;
      border-radius:24px;
      border:1px solid rgba(59,130,246,.14);
    }

    .section{
      margin-top:64px;
    }

    .section h2{
      font-size:2rem;
      margin-bottom:16px;
    }

    .section h2 span{
      color:#3b82f6;
    }

    .section p{
      color:#cbd5e1;
      line-height:1.9;
      font-size:1rem;
      margin-bottom:16px;
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:20px;
      margin-top:24px;
    }

    .card{
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:24px;
    }

    .card h3{
      color:#3b82f6;
      margin-bottom:10px;
      line-height:1.3;
    }

    .card p{
      margin:0;
      font-size:.92rem;
      color:#cbd5e1;
    }

    .workflow{
      display:grid;
      gap:16px;
      margin-top:24px;
    }

    .workflow-item{
      display:grid;
      grid-template-columns:160px 1fr;
      gap:18px;
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:20px;
    }

    .workflow-label{
      color:#3b82f6;
      font-weight:900;
      font-size:1.05rem;
    }

    .timeline{
      display:grid;
      gap:16px;
      margin-top:24px;
    }

    .timeline-item{
      display:grid;
      grid-template-columns:120px 1fr;
      gap:18px;
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:20px;
    }

    .year{
      color:#3b82f6;
      font-weight:900;
      font-size:1.15rem;
    }

    .paper{
      background:rgba(8,15,35,.75);
      border:1px solid rgba(59,130,246,.12);
      border-radius:18px;
      padding:22px;
    }

    .paper h3{
      color:#3b82f6;
      margin-bottom:8px;
    }

    .meta{
      color:#94a3b8;
      font-size:.86rem;
      line-height:1.5;
    }

    .button{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      margin-top:24px;
      padding:12px 24px;
      border-radius:999px;
      background:#2563eb;
      color:white;
      text-decoration:none;
      font-weight:700;
    }

    .card-link{
      text-decoration:none;
      color:inherit;
      display:block;
      transition:.25s ease;
      cursor:pointer;
    }

    .card-link:hover{
      transform:translateY(-4px);
      border-color:#3b82f6;
      box-shadow:0 12px 30px rgba(59,130,246,.15);
    }

    .secondary-button{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      margin-top:12px;
      padding:14px 30px;
      border-radius:999px;
      background:#8C1515;
      color:#ffffff;
      border:1px solid #A77A7A;
      text-decoration:none;
      font-weight:700;
      transition:.25s ease;
    }

    .secondary-button:hover{
      background:#6F1111;
      border-color:#8C1515;
      transform:translateY(-2px);
    }

    @media(max-width:768px){
      .container{
        padding:70px 20px 55px;
      }

      .workflow-item,
      .timeline-item{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <a href="/genomics" class="back">
      ← Back to Genomics
    </a>

    <section class="hero">

      <h1>
        Precision <span>Medicine</span>
      </h1>

      <p>
        Precision medicine uses genomic information to improve diagnosis, risk assessment, treatment selection, and patient care. By connecting molecular variation to clinical decision-making, this field transforms genomic knowledge into individualized medicine.
      </p>

      <div class="hero-image">
        <img
          src="/research-precision-medicine-hero-v1.png"
          alt="Precision Medicine Research"
        >
      </div>

    </section>

    <section class="section">

      <h2>
        Research <span>Overview</span>
      </h2>

      <p>
        Precision medicine moves beyond one-size-fits-all healthcare by integrating genomic information into clinical care. It helps clinicians understand which patients are at risk, which therapies are most likely to work, and which genomic findings are relevant for diagnosis, prognosis, and long-term management.
      </p>

      <p>
        At PanorOmics, precision medicine is the clinical application of genomics: the point where sequencing, variant discovery, and interpretation become actionable for real patients. It bridges molecular biology, computational analysis, diagnostics, therapeutics, and longitudinal healthcare.
      </p>

    </section>

    <section class="section">

      <h2>
        Core <span>Research Areas</span>
      </h2>

      <div class="grid">

        {coreAreas.map(([title, text]) => (

          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Clinical <span>Workflow</span>
      </h2>

      <div class="workflow">

        {workflow.map(([title, text]) => (

          <div class="workflow-item">
            <div class="workflow-label">{title}</div>
            <div>
              <p>{text}</p>
            </div>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Clinical <span>Technologies</span>
      </h2>

      <div class="grid">

        {technologies.map(([title, text]) => (

          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Clinical <span>Applications</span>
      </h2>

      <div class="grid">

        {clinicalApplications.map(([title, text]) => (

          <div class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Landmark <span>Discoveries</span>
      </h2>

      <div class="timeline">

        {timeline.map(([year, title, text]) => (

          <div class="timeline-item">
            <div class="year">{year}</div>
            <div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          </div>

        ))}

      </div>

    </section>

    <section class="section">

      <h2>
        Featured <span>Publications</span>
      </h2>

      <div class="grid">

        {publications.map(([title, authors, journal]) => (

          <div class="paper">
            <h3>{title}</h3>
            <div class="meta">
              {authors}<br>
              {journal}
            </div>
          </div>

        ))}

      </div>

      <a href="/publications" class="button">
        Explore Publications Library →
      </a>

    </section>

    <section class="section">

      <h2>
        Continue Your <span>Research Journey</span>
      </h2>

      <div class="grid">

        {related.map(([title, href]) => (

          <a href={href} class="card card-link">
            <h3>{title} →</h3>
            <p>Continue exploring the Genomics Research Center.</p>
          </a>

        ))}

      </div>

      <a href="/online" class="secondary-button">
        Explore PanorOmics Online →
      </a>

    </section>

  </div>

</body>

</html>
