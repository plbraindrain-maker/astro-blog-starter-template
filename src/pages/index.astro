---
// PanorOmics Landing Page

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const omicsPillars = [
  {
    name: 'GENOMICS',
    border: '#2563eb',
    text: 'The complete set of DNA, including genes, variants, and genetic architecture.'
  },
  {
    name: 'TRANSCRIPTOMICS',
    border: '#00c853',
    text: 'Examine RNA molecules to understand gene expression and cellular function.'
  },
  {
    name: 'PROTEOMICS',
    border: '#c026ff',
    text: 'Analyze the full complement of proteins to uncover function, interactions, and pathways.'
  },
  {
    name: 'METABOLOMICS',
    border: '#ff1744',
    text: 'Profile metabolites to reveal biochemical activity and metabolic states.'
  },
  {
    name: 'LIPIDOMICS',
    border: '#ffb300',
    text: 'Investigate lipids and lipid species to understand membrane biology and signaling.'
  },
  {
    name: 'EPIGENOMICS',
    border: '#5e35ff',
    text: 'Explore epigenetic modifications regulating gene activity without changing DNA.'
  }
];
---

<!doctype html>
<html lang="en">
<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>PanorOmics</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html,body{
  background:#010611;
  color:white;
  font-family:system-ui,-apple-system,sans-serif;
  overflow-x:hidden;
}

/* NAVBAR */

.site-header{
  position:sticky;
  top:0;
  z-index:1000;
  background:rgba(1,6,17,0.95);
  backdrop-filter:blur(10px);
  border-bottom:1px solid rgba(255,255,255,0.05);
}

.header-container{
  max-width:1400px;
  margin:auto;
  padding:1rem 2rem;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.logo-group{
  display:flex;
  align-items:center;
  gap:1rem;
}

.logo-group img{
  width:58px;
  height:58px;
}

.brand-title{
  font-size:2rem;
  font-weight:800;
}

.brand-title span{
  color:#2563eb;
}

.brand-sub{
  color:#94a3b8;
  font-size:0.8rem;
  letter-spacing:0.08em;
}

.main-nav{
  display:flex;
  gap:1.5rem;
}

.nav-link{
  color:white;
  text-decoration:none;
  font-size:0.9rem;
  font-weight:600;
  transition:0.3s;
}

.nav-link:hover{
  color:#3b82f6;
}

/* HERO */

.hero-section{
  max-width:1400px;
  margin:auto;
  min-height:90vh;
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:center;
  gap:4rem;
  padding:4rem 2rem;
}

.hero-left h1{
  font-size:6rem;
  line-height:0.95;
  font-weight:900;
  letter-spacing:-0.05em;
}

.hero-left span{
  color:#3b82f6;
}

.hero-left p{
  margin-top:2rem;
  font-size:1.25rem;
  line-height:1.8;
  color:#cbd5e1;
  max-width:700px;
}

.hero-btn{
  display:inline-block;
  margin-top:2rem;
  background:#2563eb;
  color:white;
  padding:1rem 2rem;
  border-radius:999px;
  text-decoration:none;
  font-weight:700;
  transition:0.3s;
}

.hero-btn:hover{
  background:#1d4ed8;
}

.hero-right{
  display:flex;
  justify-content:center;
  align-items:center;
}

.hero-right img{
  width:100%;
  max-width:700px;
  border-radius:24px;
  box-shadow:0 0 80px rgba(37,99,235,0.25);
}

/* PILLARS */

.pillars-section{
  max-width:1400px;
  margin:auto;
  padding:5rem 2rem;
}

.pillars-heading-small{
  text-align:center;
  color:#64748b;
  letter-spacing:0.25em;
  margin-bottom:1rem;
}

.pillars-title{
  text-align:center;
  font-size:4rem;
  font-weight:800;
  margin-bottom:4rem;
}

.pillars-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:2rem;
}

.pillar-card{
  background:rgba(255,255,255,0.02);
  border:2px solid;
  border-radius:24px;
  padding:2rem;
  transition:0.3s;
  min-height:240px;
}

.pillar-card:hover{
  transform:translateY(-8px);
  box-shadow:0 0 30px rgba(37,99,235,0.15);
}

.pillar-name{
  font-size:2rem;
  font-weight:800;
  margin-bottom:1.5rem;
}

.pillar-description{
  color:#cbd5e1;
  line-height:1.8;
  font-size:1.1rem;
}

/* DOGMA */

.dogma-container{
  max-width:1200px;
  margin:auto;
  padding:6rem 2rem;
  text-align:center;
}

.dogma-container h2{
  font-size:4rem;
  font-weight:800;
  margin-bottom:1rem;
}

.dogma-subtitle{
  color:#94a3b8;
  font-size:1.3rem;
  margin-bottom:3rem;
}

.dogma-graphic-wrapper img{
  width:100%;
  border-radius:24px;
}

/* MOBILE */

@media(max-width:900px){

  .header-container{
    flex-direction:column;
    gap:1rem;
  }

  .main-nav{
    flex-wrap:wrap;
    justify-content:center;
  }

  .hero-section{
    grid-template-columns:1fr;
    text-align:center;
  }

  .hero-left h1{
    font-size:4rem;
  }

  .pillars-title{
    font-size:2.5rem;
  }

  .dogma-container h2{
    font-size:2.5rem;
  }

}

</style>

</head>

<body>

<header class="site-header">

<div class="header-container">

<div class="logo-group">

<img src="/logo.png" alt="PanorOmics Logo" />

<div>

<div class="brand-title">
Panor<span>Omics</span>
</div>

<div class="brand-sub">
INTEGRATING LIFE SCIENCES • DATA • DISCOVERY
</div>

</div>

</div>

<nav class="main-nav">

{navLinks.map(link => (
<a href={link.href} class="nav-link">
{link.name}
</a>
))}

</nav>

</div>

</header>

<!-- HERO -->

<section class="hero-section">

<div class="hero-left">

<h1>
Unifying <span>omics.</span><br />
Advancing <span>health.</span><br />
Transforming <span>lives.</span>
</h1>

<p>
PanorOmics integrates multi-omics data and advanced analytics
to accelerate discovery, enable precision medicine,
and improve human health.
</p>

<a href="/research" class="hero-btn">
Explore Our Research →
</a>

</div>

<div class="hero-right">

<img src="/main-landing.png" alt="PanorOmics Platform" />

</div>

</section>

<!-- PILLARS -->

<section class="pillars-section">

<div class="pillars-heading-small">
THE SIX PILLARS OF OMICS SCIENCE
</div>

<h2 class="pillars-title">
Integrated Omics Disciplines
</h2>

<div class="pillars-grid">

{omicsPillars.map((pillar) => (

<div
class="pillar-card"
style={`border-color:${pillar.border}`}
>

<div
class="pillar-name"
style={`color:${pillar.border}`}
>
{pillar.name}
</div>

<p class="pillar-description">
{pillar.text}
</p>

</div>

))}

</div>

</section>

<!-- CENTRAL DOGMA -->

<section class="dogma-container">

<h2>
The Central Dogma of Omics Science
</h2>

<p class="dogma-subtitle">
From information to function. From biology to impact.
</p>

<div class="dogma-graphic-wrapper">

<img
src="/central-dogma.png"
alt="Central Dogma of Omics Science"
/>

</div>

</section>

</body>
</html>
