---
// Final Interactive Presentation Canvas for PanorOmics
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/icon-mark.png" />
		<title>PanorOmics | Unifying Omics. Advancing Health. Transforming Lives.</title>
		<style>
			/* Reset browser settings */
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				scroll-behavior: smooth;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED LIGHT STICKY NAVIGATION HEADER */
			.site-header {
				background-color: #f4f7fa; 
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.header-logo-icon {
				height: 45px;
				width: auto;
				display: block;
				border-radius: 8px;
			}

			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; 
				letter-spacing: -0.5px;
			}

			.brand-subtitle {
				font-size: 0.7rem;
				color: #4a607a; 
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				margin-top: 1px;
			}

			/* PAGE SECTIONS CONTAINER */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			.page-section {
				width: 100%;
				max-width: 1400px;
				display: flex;
				justify-content: center;
				position: relative; /* Essential for aligning invisible links on top of the images */
			}

			.full-page-asset {
				width: 100%;
				height: auto;
				display: block;
			}

			/* INTERACTIVE INVISIBLE CLICK LINK CONTAINERS */
			.clickable-area {
				position: absolute;
				display: block;
				cursor: pointer;
				/* background-color: rgba(255, 0, 0, 0.2); Uncomment this line to see the boxes for testing */
			}
		</style>
	</head>
	<body>

		<!-- HEADER BAR -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<img src="/icon-mark.png" alt="PanorOmics Icon" class="header-logo-icon" />
					
						<span class="brand-text">PanorOmics</span>
						<span class="brand-subtitle">The Panoramic Omics Sciences Center</span>
					</div>
				</a>
			</div>
		</header>

		<!-- INFOGRAPHIC SCROLLING SECTIONS -->
		<div class="landing-container">
			
			<!-- SECTION 1: CORE RAW LOGO GRAPHIC DISPLAY (No code text, no cropping mistakes) -->
			<section class="page-section">
				<img 
					src="/panoromics-logo.png" 
					alt="PanorOmics - Unifying Omics. Advancing Health. Transforming Lives." 
					class="full-page-asset"
				/>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA INFOGRAPHIC LAYER WITH CLICKABLE TARGETS -->
			<section class="page-section">
				<img 
					src="/central-dogma.png" 
					alt="The Central Dogma of Omics Science" 
					class="full-page-asset"
				/>

				<!-- INVISIBLE LINK OVER GENOMICS LAYER -->
				<a href="/research#genomics" class="clickable-area" style="top: 72%; left: 12%; width: 12%; height: 25%;" title="Genomics Research"></a>

				<!-- INVISIBLE LINK OVER TRANSCRIPTOMICS LAYER -->
				<a href="/research#transcriptomics" class="clickable-area" style="top: 72%; left: 25%; width: 12%; height: 25%;" title="Transcriptomics Research"></a>

				<!-- INVISIBLE LINK OVER PROTEOMICS LAYER -->
				<a href="/research#proteomics" class="clickable-area" style="top: 72%; left: 50%; width: 12%; height: 25%;" title="Proteomics Research"></a>

				<!-- INVISIBLE LINK OVER METABOLOMIC INTERACTIONS LAYER -->
				<a href="/research#metabolomics" class="clickable-area" style="top: 72%; left: 74%; width: 12%; height: 25%;" title="Metabolomics Research"></a>
			</section>

		</div>
	</body>
</html>
