---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" /> <!-- FIXES THE SYMBOLS -->
		<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" /> <!-- FIXES CACHING -->
		<BaseHead title="panoromics" description="The Panoramic Omics Sciences Center" />
		<style>
			body { background-color: #FDFCF0; color: #003366; margin: 0; padding: 0; font-family: sans-serif; }
			main { max-width: 800px; margin: 100px auto; padding: 0 2rem; }
			h2 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; opacity: 0.8; }
			p { font-size: 1.15rem; line-height: 1.8; text-align: left; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h2>THE CENTRAL DOGMA OF OMICS SCIENCE</h2>
			<p>
				PanorOmics is dedicated to advancing precision medicine through multi-omics integration and innovative data science. 
				Our center explores the complex biological landscape—integrating 
				<strong>Genomics, Transcriptomics, Epigenomics & Chromatin Dynamics, Proteomics, Metabolomics,</strong> 
				and <strong>Computational Bioinformatics</strong> to solve pressing challenges in disease mechanisms.
			</p>
		</main>
		<Footer />
	</body>
</html>
