---
import HeaderLink from './HeaderLink.astro';
---

<header style="background: white; border-bottom: 1px solid #eee; padding: 0.8rem 0;">
	<nav style="display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 0 1rem;">
		
		<!-- CLEAN LOGO SECTION -->
		<a href="/" style="display: flex; align-items: center; text-decoration: none; gap: 15px;">
			<img 
				src="/logo.png" 
				alt="PanorOmics Logo" 
				style="height: 75px; width: auto;" 
			/>
			<div style="display: flex; flex-direction: column; line-height: 1.2;">
				<span style="font-size: 1.4rem; font-weight: 800; color: #0047AB; letter-spacing: -0.5px;">
					PanorOmics
				</span>
				<span style="font-size: 0.85rem; color: #666; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">
					Sciences Center
				</span>
			</div>
		</a>

		<!-- NAVIGATION -->
		<div class="internal-links" style="display: flex; gap: 25px;">
			<HeaderLink href="/" style="color: #333; font-weight: 500; text-decoration: none;">Home</HeaderLink>
			<HeaderLink href="/blog" style="color: #333; font-weight: 500; text-decoration: none;">Research</HeaderLink>
			<HeaderLink href="/about" style="color: #333; font-weight: 500; text-decoration: none;">About</HeaderLink>
		</div>
	</nav>
</header>
