---
// Forced Clean Production Reset
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/icon-mark.png" />
		<title>PanorOmics | integrating life sciences • data • discovery</title>
		<style>
			html, body {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				background-color: #010610;
				color: #ffffff;
				font-family: system-ui, -apple-system, sans-serif;
				width: 100%;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* FIXED LIGHT NAVIGATION HEADER */
			.site-header {
				background-color: #f4f7fa; 
				border-bottom: 1px solid rgba(0, 51, 102, 0.1);
				position: sticky;
				top: 0;
				z-index: 100;
				width: 100%;
				padding: 0.75rem 0;
			}

			.nav-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.brand-link {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.header-logo-icon {
				height: 45px !important;
				width: auto !important;
				display: block !important;
				border-radius: 8px !important;
				clip-path: none !important;
			}

			.text-identity {
				display: flex;
				flex-direction: column;
				line-height: 1.2;
			}

			.brand-text {
				font-size: 1.5rem;
				font-weight: 800;
				color: #00264d; 
				letter-spacing: -0.5px;
			}

			.brand-subtitle {
				font-size: 0.75rem;
				color: #00264d; 
				font-weight: 500;
				letter-spacing: 0.2px;
				margin-top: 2px;
			}

			#search-button {
				background: none;
				border: none;
				cursor: pointer;
				padding: 8px;
				display: flex;
				align-items: center;
			}

			/* LAYOUT MATRIX */
			.landing-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				background-color: #010610;
			}

			.hero-matrix-row {
				width: 100%;
				max-width: 1400px;
				padding: 4rem 2rem;
				box-sizing: border-box;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 3rem;
			}

			.left-logo-frame {
				width: 160px;
				height: 160px;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}

			.left-logo-frame img {
				width: 100%;
				height: auto;
				display: block;
			}

			.center-landing-link {
				display: block;
				width: 100%;
				max-width: 750px;
				cursor: pointer;
			}

			.page-section {
				width: 100%;
				max-width: 1400px;
				display: flex;
				justify-content: center;
				position: relative;
			}

			.full-page-asset {
				width: 100% !important;
				height: auto !important;
				display: block !important;
				border-radius: 0px !important;
				clip-path: none !important;
			}

			.clickable-area {
				position: absolute;
				display: block;
				cursor: pointer;
			}
		</style>
	</head>
	<body>

		<!-- FIXED STICKY HEADER -->
		<header class="site-header">
			<div class="nav-container">
				<a href="/" class="brand-link">
					<img src="/icon-mark.png" alt="PanorOmics Icon" class="header-logo-icon" />
					
						<span class="brand-text">PanorOmics</span>
						<!-- FORCED FIXED TAGLINE HERE -->
						<span class="brand-subtitle">integrating life sciences • data • discovery</span>
					</div>
				</a>

				<div class="header-actions">
					<button id="search-button" aria-label="Search site">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#003366" stroke-width="2.5">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
					</button>
				</div>
			</div>
		</header>

		<!-- CONTENT BLOCK MATRIX -->
		<div class="landing-container">
			
			<!-- SECTION 1: HERO MATRIX (Logo Left, Clickable Landing Graphic Center) -->
			<section class="hero-matrix-row">
				<div class="left-logo-frame">
					
				</div>
				
				<a href="/about" class="center-landing-link" title="Click to open landing content">
					<img src="/panoromics-logo.png" alt="PanorOmics Layout" class="full-page-asset" />
				</a>
			</section>

			<!-- SECTION 2: CENTRAL DOGMA INFOGRAPHIC LAYER WITH CLICKABLE TARGETS -->
			<section class="page-section">
				<img src="/central-dogma.png" alt="The Central Dogma of Omics Science" class="full-page-asset" />

				<!-- CLICK LINK AREA ASSIGNMENTS -->
				<a href="/research#genomics" class="clickable-area" style="top: 60%; left: 0%; width: 16.6%; height: 40%;"></a>
				<a href="/research#transcriptomics" class="clickable-area" style="top: 60%; left: 16.6%; width: 16.6%; height: 40%;"></a>
				<a href="/research#proteomics" class="clickable-area" style="top: 60%; left: 33.2%; width: 16.6%; height: 40%;"></a>
				<a href="/research#metabolomics" class="clickable-area" style="top: 60%; left: 49.8%; width: 16.6%; height: 40%;"></a>
				<a href="/research#lipidomics" class="clickable-area" style="top: 60%; left: 66.4%; width: 16.6%; height: 40%;"></a>
				<a href="/research#epigenomics" class="clickable-area" style="top: 60%; left: 83%; width: 17%; height: 40%;"></a>
			</section>

		</div>

		<script>
			document.getElementById('search-button')?.addEventListener('click', () => {
				const q = prompt("Search PanorOmics:");
				if (q) window.location.href = `/search?q=${encodeURIComponent(q)}`;
			});
		</script>
	</body>
</html>
