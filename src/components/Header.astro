---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header style="background: white; border-bottom: 1px solid #eee; padding: 1rem 0;">
	<nav style="display: flex; align-items: center; justify-content: space-between; max-width: 960px; margin: 0 auto; padding: 0 1rem;">
		
		<!-- LOGO AND TITLE SECTION -->
		<a href="/" style="display: flex; align-items: center; text-decoration: none; gap: 15px;">
			<img 
  src="/logo.png" 
  alt="PanorOmics Logo" 
  style="height: 85px !important; width: auto; max-height: none;" 
/>
			<span style="font-size: 1.5rem; font-weight: bold; color: #0047AB; line-height: 1.2;">
				Panoramic Omics <br/> Sciences Center
			</span>
		</a>

		<!-- NAVIGATION LINKS -->
		<div class="internal-links" style="display: flex; gap: 20px;">
			<HeaderLink href="/" style="color: #333; text-decoration: none;">Home</HeaderLink>
			<HeaderLink href="/blog" style="color: #333; text-decoration: none;">Research</HeaderLink>
			<HeaderLink href="/about" style="color: #333; text-decoration: none;">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		background: white;
		box-shadow: 0 2px 8px rgba(0,0,0,0.05);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
</style>
