  color:#60a5fa;
}

.hero{
  margin-top:36px;
}

h1{
  font-size:clamp(2.3rem,4vw,4rem);
  line-height:1;
  letter-spacing:-.05em;
  margin-bottom:20px;
}

h1 span{
  color:#3b82f6;
}

.lead{
  font-size:1rem;
  line-height:1.8;
  color:#cbd5e1;
