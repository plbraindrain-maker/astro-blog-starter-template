---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Research', href: '/research' },
  { name: 'Education', href: '/education' },
  { name: 'Platforms', href: '/platforms' },
  { name: 'Data', href: '/data' },
  { name: 'Publications', href: '/publications' },
  { name: 'News', href: '/news' },
  { name: 'Contact', href: '/contact' },
];

const omics = [
  { name: 'Genomics', href: '/research' },
  { name: 'Transcriptomics', href: '/research' },
  { name: 'Proteomics', href: '/research' },
  { name: 'Metabolomics', href: '/research' },
  { name: 'Lipidomics', href: '/research' },
  { name: 'Epigenomics', href: '/research' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PanorOmics</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}

body{
  background:#020817;
  color:white;
  font-family:Arial,Helvetica,sans-serif;
  overflow-x:hidden;
}

.header{
  background:white;
  padding:1rem 2rem;
}

.header-inner{
  max-width:1500px;
  margin:auto;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:2rem;
}

.brand{
  display:flex;
  align-items:center;
  gap:1rem;
  text-decoration:none;
}

.brand img{
  width:62px;
  height:62px;
}

.brand-title{
  font-size:2.8rem;
  font-weight:900;
  color:#020817;
  line-height:1;
}

.brand-title span{color:#2563eb}

.brand-sub{
  color:#64748b;
  font-size:.8rem;
  letter-spacing:.22em;
  margin-top:.25rem;
}

.nav{
  display:flex;
  gap:1.7rem;
  flex-wrap:wrap;
}

.nav a{
  color:#0f172a;
  text-decoration:none;
  font-weight:800;
}

.nav a:hover{color:#2563eb}

.hero{
  position:relative;
  min-height:88vh;
  padding:5rem 2rem;
  display:flex;
  align-items:center;
  background:
    radial-gradient(circle at 70% 45%,rgba(37,99,235,.35),transparent 40%),
    #020817;
  overflow:hidden;
}

.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:url('/main-landing.png') center right/contain no-repeat;
  opacity:.34;
  filter:saturate(1.15);
}

.hero::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(90deg,#020817 0%,rgba(2,8,23,.92) 33%,rgba(2,8,23,.45) 70%,rgba(2,8,23,.2) 100%);
}

.hero-inner{
  position:relative;
  z-index:2;
  max-width:1500px;
  margin:auto;
  width:100%;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:4rem;
  align-items:center;
}

.hero h1{
  font-size:clamp(4rem,6vw,7rem);
  line-height:1;
  font-weight:950;
  letter-spacing:-.05em;
}

.blue{color:#3b82f6}

.hero p{
  margin:2rem 0;
  max-width:680px;
  color:#dbeafe;
  font-size:1.25rem;
  line-height:1.8;
}

.actions{
  display:flex;
  gap:1rem;
  flex-wrap:wrap;
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:1rem 1.8rem;
  border-radius:999px;
  text-decoration:none;
  font-weight:900;
}

.btn-primary{
  background:#2563eb;
  color:white;
  box-shadow:0 0 40px rgba(37,99,235,.35);
}

.btn-secondary{
  border:1px solid rgba(96,165,250,.5);
  color:#dbeafe;
  background:rgba(37,99,235,.1);
}

.hero-panel{
  position:relative;
  z-index:3;
  border-radius:32px;
  overflow:hidden;
  box-shadow:0 0 90px rgba(37,99,235,.35);
}

.hero-panel img{
  width:100%;
  display:block;
}

.omics-row{
  max-width:1500px;
  margin:-2rem auto 0;
  position:relative;
  z-index:4;
  padding:0 2rem 5rem;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(190px,1fr));
  gap:1rem;
}

.omics-card{
  min-height:150px;
  padding:1.4rem;
  border-radius:20px;
  border:1px solid rgba(96,165,250,.25);
  background:rgba(255,255,255,.035);
  text-decoration:none;
  color:white;
  transition:.25s;
}

.omics-card:hover{
  transform:translateY(-6px);
  border-color:#3b82f6;
  box-shadow:0 0 35px rgba(37,99,235,.2);
}

.omics-card h3{
  margin-bottom:.7rem;
  font-size:1.25rem;
}

.omics-card p{
  color:#cbd5e1;
  line-height:1.6;
  font-size:.95rem;
}

.dogma{
  padding:5rem 2rem 7rem;
  text-align:center;
  background:#020817;
}

.dogma h2{
  font-size:clamp(2.8rem,5vw,5rem);
  line-height:1.05;
  font-weight:950;
  margin-bottom:1rem;
}

.dogma p{
  color:#94a3b8;
  font-size:1.3rem;
  margin-bottom:3rem;
}

.dogma-img{
  max-width:1500px;
  margin:auto;
  border-radius:30px;
  overflow:hidden;
  box-shadow:0 0 80px rgba(37,99,235,.25);
}

.dogma-img img{
  width:100%;
  display:block;
}

@media(max-width:1000px){
  .header-inner{flex-direction:column}
  .nav{justify-content:center}
  .hero-inner{grid-template-columns:1fr;text-align:center}
  .hero p{margin-left:auto;margin-right:auto}
  .actions{justify-content:center}
  .hero-panel{display:none}
  .hero::before{opacity:.22;background-size:cover}
  .brand-title{font-size:2rem}
}
</style>
</head>

<body>

<header class="header">
  <div class="header-inner">
    <a class="brand" href="/">
      <img src="/panoromics-logo.png" alt="PanorOmics Logo" />
      <div>
        <div class="brand-title">Panor<span>Omics</span></div>
        <div class="brand-sub">THE PANORAMIC OMICS SCIENCES CENTER</div>
      </div>
    </a>

    <nav class="nav">
      {navLinks.map(link => (
        <a href={link.href}>{link.name}</a>
      ))}
    </nav>
  </div>
</header>

<section class="hero">
  <div class="hero-inner">

    <div>
      <h1>
        Unifying <span class="blue">omics.</span><br />
        Advancing <span class="blue">health.</span><br />
        Transforming <span class="blue">lives.</span>
      </h1>

      <p>
        PanorOmics integrates multi-omics data, artificial intelligence,
        systems biology, and translational science to accelerate discovery,
        precision medicine, and biotechnology innovation.
      </p>

      <div class="actions">
        <a class="btn btn-primary" href="/research">Explore Research →</a>
        <a class="btn btn-secondary" href="/education">Education Programs</a>
      </div>
    </div>

    <a class="hero-panel" href="/research">
      <img src="/main-landing.png" alt="PanorOmics landing visual" />
    </a>

  </div>
</section>

<section class="omics-row">
  {omics.map(item => (
    <a class="omics-card" href={item.href}>
      <h3>{item.name}</h3>
      <p>Explore integrated {item.name.toLowerCase()} within the PanorOmics ecosystem.</p>
    </a>
  ))}
</section>

<section class="dogma">
  <h2>The Central Dogma of Omics Science</h2>
  <p>From information to function. From biology to impact.</p>

  <div class="dogma-img">
    <img src="/central-dogma.png" alt="Central Dogma of Omics Science" />
  </div>
</section>

</body>
</html>
